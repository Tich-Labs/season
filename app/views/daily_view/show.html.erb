<% content_for(:page_title) { @date.strftime("%B") } %>
<% content_for(:header_left) do %>
  <%= link_to user_root_path(date: @date.to_s),
        style: "color:#933a35; font-size:15px; font-weight:500; text-decoration:none; padding:8px 4px; font-family:'Montserrat',sans-serif; letter-spacing:0.04em; white-space:nowrap;" do %>
    &lt; back
  <% end %>
<% end %>

<% content_for(:header_right) do %>
  <div style="display:flex; align-items:center; gap:2px;">
    <%= link_to daily_view_path(date: (@date - 1.day).to_s),
          style: "width:36px; height:36px; display:flex; align-items:center; justify-content:center; color:#933a35;" do %>
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
    <% end %>
    <%= link_to daily_view_path(date: (@date + 1.day).to_s),
          style: "width:36px; height:36px; display:flex; align-items:center; justify-content:center; color:#933a35;" do %>
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
    <% end %>
  </div>
<% end %>

<%
  hour_px          = 64
  timeline_start_h = 6
  timeline_end_h   = 22
  phase_col        = @phase_colour || "#933a35"
  name             = current_user.first_name.presence || "there"

  fertility_status = case @phase
  when "menstrual"  then "unlikely"
  when "follicular" then "possible"
  when "ovulation"  then "peak fertility"
  when "luteal"     then "unlikely"
  else nil
  end
%>

<div style="background:#FFFFFF; min-height:100vh; padding-bottom:100px; font-family:'Montserrat',sans-serif;">
  <div style="max-width:430px; margin:0 auto;">

    <%# ── Greeting banner (Figma: Kalender April — phase-coloured header) ── %>
    <div style="background:<%= phase_col %>; padding:20px 16px 18px;">
      <p style="color:#FFFFFF; font-size:28px; font-weight:500; margin:0 0 4px; line-height:1.15;">
        Hello <%= name %>
      </p>
      <% if @phase %>
        <p style="color:#FFFFFF; font-size:14px; font-weight:400; margin:0; opacity:0.9; line-height:1.4;">
          You are in your <%= @season || @phase.capitalize %><br>And this is your day:
        </p>
      <% end %>
    </div>

    <%# ── Week strip ── %>
    <div style="padding:10px 8px 0; background:#FFFFFF;">
      <div style="display:grid; grid-template-columns:repeat(7,1fr);">
        <% %w[M T W T F S S].each_with_index do |letter, i| %>
          <div style="text-align:center; font-size:12px; font-weight:500; color:<%= i >= 5 ? '#D18D84' : '#933a35' %>; padding:2px 0;">
            <%= letter %>
          </div>
        <% end %>
        <% @week_dates.each_with_index do |day, i| %>
          <% is_selected = day == @date; is_weekend = i >= 5; num_col = is_weekend ? "#D18D84" : "#933a35" %>
          <div style="text-align:center; padding:4px 0;">
            <% if is_selected %>
              <span style="display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; background:<%= phase_col %>; color:#FFFFFF; font-size:15px; font-weight:700;">
                <%= day.day %>
              </span>
            <% else %>
              <%= link_to day.day, daily_view_path(date: day.to_s),
                    style: "display:inline-block; color:#{num_col}; font-size:15px; font-weight:500; text-decoration:none; width:28px; height:28px; line-height:28px; text-align:center;" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── All-day events ── %>
    <% if @all_day_events.any? %>
      <div style="margin-top:8px;">
        <% @all_day_events.each do |evt| %>
          <div style="background:#EDE1D5; padding:6px 12px; display:flex; align-items:center; gap:12px; min-height:26px;">
            <span style="font-size:11px; font-weight:500; color:<%= phase_col %>; min-width:44px;">All day</span>
            <span style="font-size:15px; font-weight:700; color:<%= phase_col %>;"><%= evt.title %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Timeline ── %>
    <div style="margin-top:10px; padding-bottom:16px;">
      <div style="position:relative; height:<%= (timeline_end_h - timeline_start_h + 1) * hour_px %>px;">

        <%# Hour grid lines and time labels %>
        <% (timeline_start_h..timeline_end_h).each do |hour| %>
          <div style="position:absolute; left:0; right:0; top:<%= (hour - timeline_start_h) * hour_px %>px; display:flex; align-items:center;">
            <span style="width:44px; text-align:right; padding-right:8px; font-size:11px; color:#AFAFAF; flex-shrink:0; line-height:1; font-family:'Montserrat',sans-serif;">
              <%= sprintf("%02d:00", hour) %>
            </span>
            <div style="flex:1; height:1px; background:#EDE1D5;"></div>
          </div>
        <% end %>

        <%# Current time line (today only) %>
        <% if @date == Date.today %>
          <% now = Time.now; now_top = [((now.hour - timeline_start_h) * hour_px + now.min.to_f * hour_px / 60.0).round, 0].max %>
          <div style="position:absolute; left:44px; right:0; top:<%= now_top %>px; height:2px; background:<%= phase_col %>; z-index:2; pointer-events:none;">
            <div style="position:absolute; left:-4px; top:-3px; width:8px; height:8px; border-radius:50%; background:<%= phase_col %>;"></div>
          </div>
        <% end %>

        <%# Timed event blocks %>
        <% @timed_events.each do |evt| %>
          <% st = evt.start_time; et = evt.end_time %>
          <% s_h = st.hour; s_m = st.min %>
          <% next if s_h < timeline_start_h || s_h > timeline_end_h %>
          <% dur = et ? ((et.hour * 60 + et.min) - (st.hour * 60 + st.min)) : 60 %>
          <% dur = 30 if dur <= 0 %>
          <% top_px    = ((s_h - timeline_start_h) * hour_px + s_m.to_f * hour_px / 60.0).round %>
          <% height_px = [(dur * hour_px / 60.0).round, 26].max %>
          <%= link_to edit_calendar_event_path(evt),
                style: "position:absolute; left:48px; right:8px; top:#{top_px}px; height:#{height_px}px; background:#{phase_col}; border-radius:6px; padding:5px 8px; overflow:hidden; box-sizing:border-box; z-index:1; text-decoration:none; display:block;" do %>
            <div style="color:#FFFFFF; font-size:11px; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; line-height:1.3;"><%= evt.title %></div>
            <% if height_px > 30 && et %>
              <div style="color:#FFFFFF; font-size:10px; opacity:0.8; margin-top:1px;"><%= st.strftime("%H:%M") %>&ndash;<%= et.strftime("%H:%M") %></div>
            <% end %>
            <% if height_px > 46 && evt.notes.present? %>
              <div style="color:#FFFFFF; font-size:10px; opacity:0.85; margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Note: <%= evt.notes %></div>
            <% end %>
          <% end %>
        <% end %>

      </div>
    </div>

    <%# ── Phase tips (Figma: Verwenden) ── %>
    <% if @phase %>
      <div style="border-top:1px solid #EDE1D5; padding:16px 16px 8px; background:#FFFFFF;">
        <p style="color:<%= phase_col %>; font-size:13px; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; margin:0 0 12px;">
          Here are your tips for today:
        </p>

        <div style="display:flex; flex-direction:column; gap:8px;">

          <%# Super Power %>
          <% if @content&.superpower_text.present? %>
            <div style="background:<%= phase_col %>; border-radius:10px; padding:12px 14px;">
              <p style="color:#FFFFFF; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin:0 0 3px; opacity:0.8;">Super Power</p>
              <p style="color:#FFFFFF; font-size:15px; font-weight:500; margin:0; line-height:1.3;"><%= @content.superpower_text %></p>
            </div>
          <% end %>

          <%# Watch out for %>
          <% if @content&.take_care_text.present? %>
            <div style="background:<%= phase_col %>; border-radius:10px; padding:12px 14px;">
              <p style="color:#FFFFFF; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin:0 0 3px; opacity:0.8;">Watch out for</p>
              <p style="color:#FFFFFF; font-size:15px; font-weight:500; margin:0; line-height:1.3;"><%= @content.take_care_text %></p>
            </div>
          <% end %>

          <%# Sport %>
          <% if @content&.sport_text.present? %>
            <div style="background:<%= phase_col %>; border-radius:10px; padding:12px 14px;">
              <p style="color:#FFFFFF; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin:0 0 3px; opacity:0.8;">Sport</p>
              <p style="color:#FFFFFF; font-size:15px; font-weight:500; margin:0; line-height:1.3;"><%= @content.sport_text %></p>
            </div>
          <% end %>

          <%# Nutrition %>
          <% if @content&.nutrition_text.present? %>
            <div style="background:<%= phase_col %>; border-radius:10px; padding:12px 14px;">
              <p style="color:#FFFFFF; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin:0 0 3px; opacity:0.8;">Nutrition</p>
              <p style="color:#FFFFFF; font-size:15px; font-weight:500; margin:0; line-height:1.3;"><%= @content.nutrition_text %></p>
            </div>
          <% end %>

          <%# Fertility %>
          <% if fertility_status %>
            <div style="background:<%= phase_col %>; border-radius:10px; padding:12px 14px;">
              <p style="color:#FFFFFF; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin:0 0 3px; opacity:0.8;">Fertility</p>
              <p style="color:#FFFFFF; font-size:15px; font-weight:500; margin:0;"><%= fertility_status %></p>
            </div>
          <% end %>

          <%# Mood %>
          <% if @content&.mood_text.present? %>
            <div style="background:<%= phase_col %>; border-radius:10px; padding:12px 14px;">
              <p style="color:#FFFFFF; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin:0 0 3px; opacity:0.8;">Mood</p>
              <p style="color:#FFFFFF; font-size:15px; font-weight:500; margin:0; line-height:1.3;"><%= @content.mood_text %></p>
            </div>
          <% end %>

        </div>
      </div>
    <% end %>

  </div>
</div>

<%# ── FAB: add event ── %>
<div style="position:fixed; bottom:80px; left:50%; transform:translateX(-50%); z-index:40;">
  <%= link_to new_calendar_event_path(date: @date.to_s),
        style: "width:60px; height:60px; border-radius:30px; background:#EDE1D5; display:flex; align-items:center; justify-content:center; box-shadow:0 4px 16px rgba(0,0,0,0.15); text-decoration:none;" do %>
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#933a35" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
  <% end %>
</div>
