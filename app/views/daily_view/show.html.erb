<% content_for(:page_title) { @date.strftime("%B") } %>
<% content_for(:header_left) do %>
  <%= link_to user_root_path(date: @date.to_s),
        class: "text-brand-primary font-montserrat text-base font-medium no-underline px-1 py-2 tracking-wider whitespace-nowrap" do %>
    &lt; back
  <% end %>
<% end %>

<% content_for(:header_right) do %>
  <div class="flex items-center gap-0.5">
    <%= link_to daily_view_path(date: (@date - 1.day).to_s),
          aria: { label: "Previous day" },
          class: "w-9 h-9 flex items-center justify-center text-brand-primary" do %>
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polyline points="15 18 9 12 15 6" /></svg>
    <% end %>
    <%= link_to daily_view_path(date: (@date + 1.day).to_s),
          aria: { label: "Next day" },
          class: "w-9 h-9 flex items-center justify-center text-brand-primary" do %>
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6" /></svg>
    <% end %>
  </div>
<% end %>

<%
  hour_px          = 64
  timeline_start_h = 6
  timeline_end_h   = 22
  phase_col        = @phase_colour || "#933a35"
  name             = current_user.first_name.presence || "there"

  fertility_status = case @phase
  when "menstrual"  then "unlikely"
  when "follicular" then "possible"
  when "ovulation"  then "peak fertility"
  when "luteal"     then "unlikely"
  else nil
  end
%>

<div class="bg-white min-h-screen pb-24">
  <div class="max-w-app mx-auto">

    <%# ── Greeting banner (Figma: Kalender April — phase-coloured header) ── %>
    <div class="py-5 px-4" style="background: <%= phase_col %>;">
      <p class="text-white text-3xl font-medium m-0 mb-1 leading-tight">
        Hello <%= name %>
      </p>
      <% if @phase %>
        <p class="text-white text-sm font-normal m-0 opacity-90 leading-relaxed">
          You are in your <%= @season || @phase.capitalize %><br>And this is your day:
        </p>
      <% end %>
    </div>

    <%# ── Week strip ── %>
    <div class="px-2 pt-2.5 bg-white">
      <div class="grid grid-cols-7">
        <% %w[M T W T F S S].each_with_index do |letter, i| %>
          <div class="text-center text-xs font-medium py-0.5" style="color: <%= i >= 5 ? '#D18D84' : '#933a35' %>;">
            <%= letter %>
          </div>
        <% end %>
        <% @week_dates.each_with_index do |day, i| %>
          <% is_selected = day == @date; is_weekend = i >= 5; num_col = is_weekend ? "#D18D84" : "#933a35" %>
          <div class="text-center py-1">
            <% if is_selected %>
              <span class="inline-flex items-center justify-center w-11 h-11 rounded-full text-white text-base font-bold" style="background: <%= phase_col %>;">
                <%= day.day %>
              </span>
            <% else %>
              <%= link_to day.day, daily_view_path(date: day.to_s),
                    class: "inline-block font-medium text-base no-underline w-11 h-11 leading-11 text-center", style: "color: #{num_col};" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── All-day events ── %>
    <% if @all_day_events.any? %>
      <div class="mt-2">
        <% @all_day_events.each do |evt| %>
          <div class="bg-brand-field px-3 py-1.5 flex items-center gap-3 min-h-6">
            <span class="text-xs font-medium min-w-11" style="color: <%= phase_col %>;">All day</span>
            <span class="text-base font-bold" style="color: <%= phase_col %>;"><%= evt.title %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Timeline ── %>
    <div class="mt-2.5 pb-4">
      <div style="position:relative; height:<%= (timeline_end_h - timeline_start_h + 1) * hour_px %>px;">

        <%# Hour grid lines and time labels %>
        <% (timeline_start_h..timeline_end_h).each do |hour| %>
          <div style="position:absolute; left:0; right:0; top:<%= (hour - timeline_start_h) * hour_px %>px;" class="flex items-center">
            <span style="width:44px; text-align:right; padding-right:8px; font-size:11px; color:#AFAFAF; flex-shrink:0; line-height:1;">
              <%= sprintf("%02d:00", hour) %>
            </span>
            <div style="flex:1; height:1px; background:#EDE1D5;"></div>
          </div>
        <% end %>

        <%# Current time line (today only) %>
        <% if @date == Time.zone.today %>
          <% now = Time.now; now_top = [((now.hour - timeline_start_h) * hour_px + now.min.to_f * hour_px / 60.0).round, 0].max %>
          <div style="position:absolute; left:44px; right:0; top:<%= now_top %>px; height:2px; background:<%= phase_col %>; z-index:2; pointer-events:none;">
            <div style="position:absolute; left:-4px; top:-3px; width:8px; height:8px; border-radius:50%; background:<%= phase_col %>;"></div>
          </div>
        <% end %>

        <%# Timed event blocks %>
        <% @timed_events.each do |evt| %>
          <% st = evt.start_time; et = evt.end_time %>
          <% s_h = st.hour; s_m = st.min %>
          <% next if s_h < timeline_start_h || s_h > timeline_end_h %>
          <% dur = et ? ((et.hour * 60 + et.min) - (st.hour * 60 + st.min)) : 60 %>
          <% dur = 30 if dur <= 0 %>
          <% top_px    = ((s_h - timeline_start_h) * hour_px + s_m.to_f * hour_px / 60.0).round %>
          <% height_px = [(dur * hour_px / 60.0).round, 26].max %>
          <%= link_to edit_calendar_event_path(evt),
                class: "absolute no-underline block", style: "left:48px; right:8px; top:#{top_px}px; height:#{height_px}px; background:#{phase_col}; border-radius:6px; padding:5px 8px; overflow:hidden; box-sizing:border-box; z-index:1;" do %>
            <div class="text-white text-xs font-bold whitespace-nowrap overflow-hidden text-ellipsis leading-relaxed"><%= evt.title %></div>
            <% if height_px > 30 && et %>
              <div class="text-white text-xs opacity-80 mt-0.5"><%= st.strftime("%H:%M") %>&ndash;<%= et.strftime("%H:%M") %></div>
            <% end %>
            <% if height_px > 46 && evt.notes.present? %>
              <div class="text-white text-xs opacity-85 mt-0.5 whitespace-nowrap overflow-hidden text-ellipsis">Note: <%= evt.notes %></div>
            <% end %>
          <% end %>
        <% end %>

      </div>
    </div>

    <%# ── Phase tips (Figma: Verwenden) ── %>
    <% if @phase %>
      <div class="border-t border-brand-field px-4 py-4 pb-2 bg-white">
        <p class="text-sm font-semibold uppercase tracking-wider m-0 mb-3" style="color: <%= phase_col %>;">
          Here are your tips for today:
        </p>

        <div class="flex flex-col gap-2">

          <%# Super Power %>
          <% if @content&.superpower_text.present? %>
            <div class="rounded-lg px-3.5 py-3" style="background: <%= phase_col %>;">
              <p class="text-white text-xs font-semibold uppercase tracking-widest m-0 mb-0.5 opacity-80">Super Power</p>
              <p class="text-white text-base font-medium m-0 leading-snug"><%= @content.superpower_text %></p>
            </div>
          <% end %>

          <%# Watch out for %>
          <% if @content&.take_care_text.present? %>
            <div class="rounded-lg px-3.5 py-3" style="background: <%= phase_col %>;">
              <p class="text-white text-xs font-semibold uppercase tracking-widest m-0 mb-0.5 opacity-80">Watch out for</p>
              <p class="text-white text-base font-medium m-0 leading-snug"><%= @content.take_care_text %></p>
            </div>
          <% end %>

          <%# Sport %>
          <% if @content&.sport_text.present? %>
            <div class="rounded-lg px-3.5 py-3" style="background: <%= phase_col %>;">
              <p class="text-white text-xs font-semibold uppercase tracking-widest m-0 mb-0.5 opacity-80">Sport</p>
              <p class="text-white text-base font-medium m-0 leading-snug"><%= @content.sport_text %></p>
            </div>
          <% end %>

          <%# Nutrition %>
          <% if @content&.nutrition_text.present? %>
            <div class="rounded-lg px-3.5 py-3" style="background: <%= phase_col %>;">
              <p class="text-white text-xs font-semibold uppercase tracking-widest m-0 mb-0.5 opacity-80">Nutrition</p>
              <p class="text-white text-base font-medium m-0 leading-snug"><%= @content.nutrition_text %></p>
            </div>
          <% end %>

          <%# Fertility %>
          <% if fertility_status %>
            <div class="rounded-lg px-3.5 py-3" style="background: <%= phase_col %>;">
              <p class="text-white text-xs font-semibold uppercase tracking-widest m-0 mb-0.5 opacity-80">Fertility</p>
              <p class="text-white text-base font-medium m-0"><%= fertility_status %></p>
            </div>
          <% end %>

          <%# Mood %>
          <% if @content&.mood_text.present? %>
            <div class="rounded-lg px-3.5 py-3" style="background: <%= phase_col %>;">
              <p class="text-white text-xs font-semibold uppercase tracking-widest m-0 mb-0.5 opacity-80">Mood</p>
              <p class="text-white text-base font-medium m-0 leading-snug"><%= @content.mood_text %></p>
            </div>
          <% end %>

        </div>
      </div>
    <% end %>
