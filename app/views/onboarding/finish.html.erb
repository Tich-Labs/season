<meta name="turbo-cache-control" content="no-cache">

<div class="relative bg-white min-h-screen overflow-hidden">
  <div class="absolute left-0 top-0 w-full h-7 bg-white overflow-hidden">
    <div class="absolute left-[8px] top-[4px] text-zinc-900 text-xs font-normal font-['Montserrat'] leading-4 tracking-wide">12:30</div>
    <div class="absolute left-[368px] top-[4px] w-4 h-4 overflow-hidden">
      <div class="absolute left-0 top-[2.67px] w-4 h-3 bg-zinc-400"></div>
      <div class="absolute left-[1.64px] top-[5.67px] w-3 h-2 bg-zinc-900"></div>
    </div>
    <div class="absolute left-[388px] top-[4px] w-4 h-4 overflow-hidden">
      <div class="absolute left-[1.33px] top-[1.33px] w-3.5 h-3.5 bg-zinc-900"></div>
      <div class="absolute left-[11px] top-[1.33px] w-1 h-3.5 bg-zinc-400"></div>
    </div>
    <div class="absolute left-[408px] top-[4px] w-4 h-4 overflow-hidden">
      <div class="absolute left-[5px] top-[2px] w-1.5 h-3.5 bg-zinc-900"></div>
      <div class="absolute left-[5px] top-[2px] w-1.5 h-1.5 bg-zinc-400"></div>
    </div>
  </div>

  <div class="flex flex-col items-center justify-start pt-16 px-6">
    <div class="w-80 h-96">
      <%= image_tag 'ef5a97eb1ce5997f5ce9b1a64aeafe4e00026251.gif',
          class: 'w-full h-full object-contain',
          alt: t('.animation_alt') %>
    </div>

    <p class="mt-10 text-center text-[#933a35] text-[22px] leading-[32px] font-medium tracking-wide max-w-[320px]">
      <%= t('.message') %>
    </p>
  </div>
</div>

<script>
  window.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
      window.location.href = '<%= calendar_path %>';
    }, 10000);
  });
</script>
