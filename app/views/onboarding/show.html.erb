<div class="space-y-8">
  <% case @step %>
  <% when 1 %>
    <div class="text-center">
      <h1 class="font-serif text-3xl text-season-charcoal mb-3">When were you born?</h1>
      <p class="text-gray-500">We use this to calculate your cycle</p>
    </div>

    <%= form_with url: onboarding_path(step: 1), method: :post, class: "space-y-6" do |f| %>
      <div class="flex gap-3 justify-center">
        <select name="birthday(2i)" class="form-input rounded-xl text-center text-lg py-4 flex-1">
          <option value="">Month</option>
          <% (1..12).each do |m| %>
            <option value="<%= m %>"><%= Date.new(2024, m).strftime("%B") %></option>
          <% end %>
        </select>
        <select name="birthday(3i)" class="form-input rounded-xl text-center text-lg py-4 flex-1">
          <option value="">Day</option>
          <% (1..31).each do |d| %>
            <option value="<%= d %>"><%= d %></option>
          <% end %>
        </select>
        <select name="birthday(1i)" class="form-input rounded-xl text-center text-lg py-4 flex-1">
          <option value="">Year</option>
          <% (1970..2006).to_a.reverse.each do |y| %>
            <option value="<%= y %>"><%= y %></option>
          <% end %>
        </select>
      </div>

      <button type="submit" class="btn-primary w-full">Continue</button>
    <% end %>

  <% when 2 %>
    <div class="text-center">
      <h1 class="font-serif text-3xl text-season-charcoal mb-3">How long is your cycle?</h1>
      <p class="text-gray-500">Most people have a 28-day cycle</p>
    </div>

    <%= form_with url: onboarding_path(step: 2), method: :post, class: "space-y-6" do |f| %>
      <div class="grid grid-cols-7 gap-2">
        <% (21..35).each do |days| %>
          <label class="cursor-pointer">
            <input type="radio" name="cycle_length" value="<%= days %>" class="peer sr-only">
            <div class="text-center py-3 rounded-xl border-2 border-gray-200 peer-checked:border-season-terra peer-checked:bg-season-terra peer-checked:text-white transition-colors">
              <%= days %>
            </div>
          </label>
        <% end %>
      </div>

      <button type="submit" class="btn-primary w-full">Continue</button>
    <% end %>

  <% when 3 %>
    <div class="text-center">
      <h1 class="font-serif text-3xl text-season-charcoal mb-3">How long is your period?</h1>
      <p class="text-gray-500">Typically 3-7 days</p>
    </div>

    <%= form_with url: onboarding_path(step: 3), method: :post, class: "space-y-6" do |f| %>
      <div class="grid grid-cols-5 gap-2">
        <% (2..10).each do |days| %>
          <label class="cursor-pointer">
            <input type="radio" name="period_length" value="<%= days %>" class="peer sr-only">
            <div class="text-center py-4 rounded-xl border-2 border-gray-200 peer-checked:border-season-terra peer-checked:bg-season-terra peer-checked:text-white transition-colors text-lg">
              <%= days %>
            </div>
          </label>
        <% end %>
      </div>

      <button type="submit" class="btn-primary w-full">Let's go</button>
    <% end %>
  <% end %>
</div>

<div class="flex justify-center gap-2 mt-8">
  <% (1..3).each do |i| %>
    <div class="w-2 h-2 rounded-full <%= i == @step ? 'bg-season-terra' : 'bg-gray-300' %>"></div>
  <% end %>
</div>
