<div class="bg-white min-h-screen flex flex-col items-center pt-16 pb-12 px-6 max-w-app mx-auto">

  <%= image_tag "season-logo.svg", class: "w-32 h-auto mb-12", alt: "Season" %>

  <h1 class="text-xl font-bold text-brand-primary text-center mb-2">
    <%= "Welcome back, #{@user.name}!" %>
  </h1>

  <p class="text-sm text-brand-primary text-center mb-10">
    Your Season V2 account is ready.
  </p>

  <%= form_with url: invite_path(params[:token]),
      method: :patch do |f| %>

    <!-- Email pre-filled read-only -->
    <input type="email"
      value="<%= @user.email %>"
      autocomplete="email"
      readonly
      class="w-full bg-[#F5EDE8] rounded-2xl p-4 border-none text-base text-brand-primary opacity-70 mb-3">

    <!-- Password field -->
    <%= f.password_field :password,
        placeholder: 'Set your password...',
        class: "w-full bg-[#F5EDE8] rounded-2xl p-4 border-none text-base mb-8" %>

    <%= f.submit 'Get started',
        class: "w-full bg-brand-primary text-white border-none rounded-2xl p-4 text-base font-semibold cursor-pointer" %>
  <% end %>
</div>
