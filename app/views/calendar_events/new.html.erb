<% content_for(:page_title) { "Appointment" } %>
<% content_for(:header_left) do %>
  <%= link_to (params[:date] ? daily_view_path(date: params[:date]) : user_root_path),
        style: "color:#933a35; font-size:15px; font-weight:500; text-decoration:none; padding:8px 4px; font-family:'Montserrat',sans-serif;" do %>
    &lt; back
  <% end %>
<% end %>

<%
  phase     = current_user.current_phase
  phase_col = CycleCalculatorService::PHASE_META[phase]&.dig(:colour) || "#933a35"
  evt_date  = params[:date] ? Date.parse(params[:date]) : Time.zone.today
%>

<div style="background:#FAF7F4; min-height:100vh; padding-bottom:40px; font-family:'Montserrat',sans-serif;">
  <div style="max-width:430px; margin:0 auto;">

    <%= form_with model: @event, url: calendar_events_path, local: true do |f| %>

      <%# ── Phase-coloured title block (Figma: top rectangle 360×125) ── %>
      <div style="background:<%= phase_col %>; padding:24px 20px 20px;">
        <%= f.text_field :title,
              placeholder: "Enter title",
              required: true,
              style: "width:100%; background:transparent; border:none; border-bottom:2px solid rgba(255,255,255,0.5); color:#FFFFFF; font-size:22px; font-weight:600; font-family:'Montserrat',sans-serif; padding:4px 0 8px; outline:none; box-sizing:border-box;",
              "data-placeholder-color": "rgba(255,255,255,0.6)" %>
      </div>

      <%# ── Date + time row ── %>
      <div style="background:#FFFFFF; padding:14px 20px; border-bottom:1px solid #EDE1D5; display:flex; align-items:center; gap:12px;">
        <%= vuesax_icon "calendar", size: 20, colour: phase_col, style: "flex-shrink:0;" %>
        <div style="flex:1;">
          <%= f.date_field :date,
                value: evt_date,
                required: true,
                style: "width:100%; background:transparent; border:none; font-size:16px; color:#3d2b28; font-family:'Montserrat',sans-serif; outline:none; padding:0;" %>
        </div>
      </div>

      <%# ── Time range row ── %>
      <div style="background:#FFFFFF; padding:14px 20px; border-bottom:1px solid #EDE1D5; display:flex; align-items:center; gap:12px;">
        <%= vuesax_icon "clock", size: 20, colour: phase_col, style: "flex-shrink:0;" %>
        <div style="display:flex; align-items:center; gap:8px; flex:1;">
          <%= f.time_field :start_time,
                style: "background:#EDE1D5; border:none; border-radius:8px; padding:8px 10px; font-size:15px; color:#3d2b28; font-family:'Montserrat',sans-serif; outline:none;" %>
          <span style="color:#6B6B6B; font-size:14px;">&ndash;</span>
          <%= f.time_field :end_time,
                style: "background:#EDE1D5; border:none; border-radius:8px; padding:8px 10px; font-size:15px; color:#3d2b28; font-family:'Montserrat',sans-serif; outline:none;" %>
        </div>
      </div>

      <%# ── Option rows ── %>

      <%# Reminder row — decorative for now (no DB column) %>
      <div style="background:#FFFFFF; padding:14px 20px; border-bottom:1px solid #EDE1D5; display:flex; align-items:center; gap:12px;">
        <%= vuesax_icon "notification", size: 20, colour: phase_col, style: "flex-shrink:0;" %>
        <span style="color:#3d2b28; font-size:15px; flex:1;">15 minutes before</span>
        <svg width="16" height="16" fill="none" stroke="#AFAFAF" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </div>

      <%# Repeat row — decorative %>
      <div style="background:#FFFFFF; padding:14px 20px; border-bottom:1px solid #EDE1D5; display:flex; align-items:center; gap:12px;">
        <svg width="20" height="20" fill="none" stroke="<%= phase_col %>" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;">
          <polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
        </svg>
        <span style="color:#3d2b28; font-size:15px; flex:1;">Repeat</span>
        <svg width="16" height="16" fill="none" stroke="#AFAFAF" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </div>

      <%# Location row — decorative %>
      <div style="background:#FFFFFF; padding:14px 20px; border-bottom:1px solid #EDE1D5; display:flex; align-items:center; gap:12px;">
        <%= vuesax_icon "location", size: 20, colour: phase_col, style: "flex-shrink:0;" %>
        <span style="color:#AFAFAF; font-size:15px; flex:1;">Add location</span>
        <svg width="16" height="16" fill="none" stroke="#AFAFAF" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </div>

      <%# Notes row — functional %>
      <div style="background:#FFFFFF; padding:14px 20px; border-bottom:1px solid #EDE1D5; display:flex; align-items:flex-start; gap:12px;">
        <%= vuesax_icon "document-text", size: 20, colour: phase_col, style: "flex-shrink:0; margin-top:2px;" %>
        <%= f.text_area :notes,
              placeholder: "Notes",
              rows: 2,
              style: "flex:1; background:transparent; border:none; font-size:15px; color:#3d2b28; font-family:'Montserrat',sans-serif; outline:none; resize:none; padding:0;" %>
      </div>

      <%# Invite guests — decorative %>
      <div style="background:#FFFFFF; padding:14px 20px; border-bottom:1px solid #EDE1D5; display:flex; align-items:center; gap:12px;">
        <%= vuesax_icon "people", size: 20, colour: phase_col, style: "flex-shrink:0;" %>
        <span style="color:#AFAFAF; font-size:15px; flex:1;">Invite guests</span>
        <svg width="16" height="16" fill="none" stroke="#AFAFAF" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </div>

      <%# ── Set appointment button ── %>
      <div style="padding:20px 20px 0;">
        <%= f.submit "Set appointment",
              style: "width:100%; background:#{phase_col}; color:#FFFFFF; padding:16px; border-radius:12px; border:none; font-size:16px; font-weight:600; font-family:'Montserrat',sans-serif; cursor:pointer; letter-spacing:0.02em;" %>
      </div>

    <% end %>

  </div>
</div>
