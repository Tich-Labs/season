<%# Settings screen with Burger Menu slider %>
<div class="bg-white min-h-screen" data-controller="menu">

  <%# Burger Menu Slider (hidden by default) %>
  <div id="burger-menu" class="fixed inset-0 z-50 hidden" data-menu-target="slider">
    <%# Backdrop %>
    <div class="absolute inset-0 bg-black/30" data-action="click->menu#close"></div>
    
    <%# Slider panel (slides from right) %>
    <div class="absolute right-0 top-0 bottom-0 w-[300px] bg-[#FAF7F4] shadow-xl transform transition-transform duration-300"
         data-menu-target="panel"
         style="transform: translateX(100%);">
      
      <%# Close button %>
      <button class="absolute top-4 right-4 text-[#933a35]" data-action="menu#close">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      
      <%# Logo & Title %>
      <div class="pt-10 pb-6 px-5 border-b border-[#EDE1D5]">
        <%= image_tag "Season-Wortmarke 1.svg", style: "width: 140px;", alt: "Season" %>
      </div>
      
      <%# Menu items %>
      <div class="py-4">
        <a href="<%= user_root_path %>" class="flex items-center gap-4 px-5 py-3 text-[#933a35] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/>
          </svg>
          <span class="font-medium">Calendar</span>
        </a>
        
        <a href="<%= tracking_index_path %>" class="flex items-center gap-4 px-5 py-3 text-[#933a35] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/>
          </svg>
          <span class="font-medium">Track / Log</span>
        </a>
        
        <a href="<%= symptoms_path %>" class="flex items-center gap-4 px-5 py-3 text-[#933a35] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/>
          </svg>
          <span class="font-medium">Symptoms</span>
        </a>
        
        <a href="<%= superpowers_path %>" class="flex items-center gap-4 px-5 py-3 text-[#933a35] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/>
          </svg>
          <span class="font-medium">Superpowers</span>
        </a>
        
        <a href="<%= streaks_path %>" class="flex items-center gap-4 px-5 py-3 text-[#933a35] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/>
          </svg>
          <span class="font-medium">Streaks</span>
        </a>
        
        <div class="my-2 mx-5 border-t border-[#EDE1D5]"></div>
        
        <a href="<%= terms_path %>" class="flex items-center gap-4 px-5 py-3 text-[#6B6B6B] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          <span class="font-medium">Terms of Service</span>
        </a>
        
        <a href="<%= privacy_path %>" class="flex items-center gap-4 px-5 py-3 text-[#6B6B6B] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span class="font-medium">Privacy Policy</span>
        </a>
      </div>
      
      <%# Footer %>
      <div class="absolute bottom-4 left-0 right-0 text-center text-[#6B6B6B] text-sm">
        Made with <span class="text-red-500">♥</span> in Zurich
      </div>
    </div>
  </div>

  <%# ── Header ── %>
  <div class="bg-[#FAF7F4] px-5 py-4 flex items-center justify-between border-b border-[#EDE1D5]">
    <a href="<%= user_root_path %>" class="text-[#933a35]">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </a>
    <h1 class="text-[#933a35] font-bold text-lg tracking-wide">SETTINGS</h1>
    <button class="text-[#933a35]" data-action="menu#open">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="px-5 pt-5 pb-20">

    <%# ── Profile ── %>
    <div class="bg-white rounded-xl p-5 mb-4">
      <h2 class="text-[#933a35] font-bold text-base uppercase tracking-wider mb-4">Profile</h2>
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 bg-[#F5EDE8] rounded-full flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-[#933a35] text-lg font-semibold"><%= @user.name %></p>
          <p class="text-[#6B6B6B] text-sm"><%= @user.email %></p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#6B6B6B" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </div>
    </div>

    <%# ── My Calendar ── %>
    <a href="#" class="block bg-white rounded-xl p-5 mb-4">
      <h2 class="text-[#933a35] font-bold text-base uppercase tracking-wider mb-4">My Calendar</h2>
      <div class="flex justify-between">
        <div class="flex flex-col">
          <span class="text-[#6B6B6B] text-xs font-bold uppercase">Cycle length</span>
          <span class="text-[#933a35] text-2xl font-bold"><%= @user.cycle_length %> <span class="text-sm font-normal">days</span></span>
        </div>
        <div class="flex flex-col text-right">
          <span class="text-[#6B6B6B] text-xs font-bold uppercase">Period length</span>
          <span class="text-[#933a35] text-2xl font-bold"><%= @user.period_length %> <span class="text-sm font-normal">days</span></span>
        </div>
      </div>
    </a>

    <%# ── My Subscription ── %>
    <a href="#" class="block bg-white rounded-xl p-5 mb-4">
      <div class="flex justify-between items-center">
        <h2 class="text-[#933a35] font-bold text-base uppercase tracking-wider">My Subscription</h2>
        <span class="bg-[#933a35] text-white text-xs font-bold px-3 py-1 rounded-full">FREE</span>
      </div>
    </a>

    <%# ── Notifications ── %>
    <a href="#" class="block bg-white rounded-xl p-5 mb-4">
      <div class="flex justify-between items-center">
        <h2 class="text-[#933a35] font-bold text-base uppercase tracking-wider">Notifications & Reminders</h2>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#6B6B6B" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </div>
    </a>

    <div class="my-3 border-t border-[#EDE1D5]"></div>

    <%# ── Terms ── %>
    <a href="<%= terms_path %>" class="block bg-white rounded-xl p-5 mb-4">
      <div class="flex justify-between items-center">
        <span class="text-[#933a35] font-semibold">Terms of Service</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#6B6B6B" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </div>
    </a>

    <%# ── Privacy ── %>
    <a href="<%= privacy_path %>" class="block bg-white rounded-xl p-5 mb-4">
      <div class="flex justify-between items-center">
        <span class="text-[#933a35] font-semibold">Privacy Policy</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#6B6B6B" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </div>
    </a>

    <div class="my-3 border-t border-[#EDE1D5]"></div>

    <%# ── Log out ── %>
    <%= button_to "Log out",
        session_path,
        method: :delete,
        class: "w-full bg-transparent text-[#933a35] text-center py-4 rounded-xl font-semibold border-2 border-[#933a35]" %>

    <%# Footer ─%>
    <p class="text-center mt-6 text-[#6B6B6B] text-sm">
      Made with <span class="text-red-500">♥</span> in Zurich
    </p>
  </div>

</div>