<%# Settings screen - matches Figma node 12048-37859 %>
<%# Header auto-rendered by layout (controller_name == 'settings') %>

<div style="background:#ffffff; min-height:100%;">

  <%# Content - max-width 430px centered %>
  <div style="max-width:430px; margin:0 auto; padding:0 16px 80px;">

    <%# ── Personal Settings ── %>
    <div style="padding:20px 0 8px;">
      <h2 style="color:#933a35; font-size:16px; font-weight:700;">Personal Settings</h2>
    </div>
    <div style="border-bottom:1px solid #DDD0CB;"></div>

    <%# My Profile %>
    <a href="<%= profile_settings_path %>" style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <%= vuesax_icon "user", size: 24 %>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">My Profile</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </a>

    <%# My Subscriptions %>
    <a href="<%= subscriptions_settings_path %>" style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <%= vuesax_icon "bag", size: 24 %>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">My Subscriptions</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </a>
    <%# My Calendar %>
    <a href="<%= calendar_settings_path %>" style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <%= vuesax_icon "calendar", size: 24 %>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">My Calendar</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </a>

    <%# ── App Settings ── %>
    <div style="padding:24px 0 8px;">
      <h2 style="color:#933a35; font-size:16px; font-weight:700;">App Settings</h2>
    </div>
    <div style="border-bottom:1px solid #DDD0CB;"></div>

    <%# Notifications & Reminders %>
    <a href="<%= notifications_settings_path %>" style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <%= vuesax_icon "notification", size: 24 %>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Notifications & Reminders</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </a>

    <%# Language %>
    <a href="#" style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
      </svg>
      <div style="flex:1;">
        <span style="color:#933a35; font-size:16px; font-weight:500;">Language</span>
        <span style="display:block; color:#D18D83; font-size:14px; margin-top:4px;">English</span>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </a>

    <%# Darkmode %>
    <div style="display:flex; align-items:center; gap:16px; padding:16px 0; cursor:pointer;" onclick="alert('Dark mode toggle - coming soon!')">
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Darkmode</span>
      <div style="width:40px; height:20px; background:#933a35; border-radius:25px; padding:2px;">
        <div style="width:16px; height:16px; background:white; border-radius:50%; margin-left:auto;"></div>
      </div>
    </div>

    <%# ── About Season ── %>
    <div style="padding:24px 0 8px;">
      <h2 style="color:#933a35; font-size:16px; font-weight:700;">About Season</h2>
    </div>
    <div style="border-bottom:1px solid #DDD0CB;"></div>

    <%# Rate in the App Store %>
    <div style="position:relative;">
      <a href="#" style="display:flex; align-items:center; gap:16px; padding:16px; background:#899884; border-radius:8px; margin-top:16px; text-decoration:none;">
        <%= vuesax_icon "star", size: 32, colour: "white" %>
        <div style="flex:1;">
          <span style="display:block; color:white; font-size:16px; font-weight:700;">Rate in the App Store</span>
          <span style="color:white; font-size:14px;">for even more benefits!</span>
        </div>
      </a>
      <div style="position:absolute; right:8px; top:8px; background:#EDE1D5; border-radius:9999px; padding:4px 10px;">
        <span style="color:#933a35; font-size:12px;">Coming soon</span>
      </div>
    </div>

    <%# Support %>
    <button type="button"
            onclick="openFeedbackModal('support')"
            style="display:flex; align-items:center; gap:16px; padding:16px; background:#899884; border-radius:8px; margin-top:8px; width:100%; border:none; cursor:pointer; text-align:left;">
      <%= vuesax_icon "message-question", size: 32, colour: "white" %>
      <div style="flex:1;">
        <span style="display:block; color:white; font-size:16px; font-weight:700;">Support</span>
        <span style="color:white; font-size:14px;">Contact us!</span>
      </div>
    </button>

    <%# Share Season with friends %>
    <div style="position:relative;">
      <a href="#" style="display:flex; align-items:center; gap:16px; padding:16px; background:#899884; border-radius:8px; margin-top:8px; margin-bottom:16px; text-decoration:none;">
        <%= vuesax_icon "share", size: 32, colour: "white" %>
        <div style="flex:1;">
          <span style="display:block; color:white; font-size:16px; font-weight:700;">Share Season with friends</span>
          <span style="color:white; font-size:14px;">for even more benefits!</span>
        </div>
      </a>
      <div style="position:absolute; right:8px; top:8px; background:#EDE1D5; border-radius:9999px; padding:4px 10px;">
        <span style="color:#933a35; font-size:12px;">Coming soon</span>
      </div>
    </div>

  </div>
</div>
