<%# Settings screen - matches Figma node 12048-37859 %>
<div class="bg-white min-h-screen" data-controller="menu">

  <%# Burger Menu Slider (hidden by default) %>
  <div id="burger-menu" class="fixed inset-0 z-50 hidden" data-menu-target="slider">
    <%# Backdrop %>
    <div class="absolute inset-0 bg-black/30" data-action="click->menu#close"></div>
    
    <%# Slider panel (slides from right) %>
    <div class="absolute right-0 top-0 bottom-0 w-[300px] bg-[#FAF7F4] shadow-xl transform transition-transform duration-300"
         data-menu-target="panel"
         style="transform: translateX(100%);">
      <%# Close button %>
      <button class="absolute top-4 right-4 text-[#933a35]" data-action="menu#close">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      
      <%# Logo & Title %>
      <div class="pt-10 pb-6 px-5 border-b border-[#EDE1D5]">
        <%= image_tag "Season-Wortmarke 1.svg", style: "width: 140px;", alt: "Season" %>
      </div>
      
      <%# Menu items %>
      <div class="py-4">
        <a href="<%= user_root_path %>" class="flex items-center gap-4 px-5 py-3 text-[#933a35] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/></svg>
          <span class="font-medium">Calendar</span>
        </a>
        <a href="<%= tracking_index_path %>" class="flex items-center gap-4 px-5 py-3 text-[#933a35] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/></svg>
          <span class="font-medium">Track / Log</span>
        </a>
        <a href="<%= streaks_path %>" class="flex items-center gap-4 px-5 py-3 text-[#933a35] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/></svg>
          <span class="font-medium">Streaks</span>
        </a>
        
        <div class="my-2 mx-5 border-t border-[#EDE1D5]"></div>
        
        <a href="<%= terms_path %>" class="flex items-center gap-4 px-5 py-3 text-[#6B6B6B] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span class="font-medium">Terms of Service</span>
        </a>
        <a href="<%= privacy_path %>" class="flex items-center gap-4 px-5 py-3 text-[#6B6B6B] hover:bg-[#EDE1D5]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="font-medium">Privacy Policy</span>
        </a>
      </div>
      
      <div class="absolute bottom-4 left-0 right-0 text-center text-[#6B6B6B] text-sm">
        Made with <span class="text-red-500">♥</span> in Zurich
      </div>
    </div>
  </div>

  <%# Header %>
  <div class="bg-[#933a35] px-4 py-4 flex items-center justify-between">
    <button class="text-white w-6" data-action="menu#open">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <h1 class="text-white text-2xl font-medium">Settings</h1>
    <div class="w-6"></div>
  </div>

  <div class="pb-20">

    <%# ── Personal Settings ── %>
    <div class="px-4 pt-5 pb-2">
      <h2 class="text-[#933a35] text-base font-bold">Personal Settings</h2>
    </div>
    <div class="border-b border-[#DDD0CB]"></div>

    <%# My Profile %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 border-b border-[#EDE1D5]">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      <span class="flex-1 text-[#933a35] text-base font-medium">My Profile</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <%# My Abonnements %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 border-b border-[#EDE1D5]">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M6 2a1 1 0 0 1 1 1v1h10V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/>
      </svg>
      <span class="flex-1 text-[#933a35] text-base font-medium">My Abonnements</span>
      <span class="bg-stone-200 text-[#933a35] text-xs px-2 py-1 rounded">Coming soon</span>
    </a>

    <%# My Calendar %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 border-b border-[#EDE1D5]">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M6 2a1 1 0 0 1 1 1v1h10V3a1 1 0 1 1 2 0v1h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z"/>
      </svg>
      <span class="flex-1 text-[#933a35] text-base font-medium">My Calendar</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <%# ── App Settings ── %>
    <div class="px-4 pt-6 pb-2">
      <h2 class="text-[#933a35] text-base font-bold">App Settings</h2>
    </div>
    <div class="border-b border-[#DDD0CB]"></div>

    <%# Notifications & Reminders %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 border-b border-[#EDE1D5]">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
      <span class="flex-1 text-[#933a35] text-base font-medium">Notifications & Reminders</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <%# Language %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 border-b border-[#EDE1D5]">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <div class="flex-1">
        <span class="text-[#933a35] text-base font-medium">Language</span>
        <span class="block text-[#D18D83] text-sm mt-1">Englisch</span>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

    <%# Darkmode %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 border-b border-[#EDE1D5]">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <span class="flex-1 text-[#933a35] text-base font-medium">Darkmode</span>
      <div class="w-10 h-5 bg-[#933a35] rounded-full p-1">
        <div class="w-4 h-4 bg-white rounded-full"></div>
      </div>
    </a>

    <%# ── Mehr zu Season ── %>
    <div class="px-4 pt-6 pb-2">
      <h2 class="text-[#933a35] text-base font-bold">Mehr zu Season</h2>
    </div>
    <div class="border-b border-[#DDD0CB]"></div>

    <%# Rate in the App Store %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 bg-[#899884] rounded-lg mx-4 mt-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
      <div>
        <span class="block text-white text-base font-bold">Rate in the App Store</span>
        <span class="text-white text-sm">for even more benefits!</span>
      </div>
    </a>

    <%# Support %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 bg-[#899884] rounded-lg mx-4 mt-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="10"/>
        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
      <div>
        <span class="block text-white text-base font-bold">Support</span>
        <span class="text-white text-sm">Contact us!</span>
      </div>
    </a>

    <%# Share Season with friends %>
    <a href="#" class="flex items-center gap-4 px-4 py-4 bg-[#899884] rounded-lg mx-4 mt-2 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
        <polyline points="16 6 12 2 8 6"/>
        <line x1="12" y1="2" x2="12" y2="15"/>
      </svg>
      <div>
        <span class="block text-white text-base font-bold">Share Season with friends</span>
        <span class="text-white text-sm">for even more benefits!</span>
      </div>
    </a>

  </div>
</div>