<%# Settings screen — matches Figma node 12048-15697 %>
<div class="bg-white min-h-screen">

  <%# ── Header ── %>
  <div style="background-color:#933a35;" class="px-5 py-4 flex items-center">
    <button class="text-white w-6 flex-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
        <line x1="2" y1="6"  x2="22" y2="6"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <line x1="2" y1="18" x2="22" y2="18"/>
      </svg>
    </button>
    <div class="flex-1 flex items-center justify-center gap-2 text-white">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
        <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l1.72-1.34c.15-.12.19-.34.1-.51l-1.63-2.83c-.12-.22-.37-.29-.59-.22l-2.03.81c-.42-.32-.86-.58-1.35-.78l-.3-2.15C14.73 3.18 14.52 3 14.26 3h-3.26c-.26 0-.47.18-.49.42l-.3 2.15c-.48.2-.93.47-1.35.78l-2.03-.81c-.22-.09-.47 0-.59.22L4.61 8.59c-.12.16-.08.39.1.51l1.72 1.34c-.05.3-.07.62-.07.94s.02.64.07.94L4.71 13.66c-.15.12-.19.34-.1.51l1.63 2.83c.12.22.37.29.59.22l2.03-.81c.42.32.86.58 1.35.78l.3 2.15c.02.24.23.42.49.42h3.26c.26 0 .47-.18.49-.42l.3-2.15c.48-.2.93-.47 1.35-.78l2.03.81c.22.09.47 0 .59-.22l1.63-2.83c.12-.22.07-.39-.1-.51l-1.72-1.34zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
      </svg>
      <span class="font-semibold text-lg">Settings</span>
    </div>
    <div class="w-6 flex-none"></div>
  </div>

  <%# ── Personal Settings ── %>
  <div class="px-5 pt-5 pb-2">
    <h2 style="color:#933a35;" class="font-bold text-base">Personal Settings</h2>
  </div>
  <div style="border-bottom:1px solid #DDD0CB;"></div>

  <a href="#" class="flex items-center gap-4 px-5 py-4" style="border-bottom:1px solid #EFE5DF;">
    <span style="color:#933a35;" class="flex-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
    </span>
    <span class="flex-1 font-medium text-base" style="color:#933a35;">My Profile</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="#933a35" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
  </a>

  <a href="#" class="flex items-center gap-4 px-5 py-4" style="border-bottom:1px solid #EFE5DF;">
    <span style="color:#933a35;" class="flex-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
    </span>
    <span class="flex-1 font-medium text-base" style="color:#933a35;">My Abonnements</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="#933a35" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
  </a>

  <a href="#" class="flex items-center gap-4 px-5 py-4">
    <span style="color:#933a35;" class="flex-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8"  y1="2" x2="8"  y2="6"/>
        <line x1="3"  y1="10" x2="21" y2="10"/>
        <rect x="7"  y="13" width="2" height="2" rx="0.5" fill="#933a35" stroke="none"/>
        <rect x="11" y="13" width="2" height="2" rx="0.5" fill="#933a35" stroke="none"/>
        <rect x="15" y="13" width="2" height="2" rx="0.5" fill="#933a35" stroke="none"/>
      </svg>
    </span>
    <span class="flex-1 font-medium text-base" style="color:#933a35;">My Calender</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="#933a35" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
  </a>

  <%# ── App Settings ── %>
  <div class="px-5 pt-5 pb-2">
    <h2 style="color:#933a35;" class="font-bold text-base">App Settings</h2>
  </div>
  <div style="border-bottom:1px solid #DDD0CB;"></div>

  <a href="#" class="flex items-center gap-4 px-5 py-4" style="border-bottom:1px solid #EFE5DF;">
    <span style="color:#933a35;" class="flex-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    </span>
    <span class="flex-1 font-medium text-base" style="color:#933a35;">Notifications &amp; reminder</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="#933a35" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
  </a>

  <a href="#" class="flex items-center gap-4 px-5 py-4" style="border-bottom:1px solid #EFE5DF;">
    <span style="color:#933a35;" class="flex-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <line x1="3" y1="9" x2="21" y2="9"/>
        <line x1="9" y1="3" x2="9"  y2="9"/>
      </svg>
    </span>
    <div class="flex-1">
      <div class="flex items-center gap-1">
        <span class="font-medium text-base" style="color:#933a35;">Language</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="#933a35" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </div>
      <span class="text-sm" style="color:#933a35;opacity:0.6;">Englisch</span>
    </div>
  </a>

  <div class="flex items-center gap-4 px-5 py-4">
    <span style="color:#933a35;" class="flex-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </span>
    <span class="flex-1 font-medium text-base" style="color:#933a35;">Darkmode</span>
    <label style="position:relative;display:inline-flex;align-items:center;cursor:pointer;">
      <input type="checkbox" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0;" checked>
      <span style="display:block;width:44px;height:24px;background:#933a35;border-radius:12px;position:relative;transition:background 0.2s;">
        <span style="position:absolute;top:2px;right:2px;width:20px;height:20px;background:white;border-radius:50%;transition:transform 0.2s;"></span>
      </span>
    </label>
  </div>

  <%# ── Mehr zu Season ── %>
  <div class="px-5 pt-5 pb-2">
    <h2 style="color:#933a35;" class="font-bold text-base">Mehr zu Season</h2>
  </div>
  <div style="border-bottom:1px solid #DDD0CB;"></div>

  <div class="px-5 pt-4" style="display:flex;flex-direction:column;gap:12px;">

    <%# Support %>
    <div style="position:relative;background:#4D6B58;border-radius:16px;padding:20px 20px;display:flex;align-items:center;gap:16px;">
      <span style="position:absolute;top:10px;right:10px;background:#FDF0EE;color:#933a35;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">Coming soon</span>
      <span style="color:white;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
          <circle cx="12" cy="17" r="0.8" fill="white" stroke="none"/>
        </svg>
      </span>
      <div>
        <p style="color:white;font-weight:700;font-size:15px;margin:0;">Support</p>
        <p style="color:rgba(255,255,255,0.7);font-size:13px;margin:2px 0 0;">Contact us!</p>
      </div>
    </div>

    <%# Rate in the App Store %>
    <div style="position:relative;background:#4D6B58;border-radius:16px;padding:20px 20px;display:flex;align-items:center;gap:16px;">
      <span style="position:absolute;top:10px;right:10px;background:#FDF0EE;color:#933a35;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">Coming soon</span>
      <span style="color:white;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
      </span>
      <div>
        <p style="color:white;font-weight:700;font-size:15px;margin:0;">Rate in the App Store</p>
        <p style="color:rgba(255,255,255,0.7);font-size:13px;margin:2px 0 0;">for even more benefits!</p>
      </div>
    </div>

    <%# Share Season with friends %>
    <div style="position:relative;background:#4D6B58;border-radius:16px;padding:20px 20px;display:flex;align-items:center;gap:16px;">
      <span style="position:absolute;top:10px;right:10px;background:#FDF0EE;color:#933a35;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;">Coming soon</span>
      <span style="color:white;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>
      </span>
      <div>
        <p style="color:white;font-weight:700;font-size:15px;margin:0;">Share Season with friends</p>
        <p style="color:rgba(255,255,255,0.7);font-size:13px;margin:2px 0 0;">for even more benefits!</p>
      </div>
    </div>

  </div>

  <%# ── Log out ── %>
  <div class="px-5 pt-6 pb-8">
    <%= button_to "Log out",
        session_path,
        method: :delete,
        style: "width:100%;background:transparent;border:2px solid #933a35;color:#933a35;font-weight:600;padding:14px;border-radius:16px;font-size:16px;cursor:pointer;" %>
  </div>

</div>
