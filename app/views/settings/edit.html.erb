<div style="background:#FAF7F4; min-height:100%; padding-bottom:16px;">

  <!-- Header -->
  <div style="background:#ffffff; padding:20px 24px 16px; border-bottom:1px solid #EDE1D5;">
    <div style="max-width:430px; margin:0 auto;">
      <h1 style="color:#933a35; font-size:24px; font-weight:700; letter-spacing:1px; text-align:center;">SETTINGS</h1>
    </div>
  </div>

  <div style="max-width:430px; margin:0 auto; padding:16px;">

    <%= form_with model: @user, url: settings_path, method: :patch, local: true do |f| %>

      <!-- Profile section -->
      <div style="background:#ffffff; border-radius:12px; padding:20px; margin-bottom:12px;">
        <h2 style="color:#933a35; font-size:16px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:16px;">Profile</h2>

        <div style="margin-bottom:16px;">
          <label style="color:#6B6B6B; font-size:13px; font-weight:500; text-transform:uppercase; letter-spacing:0.5px; display:block; margin-bottom:8px;">Name</label>
          <%= f.text_field :name,
              placeholder: "Your name",
              style: "width:100%; background:#F5EDE8; border-radius:8px; padding:12px 16px; border:none; font-size:16px; color:#933a35; outline:none; box-sizing:border-box;" %>
        </div>

        <div>
          <label style="color:#6B6B6B; font-size:13px; font-weight:500; text-transform:uppercase; letter-spacing:0.5px; display:block; margin-bottom:8px;">Email</label>
          <div style="background:#EDE1D5; border-radius:8px; padding:12px 16px; font-size:16px; color:#6B6B6B;">
            <%= current_user.email %>
          </div>
        </div>
      </div>

      <!-- Language -->
      <div style="background:#ffffff; border-radius:12px; padding:20px; margin-bottom:12px;">
        <h2 style="color:#933a35; font-size:16px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:16px;">Language</h2>

        <div style="display:flex; flex-direction:column; gap:10px;">
          <% [["en", "English 🇬🇧"], ["de", "Deutsch 🇩🇪"]].each do |code, label| %>
            <label style="display:flex; align-items:center; gap:12px; padding:14px 16px; background:#FAF7F4; border-radius:8px; cursor:pointer; border:2px solid <%= @user.language == code ? '#933a35' : 'transparent' %>;">
              <%= f.radio_button :language, code, style: "accent-color:#933a35; width:20px; height:20px;" %>
              <span style="color:#933a35; font-size:16px; font-weight:500;"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Cycle details -->
      <div style="background:#ffffff; border-radius:12px; padding:20px; margin-bottom:12px;">
        <h2 style="color:#933a35; font-size:16px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:16px;">Cycle details</h2>

        <div style="margin-bottom:16px;">
          <label style="color:#6B6B6B; font-size:13px; font-weight:500; text-transform:uppercase; letter-spacing:0.5px; display:block; margin-bottom:8px;">Cycle length (days)</label>
          <%= f.number_field :cycle_length,
              min: 21, max: 45, step: 1,
              style: "width:100%; background:#F5EDE8; border-radius:8px; padding:12px 16px; border:none; font-size:16px; color:#933a35; outline:none; box-sizing:border-box;" %>
        </div>

        <div>
          <label style="color:#6B6B6B; font-size:13px; font-weight:500; text-transform:uppercase; letter-spacing:0.5px; display:block; margin-bottom:8px;">Period length (days)</label>
          <%= f.number_field :period_length,
              min: 1, max: 10, step: 1,
              style: "width:100%; background:#F5EDE8; border-radius:8px; padding:12px 16px; border:none; font-size:16px; color:#933a35; outline:none; box-sizing:border-box;" %>
        </div>
      </div>

      <!-- Contraception -->
      <div style="background:#ffffff; border-radius:12px; padding:20px; margin-bottom:12px;">
        <h2 style="color:#933a35; font-size:16px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:16px;">Contraception</h2>

        <%= f.select :contraception_type,
            [["None", "none"], ["Condoms", "condoms"], ["Birth control pill", "pill"],
             ["IUD", "iud"], ["Implant", "implant"], ["Patch", "patch"], ["Ring", "ring"], ["Other", "other"]],
            {},
            style: "width:100%; background:#F5EDE8; border-radius:8px; padding:12px 16px; border:none; font-size:16px; color:#933a35; outline:none; box-sizing:border-box; -webkit-appearance:none; appearance:none;" %>
      </div>

      <!-- Save button -->
      <%= f.submit "Save settings",
          style: "display:block; width:100%; background:#933a35; color:#ffffff; text-align:center; padding:16px; border-radius:12px; font-size:16px; font-weight:500; border:none; cursor:pointer;" %>

    <% end %>

    <!-- Divider -->
    <div style="margin:20px 0; border-top:1px solid #EDE1D5;"></div>

    <!-- Sign out -->
    <%= button_to "Sign out",
        session_path,
        method: :delete,
        style: "display:block; width:100%; background:transparent; color:#933a35; text-align:center; padding:16px; border-radius:12px; font-size:16px; font-weight:500; border:2px solid #933a35; cursor:pointer;" %>

    <!-- Legal links -->
    <div style="display:flex; justify-content:center; gap:24px; margin-top:20px;">
      <a href="<%= terms_path %>" style="color:#6B6B6B; font-size:13px; text-decoration:none;">Terms of Use</a>
      <a href="<%= privacy_path %>" style="color:#6B6B6B; font-size:13px; text-decoration:none;">Privacy Policy</a>
    </div>

  </div>
</div>
