<%# My Profile screen - matches Figma node 12048-37877 %>
<%# Dark header auto-applied by layout; only back arrow override needed %>
<% content_for(:header_left) do %>
  <%= link_to edit_settings_path, class: "p-2 flex items-center" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </svg>
  <% end %>
<% end %>

<div style="background:#ffffff; min-height:100%;">

  <%# Content - max-width 430px centered %>
  <div style="max-width:430px; margin:0 auto; padding:0 16px 80px;">

    <%# ── My profile ── %>
    <div style="padding:20px 0 8px;">
      <h2 style="color:#933a35; font-size:16px; font-weight:700;">My profile</h2>
    </div>
    <div style="border-bottom:1px solid #DDD0CB;"></div>

    <%# Profile Picture %>
    <div style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <img src="https://placehold.co/27x27" style="width:48px; height:48px; border-radius:50%;" alt="Profile">
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Profile Picture</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </div>

    <%# E-Mail Address %>
    <div style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
        <polyline points="22,6 12,13 2,6" />
      </svg>
      <div style="flex:1;">
        <span style="color:#933a35; font-size:16px; font-weight:500;">E-Mail Address</span>
        <span style="display:block; color:#D18D83; font-size:14px; margin-top:4px;"><%= @user.email %></span>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </div>

    <%# Change password %>
    <div style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
      </svg>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Change password</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </div>

    <%# Access code %>
    <div style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Access code</span>
      <div style="display:flex; align-items:center; gap:8px;">
        <span style="color:#D18D83; font-size:14px;">FaceID</span>
        <%# Toggle switch %>
        <div style="width:40px; height:20px; background:#933a35; border-radius:25px; padding:2px;">
          <div style="width:16px; height:16px; background:white; border-radius:50%; margin-left:auto;"></div>
        </div>
      </div>
    </div>

    <div style="border-bottom:1px solid #DDD0CB; padding-top: 16px;"></div>

    <%# ── Personal information ── %>
    <div style="display:flex; align-items:center; gap:8px; padding:24px 0 8px;">
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
        <circle cx="12" cy="7" r="4" />
      </svg>
      <h2 style="color:#933a35; font-size:16px; font-weight:700; flex:1;">Personal information</h2>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </div>

    <%# Personal info items %>
    <div style="display:flex; align-items:center; padding:8px 0 8px 32px;">
      <span style="flex:1; color:#D18D83; font-size:14px;">Name: <%= @user.first_name %></span>
      <svg style="width:6px; height:12px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </div>

    <div style="display:flex; align-items:center; padding:8px 0 8px 32px;">
      <span style="flex:1; color:#D18D83; font-size:14px;">Age: <%= @user.age %></span>
    </div>

    <div style="display:flex; align-items:center; padding:8px 0 8px 32px;">
      <span style="flex:1; color:#D18D83; font-size:14px;">Cycle days: <%= @user.cycle_days %></span>
    </div>

    <div style="display:flex; align-items:center; padding:8px 0 8px 32px;">
      <span style="flex:1; color:#D18D83; font-size:14px;">Last Menstruation <%= @user.last_menstruation %></span>
    </div>

    <div style="border-bottom:1px solid #DDD0CB; padding-top: 16px;"></div>

    <%# ── Delete Account ── %>

    <%# Delete Account link %>
    <a href="#" style="display:flex; align-items:center; gap:16px; padding:16px 0; text-decoration:none;">
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <polyline points="3 6 5 6 21 6" />
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
      </svg>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Delete Account</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </a>

  </div>
</div>
