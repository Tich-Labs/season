<%# My Profile screen - matches Figma node 12048-37877 %>
<%# Dark header auto-applied by layout; only back arrow override needed %>
<% content_for(:header_left) do %>
  <%= link_to edit_settings_path, class: "p-2 flex items-center" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </svg>
  <% end %>
<% end %>

<div style="background:#ffffff; min-height:100%;" data-controller="profile-modal" data-action="click@window->profile-modal#clickOutside">

  <%# Content - max-width 430px centered %>
  <div style="max-width:430px; margin:0 auto; padding:0 16px 80px;">

    <%# ── My profile ── %>
    <div style="padding:20px 0 8px;">
      <h2 style="color:#933a35; font-size:16px; font-weight:700;">My profile</h2>
    </div>
    <div style="border-bottom:1px solid #DDD0CB;"></div>

    <%# Profile Picture %>
    <button data-action="click->profile-modal#openAvatarModal" aria-haspopup="dialog"
            style="display:flex; align-items:center; gap:16px; padding:16px 0; width:100%; background:none; border:none; cursor:pointer; text-align:left;">
      <% if @user.avatar_preset.present? %>
        <% preset = AvatarService.find_by_id(@user.avatar_preset) %>
        <% if preset %>
          <%= image_tag "avatars/#{preset[:file]}", style: "width:48px; height:48px; border-radius:50%; object-fit:cover; flex-shrink:0;", alt: preset[:name] %>
        <% end %>
      <% elsif @user.avatar.attached? %>
        <%= image_tag @user.avatar, style: "width:48px; height:48px; border-radius:50%; object-fit:cover; flex-shrink:0;", alt: "Profile" %>
      <% elsif @user.avatar_url.present? %>
        <%= image_tag @user.avatar_url, alt: "Profile",
              style: "width:48px; height:48px; border-radius:50%; object-fit:cover; flex-shrink:0;" %>
      <% else %>
        <div style="width:48px; height:48px; border-radius:50%; background:#EDE1D5; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
          <%= vuesax_icon "user", size: 24 %>
        </div>
      <% end %>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Profile Picture</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </button>

    <%# Avatar Modal %>
    <div id="avatar-modal" role="dialog" aria-modal="true" aria-labelledby="avatar-modal-title" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:100; align-items:center; justify-content:center;">
      <div style="background:#FAF7F4; border-radius:16px; padding:24px; width:90%; max-width:340px; margin:16px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
          <h3 id="avatar-modal-title" style="color:#933a35; font-size:18px; font-weight:600; margin:0;">Profile Picture</h3>
          <button id="avatar-modal-close" data-action="click->profile-modal#closeAvatarModal" style="background:none; border:none; cursor:pointer;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
              <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>

        <%# Preset Avatars %>
        <div style="margin-bottom:20px;">
          <label style="display:block; color:#933a35; font-size:13px; font-weight:500; margin-bottom:12px;">Choose a cat avatar</label>
          <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:12px;">
            <% AvatarService.all.each do |preset| %>
              <%= form_with url: update_avatar_settings_path, method: :patch, data: { turbo: false }, local: true do %>
                <input type="hidden" name="avatar_preset" value="<%= preset[:id] %>">
                <button type="submit" title="<%= preset[:name] %>" aria-label="<%= preset[:name] %>"
                        style="display:flex; align-items:center; justify-content:center; width:100%; aspect-ratio:1; background:white; border:<%= @user.avatar_preset == preset[:id] ? '3px solid #933a35' : '1px solid #DDD0CB' %>; border-radius:12px; padding:8px; cursor:pointer; transition:all 0.2s;">
                  <%= image_tag "avatars/#{preset[:file]}", alt: preset[:name], style: "width:100%; height:100%; object-fit:cover; border-radius:8px;" %>
                </button>
              <% end %>
            <% end %>
          </div>
        </div>

        <hr style="border:none; border-top:1px solid #DDD0CB; margin:20px 0;">

        <%# Option 1: Upload from device %>
        <%= form_with url: update_avatar_settings_path, method: :patch, multipart: true, data: { turbo: false }, id: "avatar-upload-form" do %>
          <input type="file" id="avatar-file" name="avatar" accept="image/*"
                 data-action="change->profile-modal#submitAvatarForm"
                 style="position:absolute; left:-9999px; width:1px; height:1px; opacity:0;">
          <button type="button" data-action="click->profile-modal#clickAvatarUpload"
                  style="display:flex; align-items:center; gap:12px; width:100%; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; padding:16px; margin-bottom:12px; cursor:pointer; text-align:left;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <polyline points="21 15 16 10 5 21" />
            </svg>
            <span style="color:#933a35; font-size:16px; font-weight:500;">Upload from device</span>
          </button>
        <% end %>

        <%# Option 2: Enter image URL %>
        <%= form_with url: update_avatar_settings_path, method: :patch, data: { turbo: false } do %>
          <label for="avatar-url-input" style="display:block; color:#933a35; font-size:13px; font-weight:500; margin-bottom:6px;">Or paste image URL</label>
          <input type="text" id="avatar-url-input" name="avatar_url" placeholder="https://..." autocomplete="url"
                 style="width:100%; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; padding:16px; font-size:16px; color:#933a35; box-sizing:border-box; margin-bottom:12px;">
          <button type="submit" style="width:100%; background:#933a35; color:white; border:none; border-radius:12px; padding:14px; font-size:16px; font-weight:500; cursor:pointer;">
            Add Photo
          </button>
        <% end %>

        <%# Cancel button %>
        <button data-action="click->profile-modal#closeAvatarModal"
                style="width:100%; background:transparent; color:#933a35; border:1px solid #DDD0CB; border-radius:12px; padding:14px; font-size:16px; font-weight:500; cursor:pointer; margin-top:8px;">
          Cancel
        </button>
      </div>
    </div>

    <%# E-Mail Address %>
    <button data-action="click->profile-modal#openEmailModal" style="background:none; border:none; width:100%; display:flex; align-items:center; gap:16px; padding:16px 0; cursor:pointer;">
      <%= vuesax_icon "sms", size: 24 %>
      <div style="flex:1; text-align:left;">
        <span style="color:#933a35; font-size:16px; font-weight:500;">E-Mail Address</span>
        <span style="display:block; color:#D18D83; font-size:14px; margin-top:4px;"><%= @user.email %></span>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </button>

    <%# Change password %>
    <%= link_to edit_user_password_path, style: "display:flex; align-items:center; gap:16px; padding:16px 0; text-decoration:none;" do %>
      <%= vuesax_icon "lock", size: 24 %>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Change password</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    <% end %>

    <%# Access code %>
    <div style="display:flex; align-items:center; gap:16px; padding:16px 0;">
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Access code</span>
      <div style="display:flex; align-items:center; gap:8px;">
        <span style="color:#D18D83; font-size:14px;" id="access-code-label">FaceID</span>
        <%# Toggle switch — keyboard accessible %>
        <button role="switch" aria-checked="true" aria-labelledby="access-code-label"
                tabindex="0"
                onkeydown="if(event.key===' '||event.key==='Enter'){event.preventDefault();var c=this.getAttribute('aria-checked')==='true';this.setAttribute('aria-checked',String(!c));this.style.background=c?'#DDD0CB':'#933a35';this.querySelector('.toggle-thumb').style.marginLeft=c?'0':'auto';}"
                style="width:40px; height:20px; background:#933a35; border-radius:25px; padding:2px; border:none; cursor:pointer;">
          <div class="toggle-thumb" style="width:16px; height:16px; background:white; border-radius:50%; margin-left:auto;"></div>
        </button>
      </div>
    </div>

    <div style="border-bottom:1px solid #DDD0CB; padding-top: 16px;"></div>

    <%# ── Personal information ── %>
    <button data-action="click->profile-modal#openPersonalInfoModal" style="background:none; border:none; width:100%; display:flex; align-items:center; gap:8px; padding:24px 0 8px; cursor:pointer;">
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
        <circle cx="12" cy="7" r="4" />
      </svg>
      <h2 style="color:#933a35; font-size:16px; font-weight:700; flex:1; text-align:left;">Personal information</h2>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </button>

    <%# Personal info items %>
    <button data-action="click->profile-modal#openPersonalInfoModal" style="background:none; border:none; width:100%; display:flex; align-items:center; padding:8px 0 8px 32px; cursor:pointer;">
      <span style="flex:1; color:#D18D83; font-size:14px; text-align:left;">Name: <%= @user.first_name %></span>
      <svg style="width:6px; height:12px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </button>

    <div style="display:flex; align-items:center; padding:8px 0 8px 32px;">
      <span style="flex:1; color:#D18D83; font-size:14px;">Age: <%= @user.birthday ? ((Time.zone.today - @user.birthday).to_i / 365) : "—" %></span>
    </div>

    <div style="display:flex; align-items:center; padding:8px 0 8px 32px;">
      <span style="flex:1; color:#D18D83; font-size:14px;">Cycle days: <%= @user.cycle_length || "—" %></span>
    </div>

    <div style="display:flex; align-items:center; padding:8px 0 8px 32px;">
      <span style="flex:1; color:#D18D83; font-size:14px;">Last Menstruation: <%= @user.last_period_start&.strftime("%d %b %Y") || "—" %></span>
    </div>

    <div style="border-bottom:1px solid #DDD0CB; padding-top: 16px;"></div>

<%# ── Delete Account ── %>

    <%# Delete Account link %>
    <%= link_to account_path, style: "display:flex; align-items:center; gap:16px; padding:16px 0; text-decoration:none;" do %>
      <svg style="width:24px; height:24px;" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <polyline points="3 6 5 6 21 6" />
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
      </svg>
      <span style="flex:1; color:#933a35; font-size:16px; font-weight:500;">Delete Account</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    <% end %>
    </div>
  </div>
</div>

<%# ── Email Modal ── %>
<div id="email-modal" role="dialog" aria-modal="true" aria-labelledby="email-modal-title" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:100; align-items:center; justify-content:center;">
  <div style="background:#FAF7F4; border-radius:16px; padding:24px; width:90%; max-width:340px; margin:16px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
      <h3 id="email-modal-title" style="color:#933a35; font-size:18px; font-weight:600; margin:0;">Change Email</h3>
      <button data-action="click->profile-modal#closeEmailModal" style="background:none; border:none; cursor:pointer;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <%= form_with url: update_profile_settings_path, method: :patch, local: true do %>
      <label style="display:block; color:#933a35; font-size:13px; font-weight:500; margin-bottom:6px;">New email address</label>
      <input type="email" name="email" value="<%= @user.email %>" required autocomplete="email"
             style="width:100%; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; padding:16px; font-size:16px; color:#933a35; box-sizing:border-box; margin-bottom:12px;">
      <label style="display:block; color:#933a35; font-size:13px; font-weight:500; margin-bottom:6px;">Current password</label>
      <input type="password" name="current_password" required autocomplete="current-password"
             placeholder="Enter your password to confirm"
             style="width:100%; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; padding:16px; font-size:16px; color:#933a35; box-sizing:border-box; margin-bottom:16px;">
      <button type="submit" style="width:100%; background:#933a35; color:white; border:none; border-radius:12px; padding:14px; font-size:16px; font-weight:500; cursor:pointer;">
        Save
      </button>
    <% end %>

    <button data-action="click->profile-modal#closeEmailModal"
            style="width:100%; background:transparent; color:#933a35; border:1px solid #DDD0CB; border-radius:12px; padding:14px; font-size:16px; font-weight:500; cursor:pointer; margin-top:8px;">
      Cancel
    </button>
  </div>
</div>

<%# ── Personal Information Edit Modal ── %>
<div id="personal-info-modal" role="dialog" aria-modal="true" aria-labelledby="personal-info-modal-title" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:100; align-items:center; justify-content:center;">
  <div style="background:#FAF7F4; border-radius:16px; padding:24px; width:90%; max-width:340px; margin:16px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
      <h3 id="personal-info-modal-title" style="color:#933a35; font-size:18px; font-weight:600; margin:0;">Personal Information</h3>
      <button data-action="click->profile-modal#closePersonalInfoModal" style="background:none; border:none; cursor:pointer;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <%= form_with url: update_profile_settings_path, method: :patch, local: true do %>
      <div style="margin-bottom:12px;">
        <label style="display:block; color:#933a35; font-size:14px; font-weight:500; margin-bottom:4px;">Name</label>
        <input type="text" name="name" value="<%= @user.first_name %>" required autocomplete="name"
               style="width:100%; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; padding:16px; font-size:16px; color:#933a35; box-sizing:border-box;">
      </div>

      <div style="margin-bottom:12px;">
        <label style="display:block; color:#933a35; font-size:14px; font-weight:500; margin-bottom:4px;">Cycle Length (days)</label>
        <input type="number" name="cycle_length" value="<%= @user.cycle_length || 28 %>" min="20" max="45" autocomplete="off"
               style="width:100%; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; padding:16px; font-size:16px; color:#933a35; box-sizing:border-box;">
      </div>

      <div style="margin-bottom:16px;">
        <label style="display:block; color:#933a35; font-size:14px; font-weight:500; margin-bottom:4px;">Period Length (days)</label>
        <input type="number" name="period_length" value="<%= @user.period_length || 5 %>" min="1" max="14" autocomplete="off"
               style="width:100%; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; padding:16px; font-size:16px; color:#933a35; box-sizing:border-box;">
      </div>

      <button type="submit" style="width:100%; background:#933a35; color:white; border:none; border-radius:12px; padding:14px; font-size:16px; font-weight:500; cursor:pointer;">
        Save
      </button>
    <% end %>

    <button data-action="click->profile-modal#closePersonalInfoModal"
            style="width:100%; background:transparent; color:#933a35; border:1px solid #DDD0CB; border-radius:12px; padding:14px; font-size:16px; font-weight:500; cursor:pointer; margin-top:8px;">
      Cancel
    </button>
  </div>
</div>
