<%# GDPR Consent screen - Article 9 %>
<% content_for(:header_left) do %>
  <%= link_to user_root_path, class: "p-2 flex items-center" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </svg>
  <% end %>
<% end %>

<div style="background:#ffffff; min-height:100vh;">
  <div style="max-width:430px; margin:0 auto; padding:0 16px 80px;">

    <%# Header %>
    <div style="padding:20px 0 16px;">
      <h2 style="color:#933a35; font-size:18px; font-weight:700;">Data & Privacy</h2>
    </div>
    <div style="border-bottom:1px solid #DDD0CB; margin-bottom:16px;"></div>

    <%# Intro %>
    <div style="background:#FDF0EE; border-radius:12px; padding:16px; margin-bottom:20px;">
      <p style="color:#933a35; font-size:14px; font-weight:500; margin:0;">
        Your health data is processed only with your explicit consent.
      </p>
    </div>

    <%# Consent Form %>
    <%= form_with url: "/settings/consent", method: :post, local: true do %>
      <%# Health Data Processing %>
      <label style="display:flex; align-items:flex-start; gap:12px; padding:16px; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; margin-bottom:12px; cursor:pointer;">
        <input type="checkbox" name="consents[health_data_processing]"
               <%= current_user.consent?("health_data_processing") ? "checked" : "" %>
               style="width:20px; height:20px; accent-color:#933a35; margin-top:2px;">
        <div style="flex:1;">
          <span style="display:block; color:#933a35; font-size:14px; font-weight:600;">Health Data</span>
          <span style="display:block; color:#6B6B6B; font-size:12px; margin-top:4px;">
            Cycle dates, symptoms, mood, energy, and other health information you log.
          </span>
        </div>
      </label>

      <%# Symptom Tracking %>
      <label style="display:flex; align-items:flex-start; gap:12px; padding:16px; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; margin-bottom:12px; cursor:pointer;">
        <input type="checkbox" name="consents[symptom_tracking]"
               <%= current_user.consent?("symptom_tracking") ? "checked" : "" %>
               style="width:20px; height:20px; accent-color:#933a35; margin-top:2px;">
        <div style="flex:1;">
          <span style="display:block; color:#933a35; font-size:14px; font-weight:600;">Symptom Tracking</span>
          <span style="display:block; color:#6B6B6B; font-size:12px; margin-top:4px;">
            Daily symptom logs including pain, mood, energy, sleep, and discharge.
          </span>
        </div>
      </label>

      <%# Cycle Tracking %>
      <label style="display:flex; align-items:flex-start; gap:12px; padding:16px; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; margin-bottom:12px; cursor:pointer;">
        <input type="checkbox" name="consents[cycle_tracking]"
               <%= current_user.consent?("cycle_tracking") ? "checked" : "" %>
               style="width:20px; height:20px; accent-color:#933a35; margin-top:2px;">
        <div style="flex:1;">
          <span style="display:block; color:#933a35; font-size:14px; font-weight:600;">Cycle Tracking</span>
          <span style="display:block; color:#6B6B6B; font-size:12px; margin-top:4px;">
            Menstrual dates, cycle phases, and predictions.
          </span>
        </div>
      </label>

      <%# Menstrual Data %>
      <label style="display:flex; align-items:flex-start; gap:12px; padding:16px; background:#FFFFFF; border:1px solid #DDD0CB; border-radius:12px; margin-bottom:20px; cursor:pointer;">
        <input type="checkbox" name="consents[menstrual_data]"
               <%= current_user.consent?("menstrual_data") ? "checked" : "" %>
               style="width:20px; height:20px; accent-color:#933a35; margin-top:2px;">
        <div style="flex:1;">
          <span style="display:block; color:#933a35; font-size:14px; font-weight:600;">Menstrual Data</span>
          <span style="display:block; color:#6B6B6B; font-size:12px; margin-top:4px;">
            Period start/end dates and flow intensity.
          </span>
        </div>
      </label>

      <button type="submit"
              style="width:100%; background:#933a35; color:white; border:none; border-radius:12px; padding:16px; font-size:16px; font-weight:500; cursor:pointer;">
        Save Preferences
      </button>
    <% end %>

    <%# Info text %>
    <div style="margin-top:24px; padding:16px; background:#FAF7F4; border-radius:12px;">
      <p style="color:#6B6B6B; font-size:12px; line-height:1.5; margin:0;">
        <strong style="color:#933a35;">Your Rights:</strong><br>
        You can withdraw consent at any time. Your data will be deleted according to our retention policy.
      </p>
    </div>

    <%# Link to Privacy Policy %>
    <%= link_to "View Privacy Policy", privacy_path, style: "display:block; text-align:center; color:#933a35; font-size:14px; margin-top:16px; text-decoration:underline;" %>

  </div>
</div>
