<%# Settings - My Calendar screen - matches Figma node %>
<%# Dark header auto-applied by layout; only back arrow override needed %>
<% content_for(:header_left) do %>
  <%= link_to edit_settings_path, class: "p-2 flex items-center" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </svg>
  <% end %>
<% end %>

<div style="background:#ffffff; min-height:100%;">

  <%# Content - max-width 430px centered %>
  <div style="max-width:430px; margin:0 auto; padding:0 16px 80px;">

    <%# My Calender title %>
    <div style="display:flex; align-items:center; gap:16px; padding:20px 0 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      <span style="color:#933a35; font-size:18px; font-weight:700;">My Calender</span>
    </div>
    <div style="border-bottom:1px solid #DDD0CB;"></div>

    <%# Show features title %>
    <div style="display:flex; align-items:center; gap:12px; padding:20px 0 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
        <line x1="12" y1="8" x2="12" y2="16" />
        <line x1="8" y1="12" x2="16" y2="12" />
      </svg>
      <span style="color:#933a35; font-size:16px; font-weight:500;">Show features</span>
    </div>

    <%# Appointments toggle %>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0;">
      <span style="color:#ff6b6b; font-size:14px; font-weight:500;">Appontments</span>
      <label style="position:relative; width:40px; height:20px; background:#933a35; border-radius:20px; cursor:pointer;">
        <input type="checkbox" checked style="opacity:0; width:0; height:0;">
        <span style="position:absolute; top:2px; left:2px; width:16px; height:16px; background:white; border-radius:50%; transition:0.2s;"></span>
      </label>
    </div>

    <%# Cycledays toggle %>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0;">
      <span style="color:#ff6b6b; font-size:14px; font-weight:500;">Cycledays</span>
      <label style="position:relative; width:40px; height:20px; background:#933a3520; border-radius:20px; cursor:pointer;">
        <input type="checkbox" style="opacity:0; width:0; height:0;">
        <span style="position:absolute; top:2px; left:2px; width:16px; height:16px; background:white; border-radius:50%; transition:0.2s;"></span>
      </label>
    </div>

    <%# Tracking Reminder toggle %>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0;">
      <span style="color:#ff6b6b; font-size:14px; font-weight:500;">Tracking Reminder</span>
      <label style="position:relative; width:40px; height:20px; background:#933a35; border-radius:20px; cursor:pointer;">
        <input type="checkbox" checked style="opacity:0; width:0; height:0;">
        <span style="position:absolute; top:2px; left:20px; width:16px; height:16px; background:white; border-radius:50%; transition:0.2s;"></span>
      </label>
    </div>

    <%# Moonphases toggle %>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0;">
      <span style="color:#ff6b6b; font-size:14px; font-weight:500;">Moonphases</span>
      <label style="position:relative; width:40px; height:20px; background:#933a35; border-radius:20px; cursor:pointer;">
        <input type="checkbox" checked style="opacity:0; width:0; height:0;">
        <span style="position:absolute; top:2px; left:20px; width:16px; height:16px; background:white; border-radius:50%; transition:0.2s;"></span>
      </label>
    </div>

    <%# Holidays toggle %>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0;">
      <span style="color:#ff6b6b; font-size:14px; font-weight:500;">Holidays</span>
      <label style="position:relative; width:40px; height:20px; background:#933a35; border-radius:20px; cursor:pointer;">
        <input type="checkbox" checked style="opacity:0; width:0; height:0;">
        <span style="position:absolute; top:2px; left:20px; width:16px; height:16px; background:white; border-radius:50%; transition:0.2s;"></span>
      </label>
    </div>

    <%# Kalenderwochen toggle %>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0;">
      <span style="color:#ff6b6b; font-size:14px; font-weight:500;">Kalenderwochen</span>
      <label style="position:relative; width:40px; height:20px; background:#933a3520; border-radius:20px; cursor:pointer;">
        <input type="checkbox" style="opacity:0; width:0; height:0;">
        <span style="position:absolute; top:2px; left:2px; width:16px; height:16px; background:white; border-radius:50%; transition:0.2s;"></span>
      </label>
    </div>

    <div style="border-bottom:1px solid #DDD0CB; margin:8px 0;"></div>

    <%# Day of the Week title %>
    <div style="display:flex; align-items:center; gap:12px; padding:20px 0 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
        <polyline points="14 14 17 17 20 13" />
      </svg>
      <span style="color:#933a35; font-size:16px; font-weight:500;">Day of the Week</span>
    </div>

    <%# Monday option %>
    <div style="padding:8px 0;">
      <span style="color:#933a3580; font-size:14px; font-weight:500;">Monday</span>
    </div>

    <div style="border-bottom:1px solid #DDD0CB; margin:8px 0;"></div>

    <%# Keep the device's time zone title %>
    <div style="display:flex; align-items:center; gap:12px; padding:20px 0 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
        <line x1="9" y1="6" x2="15" y2="6" />
        <line x1="9" y1="10" x2="15" y2="10" />
        <line x1="9" y1="14" x2="12" y2="14" />
        <line x1="9" y1="18" x2="12" y2="18" />
      </svg>
      <span style="color:#933a35; font-size:16px; font-weight:500;">Keep the device's time zone</span>
    </div>

    <%# Timezone option %>
    <div style="padding:8px 0;">
      <span style="color:#933a35; font-size:16px; font-weight:500;">Timezone</span>
    </div>
    <div style="padding-bottom:8px;">
      <span style="color:#933a3580; font-size:14px; font-weight:500;">Central European Standard Time</span>
    </div>

    <div style="border-bottom:1px solid #DDD0CB; margin:8px 0;"></div>

    <%# Links & Syncs title %>
    <div style="display:flex; align-items:center; gap:12px; padding:20px 0 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M21 12A9 9 0 0 1 12 21" stroke-dasharray="3 3" />
        <path d="M3 12a9 9 0 0 1 9-9" />
      </svg>
      <span style="color:#933a35; font-size:16px; font-weight:500;">Links & Syncs</span>
    </div>

    <%# Email sync options %>
    <div style="padding:12px 0;">
      <span style="color:#ff6b6b; font-size:14px; font-weight:500;">name@mailprogramm.com</span>
    </div>
    <div style="display:flex; align-items:center; gap:12px; padding:8px 0;">
      <span style="color:#933a3550; font-size:11px;">Gmail</span>
      <label style="position:relative; width:40px; height:20px; background:#933a35; border-radius:20px; cursor:pointer;">
        <input type="checkbox" checked style="opacity:0; width:0; height:0;">
        <span style="position:absolute; top:2px; left:20px; width:16px; height:16px; background:white; border-radius:50%; transition:0.2s;"></span>
      </label>
    </div>

    <div style="padding:12px 0;">
      <span style="color:#ff6b6b; font-size:14px; font-weight:500;">name@mailprogramm.com</span>
    </div>
    <div style="display:flex; align-items:center; gap:12px; padding:8px 0;">
      <span style="color:#933a3550; font-size:11px;">Microsoft</span>
      <label style="position:relative; width:40px; height:20px; background:#933a3520; border-radius:20px; cursor:pointer;">
        <input type="checkbox" style="opacity:0; width:0; height:0;">
        <span style="position:absolute; top:2px; left:2px; width:16px; height:16px; background:white; border-radius:50%; transition:0.2s;"></span>
      </label>
    </div>

  </div>
</div>
