<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:space-between; padding:60px 32px 48px; max-width:430px; margin:0 auto;">

  <!-- Title -->
  <div style="width:100%; text-align:center;">
    <h1 style="color:#933a35; font-size:36px; font-weight:700; text-transform:uppercase; letter-spacing:3.24px; text-align:center;">
      SIGN UP
    </h1>
  </div>

  <!-- Subtitle -->
  <div style="width:100%; text-align:center; margin-top:44px;">
    <p style="color:#933a35; font-size:22px; font-weight:500; text-align:center; line-height:27px; letter-spacing:1.32px;">
      <%= t('devise.registrations.new.subtitle', default: 'Create an account to track your cycle') %>
    </p>
  </div>

  <!-- Social Login -->
  <div style="width:100%; margin-top:62px;">
    <p style="color:#933a35; font-size:16px; font-weight:400; margin-bottom:21px; text-align:center;">
      <%= t('devise.registrations.new.fast_lane', default: 'Use the fast lane:') %>
    </p>

    <div style="display:flex; justify-content:center; gap:19px;">
      <%# Apple %>
      <%= button_to omniauth_authorize_path(:user, :apple),
            method: :post,
            data: { turbo: false },
            aria: { label: "Sign up with Apple" },
            style: "width:59px; height:52px; background:#000000; border-radius:8px; display:flex; align-items:center; justify-content:center; border:none; padding:0;" do %>
        <%= image_tag "apple-logo.png", alt: "Apple", style: "width:35px; height:35px; object-fit:contain;" %>
      <% end %>

      <%# Facebook %>
      <%= button_to omniauth_authorize_path(:user, :facebook),
            method: :post,
            data: { turbo: false },
            aria: { label: "Sign up with Facebook" },
            style: "width:59px; height:52px; background:#448AFF; border-radius:8px; display:flex; align-items:center; justify-content:center; border:none; padding:0;" do %>
        <%= image_tag "facebook.png", alt: "Facebook", style: "width:45px; height:45px; object-fit:contain;" %>
      <% end %>

      <%# Google %>
      <%= button_to omniauth_authorize_path(:user, :google_oauth2),
            method: :post,
            data: { turbo: false },
            aria: { label: "Sign up with Google" },
            style: "width:59px; height:52px; background:#ffffff; border:1px solid #dddddd; border-radius:8px; display:flex; align-items:center; justify-content:center; border:none; padding:0;" do %>
        <%= image_tag "google.png", alt: "Google", style: "width:34px; height:34px; object-fit:contain;" %>
      <% end %>
    </div>
  </div>
  <div style="width:100%; margin-top:62px; text-align:center;">
    <span style="color:#933a35; font-size:16px; font-weight:400;">
      <%= t('devise.registrations.new.or_email', default: '...or sign up with your E-mail:') %>
    </span>
  </div>

  <!-- Form -->
  <div style="width:100%;">
    <%= form_with url: registration_path, method: :post, local: true do |f| %>

      <% has_errors = @user.present? && @user.errors.any? %>

      <% if @error_type == :already_registered %>
        <!-- Already registered error state -->
        <div style="background:#FDF0EE; border-radius:8px; padding:12px 16px; margin-top:29px;">
          <p style="color:#933a35; font-size:28px; font-weight:700; margin-bottom:8px;">OOPS!</p>
          <p style="color:#933a35; font-size:16px; font-weight:400; margin-bottom:16px;">This email is already registered. Try logging in instead.</p>
          <a href="<%= new_session_path %>" style="display:block; width:100%; background:#933a35; color:#ffffff; text-align:center; padding:14px; border-radius:8px; font-size:18px; font-weight:500; text-decoration:none;">
            Log In
          </a>
        </div>
      <% elsif has_errors %>
        <!-- Validation error state -->
        <div style="display:flex; align-items:center; gap:8px; margin-top:19px; color:#933a35; font-size:16px; font-weight:400;">
          <span style="font-size:45px; font-weight:700; line-height:1;">!</span>
          <span><%= @user.errors.full_messages.first %></span>
        </div>
      <% end %>

      <!-- Email -->
      <div style="margin-top:29px;">
        <label for="email" class="sr-only">Email</label>
        <%= f.email_field :email,
            id: "email",
            autofocus: true,
            placeholder: t('devise.registrations.new.email_placeholder', default: 'E-mail...'),
            value: @user&.email,
            style: "width:100%; background:#EDE1D5; opacity:0.5; border-radius:8px; padding:14px 21px; height:52px; border:#{@user&.errors[:email]&.any? ? '2px solid #933a35' : 'none'}; font-size:22px; font-weight:500; color:#933a35; outline:none; box-sizing:border-box;" %>
      </div>

      <!-- Password -->
      <div style="margin-top:15px; position:relative;" data-controller="password-visibility">
        <label for="password_field" class="sr-only">Password</label>
        <%= f.password_field :password,
            id: 'password_field',
            data: { "password-visibility-target": "input" },
            placeholder: t('devise.registrations.new.password_placeholder', default: 'Password...'),
            style: "width:100%; background:#EDE1D5; opacity:0.5; border-radius:8px; padding:14px 50px 14px 21px; height:52px; border:none; font-size:22px; font-weight:500; color:#933a35; outline:none; box-sizing:border-box;" %>
        <button type="button" aria-label="Toggle password visibility" data-action="click->password-visibility#toggle" style="position:absolute; right:16px; top:50%; transform:translateY(-50%); cursor:pointer; display:inline-block; background:none; border:none; padding:0;">
          <svg data-password-visibility-target="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
          <svg data-password-visibility-target="eyeClosed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
        </button>
      </div>

      <!-- Confirm Password - shows error state if password has errors -->
      <div style="margin-top:15px; position:relative;" data-controller="password-visibility">
        <label for="password_confirmation_field" class="sr-only">Repeat password</label>
        <%= f.password_field :password_confirmation,
            id: 'password_confirmation_field',
            data: { "password-visibility-target": "input" },
            placeholder: t('devise.registrations.new.confirm_password_placeholder', default: 'Repeat password...'),
            style: "width:100%; background:#{has_errors ? '#F6F0EA' : '#EDE1D5'}; opacity:1; border-radius:8px; padding:14px 50px 14px 21px; height:52px; border:#{has_errors ? '2px solid #933a35' : 'none'}; font-size:22px; font-weight:500; color:#933a35; outline:none; box-sizing:border-box;" %>
        <button type="button" aria-label="Toggle password visibility" data-action="click->password-visibility#toggle" style="position:absolute; right:16px; top:50%; transform:translateY(-50%); cursor:pointer; display:inline-block; background:none; border:none; padding:0;">
          <svg data-password-visibility-target="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#{has_errors ? '#933a35' : 'rgba(147,58,53,0.5)'}" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
          <svg data-password-visibility-target="eyeClosed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#{has_errors ? '#933a35' : 'rgba(147,58,53,0.5)'}" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
        </button>
      </div>

      <!-- Terms -->
      <div style="display:flex; align-items:flex-start; gap:17px; margin-top:19px;">
        <input type="checkbox" required name="terms_accepted"
               style="margin-top:4px; width:31px; height:27px; accent-color:#933a35; border-radius:8px; flex-shrink:0;">
        <span style="color:#933a35; font-size:16px; font-weight:400; line-height:1.4;">
          I'll accept the <a href="/terms" style="color:#933a35; text-decoration:underline;">terms of use</a> and the <a href="/privacy" style="color:#933a35; text-decoration:underline;">privacy policy</a>
        </span>
      </div>

      <!-- Submit -->
      <div style="display:flex; justify-content:center; margin-top:75px;">
        <%= f.submit t('devise.registrations.new.submit', default: 'Create account'),
            style: "width:322px; height:#{has_errors ? '62' : '52'}px; background:#933a35; color:#ffffff; font-size:22px; font-weight:500; letter-spacing:0.66px; border-radius:8px; border:none; cursor:pointer;" %>
      </div>
    <% end %>
  </div>

  <!-- Login link -->
  <div style="width:100%; text-align:center; margin-top:22px;">
    <%= link_to t('devise.registrations.new.have_account', default: 'I already have an account'),
        new_session_path,
        style: "color:#933a35; font-size:16px; font-weight:400; text-decoration:none;" %>
  </div>

</div>
