<div class="bg-white min-h-screen flex flex-col items-center justify-between pt-[60px] pb-12 px-8 max-w-app mx-auto">

  <!-- Title -->
  <div class="w-full text-center">
    <h1 class="text-brand-primary text-[36px] font-bold uppercase tracking-[3.24px] text-center">
      SIGN UP
    </h1>
  </div>

  <!-- Subtitle -->
  <div class="w-full text-center mt-11">
    <p class="text-brand-primary text-[22px] font-medium text-center leading-[27px] tracking-[1.32px]">
      <%= t('devise.registrations.new.subtitle', default: 'Create an account, so we can save your tracked data and app settings.') %>
    </p>
  </div>

  <!-- Social Login -->
  <div class="w-full mt-[62px]">
    <p class="text-brand-primary text-base font-normal mb-[21px] text-center">
      <%= t('devise.registrations.new.fast_lane', default: 'Use the fast lane:') %>
    </p>

    <div class="flex justify-center gap-[19px]">

      <%# Apple %>
      <%= button_to omniauth_authorize_path(:user, :apple),
            method: :post,
            data: { turbo: false },
            aria: { label: "Sign up with Apple" },
            class: "w-[59px] h-[52px] bg-black rounded-lg flex items-center justify-center border-0 p-0 cursor-pointer" do %>
        <%= image_tag "apple-logo.png", alt: "Apple", class: "w-[35px] h-[35px] object-contain" %>
      <% end %>

      <%# Facebook %>
      <%= button_to omniauth_authorize_path(:user, :facebook),
            method: :post,
            data: { turbo: false },
            aria: { label: "Sign up with Facebook" },
            class: "w-[59px] h-[52px] bg-[#448AFF] rounded-lg flex items-center justify-center border-0 p-0 cursor-pointer" do %>
        <%= image_tag "facebook.png", alt: "Facebook", class: "w-[45px] h-[45px] object-contain" %>
      <% end %>

      <%# Google %>
      <%= button_to omniauth_authorize_path(:user, :google_oauth2),
            method: :post,
            data: { turbo: false },
            aria: { label: "Sign up with Google" },
            class: "w-[59px] h-[52px] bg-white border border-[#dddddd] rounded-lg flex items-center justify-center p-0 cursor-pointer" do %>
        <%= image_tag "google.png", alt: "Google", class: "w-[34px] h-[34px] object-contain" %>
      <% end %>

    </div>
  </div>

  <div class="w-full mt-[62px] text-center">
    <span class="text-brand-primary text-base font-normal">
      <%= t('devise.registrations.new.or_email', default: '...or sign up with your E-mail:') %>
    </span>
  </div>

  <!-- Form -->
  <div class="w-full">
    <%= form_with url: registration_path, method: :post do |f| %>

      <% has_errors = @user.present? && @user.errors.any? %>

      <% if @error_type == :already_registered %>
        <div id="reg-error" role="alert" class="bg-brand-error rounded-lg px-4 py-3 mt-[29px]">
          <p class="text-brand-primary text-[28px] font-bold mb-2">OOPS!</p>
          <p class="text-brand-primary text-base font-normal mb-4">This email is already registered. Try logging in instead.</p>
          <%= link_to "Log In", new_session_path,
              class: "block w-full bg-brand-primary text-white text-center py-[14px] rounded-lg text-lg font-medium no-underline" %>
        </div>
      <% elsif has_errors %>
        <div id="reg-error" role="alert" class="flex items-center gap-2 mt-[19px] text-brand-primary text-base font-normal">
          <span class="text-[45px] font-bold leading-none">!</span>
          <span><%= @user.errors.full_messages.first %></span>
        </div>
      <% end %>

      <!-- Email -->
      <div class="mt-[29px]">
        <label for="email" class="sr-only">Email</label>
        <%= f.email_field :email,
            id: "email",
            autofocus: true,
            autocomplete: "email",
            placeholder: t('devise.registrations.new.email_placeholder', default: 'E-mail...'),
            value: @user&.email,
            aria: { invalid: @user&.errors[:email]&.any?, describedby: has_errors ? "reg-error" : nil },
            class: "w-full bg-brand-field opacity-50 rounded-lg px-[21px] h-[52px] text-[22px] font-medium text-brand-primary outline-none #{@user&.errors[:email]&.any? ? 'border-2 border-brand-primary' : 'border-0'}" %>
      </div>

      <!-- Password -->
      <div class="mt-[15px] relative" data-controller="password-visibility">
        <label for="password_field" class="sr-only">Password</label>
        <%= f.password_field :password,
            id: "password_field",
            autocomplete: "new-password",
            placeholder: t('devise.registrations.new.password_placeholder', default: 'Password...'),
            data: { "password-visibility-target": "input" },
            class: "w-full bg-brand-field opacity-50 rounded-lg px-[21px] pr-[50px] h-[52px] text-[22px] font-medium text-brand-primary outline-none border-0" %>
        <button type="button" aria-label="Toggle password visibility" data-action="click->password-visibility#toggle" class="absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer bg-transparent border-0 p-0">
          <svg data-password-visibility-target="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
          <svg data-password-visibility-target="eyeClosed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
        </button>
      </div>

      <!-- Confirm Password -->
      <div class="mt-[15px] relative" data-controller="password-visibility">
        <label for="password_confirmation_field" class="sr-only">Repeat password</label>
        <%= f.password_field :password_confirmation,
            id: "password_confirmation_field",
            autocomplete: "new-password",
            placeholder: t('devise.registrations.new.confirm_password_placeholder', default: 'Repeat password...'),
            aria: { invalid: has_errors, describedby: has_errors ? "reg-error" : nil },
            data: { "password-visibility-target": "input" },
            class: "w-full rounded-lg px-[21px] pr-[50px] h-[52px] text-[22px] font-medium text-brand-primary outline-none #{has_errors ? 'bg-[#F6F0EA] border-2 border-brand-primary' : 'bg-brand-field border-0'}" %>
        <button type="button" aria-label="Toggle password visibility" data-action="click->password-visibility#toggle" class="absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer bg-transparent border-0 p-0">
          <svg data-password-visibility-target="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="<%= has_errors ? '#933a35' : 'rgba(147,58,53,0.5)' %>" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
          <svg data-password-visibility-target="eyeClosed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="<%= has_errors ? '#933a35' : 'rgba(147,58,53,0.5)' %>" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
        </button>
      </div>

      <!-- Terms -->
      <div class="flex items-start gap-[17px] mt-[19px]">
        <input type="checkbox" required name="terms_accepted"
               class="mt-1 w-[31px] h-[27px] accent-brand-primary rounded-lg shrink-0">
        <span class="text-brand-primary text-base font-normal leading-snug">
          I'll accept the <%= link_to "terms of use", terms_path, class: "text-brand-primary underline" %> and the <%= link_to "privacy policy", privacy_path, class: "text-brand-primary underline" %>
        </span>
      </div>

      <!-- Submit -->
      <div class="flex justify-center mt-[75px]">
        <%= f.submit t('devise.registrations.new.submit', default: 'Create account'),
            class: "w-[322px] bg-brand-primary text-white text-[22px] font-medium tracking-[0.66px] rounded-lg border-0 cursor-pointer #{has_errors ? 'h-[62px]' : 'h-[52px]'}" %>
      </div>
    <% end %>
  </div>

  <!-- Login link -->
  <div class="w-full text-center mt-[22px]">
    <%= link_to t('devise.registrations.new.have_account', default: 'I already have an account'),
        new_session_path,
        class: "text-brand-primary text-base font-normal no-underline" %>
  </div>

</div>
