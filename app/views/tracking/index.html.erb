<% content_for(:page_title) { "Self Analysis" } %>
<% content_for(:header_color) { "#ffffff" } %>

<%
  def arc_path(cx, cy, r_out, r_in, start_deg, end_deg)
    to_rad = Math::PI / 180.0
    sweep = end_deg - start_deg
    sweep = 359.9999 if sweep.abs >= 360
    large = sweep.abs > 180 ? 1 : 0
    dir   = sweep >= 0 ? 1 : 0
    sx = cx + r_out * Math.cos(start_deg * to_rad)
    sy = cy + r_out * Math.sin(start_deg * to_rad)
    ex = cx + r_out * Math.cos(end_deg   * to_rad)
    ey = cy + r_out * Math.sin(end_deg   * to_rad)
    ix = cx + r_in  * Math.cos(end_deg   * to_rad)
    iy = cy + r_in  * Math.sin(end_deg   * to_rad)
    jx = cx + r_in  * Math.cos(start_deg * to_rad)
    jy = cy + r_in  * Math.sin(start_deg * to_rad)
    ["M #{sx.round(3)},#{sy.round(3)}", "A #{r_out},#{r_out} 0 #{large},#{dir} #{ex.round(3)},#{ey.round(3)}", "L #{ix.round(3)},#{iy.round(3)}", "A #{r_in},#{r_in} 0 #{large},#{1 - dir} #{jx.round(3)},#{jy.round(3)}", "Z"].join(" ")
  end
%>

<% phase_colour = @meta&.dig(:colour) || "#933a35" %>
<% phase_label  = @phase ? @phase.capitalize : nil %>
<% phase_season = @meta&.dig(:season) %>

<div class="min-h-screen pb-24 bg-brand-field">
  <div class="max-w-app mx-auto px-4">

    <%# ── Avatar (tap to change) ──────────────────────────────────────── %>
    <div class="flex justify-center pt-8 pb-5">
      <%= link_to profile_settings_path, class: "relative block w-56 h-56 shrink-0", aria: { label: "Change profile picture" } do %>
        <div class="w-56 h-56 rounded-full flex items-center justify-center overflow-hidden"
             style="background:<%= phase_colour %>;">
          <% if current_user.avatar_preset.present? %>
            <% preset = AvatarService.find_by_id(current_user.avatar_preset) %>
            <% if preset %>
              <%= image_tag "avatars/#{preset[:file]}", class: "w-full h-full object-cover", alt: preset[:name] %>
            <% end %>
          <% elsif current_user.avatar.attached? %>
            <%= image_tag current_user.avatar,
                  class: "w-full h-full object-cover",
                  alt: current_user.name %>
          <% elsif current_user.avatar_url.present? %>
            <%= image_tag current_user.avatar_url,
                  class: "w-full h-full object-cover",
                  alt: current_user.name %>
          <% else %>
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none"
                 stroke="white" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
               <circle cx="12" cy="8" r="4" />
               <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
            </svg>
          <% end %>
        </div>
        <%# Camera edit badge %>
        <span class="absolute bottom-2 right-2 w-10 h-10 rounded-full bg-white shadow-md
                     flex items-center justify-center" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
               stroke="<%= phase_colour %>" stroke-width="1.8" viewBox="0 0 24 24">
             <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
             <circle cx="12" cy="13" r="4" />
          </svg>
        </span>
      <% end %>
    </div>

    <%# ── Phase text ──────────────────────────────────────────────────── %>
    <div class="text-center mb-6">
      <% if phase_label %>
        <p class="text-2xl font-medium text-brand-primary font-['Montserrat']">You are in your:</p>
        <h1 class="text-3xl font-extrabold leading-tight" style="color:<%= phase_colour %>;">
          <%= phase_label %> Phase
        </h1>
      <% else %>
        <div class="rounded-2xl px-4 py-3 text-sm bg-brand-error text-brand-primary">
          Log your last period to see your current phase.
        </div>
      <% end %>
    </div>

    <%# ── Cycle-day strip ─────────────────────────────────────────────── %>
    <% if @strip.present? %>
      <div class="mb-1 overflow-x-auto scrollbar-hide">
        <div class="flex gap-3 pt-2 pb-1 w-max px-4">
          <% @strip.each do |day| %>
            <% dot_colour = day[:colour] || "#D18D83" %>
            <div class="w-12 h-12 rounded-full flex items-center justify-center text-base font-semibold <%= day[:current] ? 'text-white ring-2 ring-offset-2 ring-white' : 'text-white opacity-75' %>"
                 style="background:<%= dot_colour %>;">
              <%= day[:cycle_day] %>
            </div>
          <% end %>
        </div>
      </div>
      <% if @cycle_day %>
        <p class="text-center text-xs text-brand-primary font-['Montserrat'] mb-6">Cycleday <%= @cycle_day %></p>
      <% end %>
    <% end %>

    <%# ── Navigation cards ───────────────────────────────────────────── %>
    <div class="flex flex-col gap-3 mb-8">

      <%= link_to symptoms_path,
            class: "flex justify-between items-center rounded-lg px-5 h-12 bg-white no-underline" do %>
        <span class="text-xl font-medium text-brand-primary font-['Montserrat']">My Symptoms</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
             stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      <% end %>

      <%= link_to superpowers_path,
            class: "flex justify-between items-center rounded-lg px-5 h-12 bg-white no-underline" do %>
        <span class="text-xl font-medium text-brand-primary font-['Montserrat']">My Superpower</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
             stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      <% end %>

      <%= link_to period_tracking_index_path,
            class: "flex justify-between items-center rounded-lg px-5 h-12 bg-white no-underline" do %>
        <span class="text-xl font-medium text-brand-primary font-['Montserrat']">Track my Period</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
             stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      <% end %>

      <button type="button"
              data-controller="open-feedback"
              data-open-feedback-type-value="feedback"
              data-action="click->open-feedback#open"
              class="flex justify-between items-center rounded-lg px-5 h-12 bg-white/50 w-full text-left">
        <span class="text-xl font-medium text-brand-primary font-['Montserrat']">Give feedback</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
             stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </button>

    </div>

    <%# ── Calendar shortcut ───────────────────────────────────────────── %>
    <div class="flex justify-center pb-4">
      <%= link_to calendar_path,
            class: "w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-sm",
            aria: { label: "Go to calendar" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none"
             stroke="<%= phase_colour %>" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
             viewBox="0 0 24 24" aria-hidden="true">
           <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
           <line x1="16" y1="2" x2="16" y2="6" />
           <line x1="8" y1="2" x2="8" y2="6" />
           <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
      <% end %>
    </div>

  </div>
</div>
