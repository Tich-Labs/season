<% content_for(:page_title) { "Selfanalysis" } %>

<%
  # Inline arc-path helper — builds a donut arc SVG path string.
  # cx/cy = centre, r_out/r_in = outer/inner radius, start/end in degrees.
  def arc_path(cx, cy, r_out, r_in, start_deg, end_deg)
    to_rad = Math::PI / 180.0
    # Clamp sweep to just under 360° so full-circle arcs still render
    sweep = end_deg - start_deg
    sweep = 359.9999 if sweep.abs >= 360
    large = sweep.abs > 180 ? 1 : 0
    dir   = sweep >= 0 ? 1 : 0

    sx = cx + r_out * Math.cos(start_deg * to_rad)
    sy = cy + r_out * Math.sin(start_deg * to_rad)
    ex = cx + r_out * Math.cos(end_deg   * to_rad)
    ey = cy + r_out * Math.sin(end_deg   * to_rad)

    ix = cx + r_in  * Math.cos(end_deg   * to_rad)
    iy = cy + r_in  * Math.sin(end_deg   * to_rad)
    jx = cx + r_in  * Math.cos(start_deg * to_rad)
    jy = cy + r_in  * Math.sin(start_deg * to_rad)

    [
      "M #{sx.round(3)},#{sy.round(3)}",
      "A #{r_out},#{r_out} 0 #{large},#{dir} #{ex.round(3)},#{ey.round(3)}",
      "L #{ix.round(3)},#{iy.round(3)}",
      "A #{r_in},#{r_in} 0 #{large},#{1 - dir} #{jx.round(3)},#{jy.round(3)}",
      "Z"
    ].join(" ")
  end
%>

<% phase_colour  = @meta&.dig(:colour)      || "#933a35" %>
<% phase_season  = @meta&.dig(:season)      || "" %>
<% phase_label   = @phase ? @phase.capitalize : nil %>

<div class="min-h-screen pb-24" style="background:#EDE1D5;">
  <div class="max-w-[430px] mx-auto px-4 pt-6">

    <%# ── Date ──────────────────────────────────────────────────────── %>
    <p class="text-sm mb-5" style="color:#6B6B6B;">
      <%= Time.zone.today.strftime("%A, %d %B %Y") %>
    </p>

    <%# ── Phase header ──────────────────────────────────────────────── %>
    <% if phase_label %>
      <p class="text-sm mb-1" style="color:#6B6B6B;">You are in your:</p>
      <h1 class="text-3xl font-bold mb-1 leading-tight" style="color:<%= phase_colour %>;">
        <%= phase_season %> &mdash; <%= phase_label %>
      </h1>
      <% if @cycle_day %>
        <p class="text-sm mb-5" style="color:#6B6B6B;">Day <%= @cycle_day %> of your cycle</p>
      <% end %>
    <% else %>
      <div class="rounded-2xl px-4 py-3 mb-5 text-sm" style="background:#FDF0EE; color:#933a35;">
        Log your last period to see your current phase.
      </div>
    <% end %>

    <%# ── Cycle-day strip ────────────────────────────────────────────── %>
    <% if @strip.present? %>
      <div class="mb-6 -mx-4 px-4 overflow-x-auto"
           style="scrollbar-width:none; -ms-overflow-style:none;">
        <div class="flex gap-2 pb-1 w-max">
          <% @strip.each do |day| %>
            <% dot_colour = day[:colour] || "#D18D83" %>
            <% if day[:current] %>
              <div class="flex flex-col items-center gap-1">
                <div class="w-11 h-11 rounded-full flex items-center justify-center text-white text-sm font-bold ring-2 ring-offset-2 ring-white"
                     style="background:<%= dot_colour %>; ring-color:<%= dot_colour %>;">
                  <%= day[:cycle_day] %>
                </div>
                <span class="text-[10px] font-semibold" style="color:<%= dot_colour %>;">
                  Today
                </span>
              </div>
            <% else %>
              <div class="flex flex-col items-center gap-1">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs opacity-70"
                     style="background:<%= dot_colour %>;">
                  <%= day[:cycle_day] %>
                </div>
                <span class="text-[9px]" style="color:#6B6B6B;">
                  <%= day[:date].strftime("%-d") %>
                </span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── SVG donut wheel ────────────────────────────────────────────── %>
    <% if @arcs.present? %>
      <div class="flex justify-center mb-6">
        <%
          cx = 110; cy = 110; r_out = 96; r_in = 62
          # Needle angle for current cycle day position
          needle_angle = -90.0
          if @cycle_day
            needle_angle = -90.0 + ((@cycle_day - 1).to_f / (current_user.cycle_length || 28)) * 360
          end
          nx = cx + (r_in + (r_out - r_in) / 2.0) * Math.cos(needle_angle * Math::PI / 180.0)
          ny = cy + (r_in + (r_out - r_in) / 2.0) * Math.sin(needle_angle * Math::PI / 180.0)
        %>
        <svg width="220" height="220" viewBox="0 0 220 220" role="img"
             aria-label="Cycle wheel showing current phase">
          <% @arcs.each do |arc| %>
            <path d="<%= arc_path(cx, cy, r_out, r_in, arc[:start_angle], arc[:end_angle]) %>"
                  fill="<%= arc[:colour] %>"
                  stroke="#EDE1D5" stroke-width="2" />
          <% end %>

          <%# Centre label %>
          <% if @cycle_day %>
            <text x="<%= cx %>" y="<%= cy - 8 %>"
                  text-anchor="middle" dominant-baseline="middle"
                  font-size="28" font-weight="700"
                  fill="<%= phase_colour %>"><%= @cycle_day %></text>
            <text x="<%= cx %>" y="<%= cy + 18 %>"
                  text-anchor="middle" dominant-baseline="middle"
                  font-size="11" fill="#6B6B6B">Day</text>
          <% else %>
            <text x="<%= cx %>" y="<%= cy %>"
                  text-anchor="middle" dominant-baseline="middle"
                  font-size="13" fill="#6B6B6B">No data</text>
          <% end %>

          <%# Current-day dot on wheel %>
          <circle cx="<%= nx.round(2) %>" cy="<%= ny.round(2) %>"
                  r="6" fill="white" stroke="<%= phase_colour %>" stroke-width="2.5" />
        </svg>
      </div>
    <% end %>

    <%# ── Selfanalysis heading ───────────────────────────────────────── %>
    <h2 class="text-xl font-bold mb-4" style="color:#3d2b28;">
      Selfanalysis &mdash; <%= Time.zone.today.strftime("%B") %>
    </h2>

    <%# ── Streak badge ───────────────────────────────────────────────── %>
    <% if @streak > 0 %>
      <div class="flex items-center gap-3 rounded-2xl px-4 py-3 mb-4"
           style="background:#ffffff;">
        <span class="text-2xl" aria-hidden="true">🔥</span>
        <div>
          <p class="font-bold text-lg leading-none" style="color:#933a35;"><%= @streak %> day streak</p>
          <p class="text-xs mt-0.5" style="color:#6B6B6B;">Keep going!</p>
        </div>
      </div>
    <% end %>

    <%# ── Navigation cards ───────────────────────────────────────────── %>
    <div class="flex flex-col gap-3 mb-4">

      <%= link_to symptoms_path,
            class: "flex justify-between items-center rounded-2xl px-5 py-4",
            style: "background:#ffffff; text-decoration:none;" do %>
        <span class="font-semibold text-base" style="color:#3d2b28;">My Symptoms</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
             stroke="#933a35" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      <% end %>

      <%= link_to superpowers_path,
            class: "flex justify-between items-center rounded-2xl px-5 py-4",
            style: "background:#ffffff; text-decoration:none;" do %>
        <span class="font-semibold text-base" style="color:#3d2b28;">My Superpower</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
             stroke="#933a35" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      <% end %>

    </div>

    <%# ── Period log form ────────────────────────────────────────────── %>
    <div class="rounded-2xl px-5 py-5" style="background:#ffffff;">
      <h3 class="font-bold text-base mb-4" style="color:#3d2b28;">Period</h3>

      <%= form_with url: tracking_index_path, method: :post, local: true do |f| %>
        <label class="flex items-center gap-3 cursor-pointer rounded-xl px-4 py-3 mb-4"
               style="background:#EDE1D5;">
          <%= f.check_box :period_start, {
                style: "width:22px; height:22px; accent-color:#933a35; flex-shrink:0;",
                id: "period_start_check"
              }, "1", "0" %>
          <span class="text-base font-medium" style="color:#933a35;">Period started today</span>
        </label>

        <%= f.submit "Save",
              class: "w-full py-3.5 rounded-xl font-semibold text-base cursor-pointer border-0",
              style: "background:#933a35; color:#ffffff;" %>
      <% end %>
    </div>

    <%# ── Feedback link ──────────────────────────────────────────────── %>
    <a href="#" class="flex justify-between items-center py-4 mt-2"
       style="color:#933a35; text-decoration:none; border-top:1px solid rgba(147,58,53,0.15);">
      <span class="text-sm"><%= t("tracking.feedback") %></span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none"
           stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

  </div>
</div>
