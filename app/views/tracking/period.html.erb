<% editing = @existing.present? %>
<% content_for(:page_title) { editing ? "Edit Period" : "Log Period" } %>
<% content_for(:header_left) do %>
  <%= link_to tracking_index_path,
        style: "color:#933a35; font-size:15px; font-weight:500; text-decoration:none; padding:8px 4px; font-family:'Montserrat',sans-serif;" do %>
    &lt; back
  <% end %>
<% end %>

<%
  today      = Time.zone.today
  first_day  = @month
  last_day   = @month.end_of_month
  start_pad  = (first_day.wday == 0 ? 6 : first_day.wday - 1)
  grid_days  = (0...(start_pad + last_day.day)).map { |i| i < start_pad ? nil : first_day + (i - start_pad) }
  grid_days += Array.new((7 - grid_days.size % 7) % 7, nil)
  prev_month = @month.prev_month
  next_month = @month.next_month
%>

<div style="background:#FAF7F4; min-height:100vh; padding-bottom:80px; font-family:'Montserrat',sans-serif;">
  <div style="max-width:430px; margin:0 auto;">

    <%# ── Phase-coloured header ── %>
    <div style="background:<%= @phase_col %>; padding:24px 20px 20px;">
      <p style="color:rgba(255,255,255,0.8); font-size:12px; font-weight:500; text-transform:uppercase; letter-spacing:0.06em; margin:0 0 4px;">
        <%= editing ? "Edit period start" : "When did your period start?" %>
      </p>
      <p style="color:#FFFFFF; font-size:22px; font-weight:700; margin:0; line-height:1.2;">
        <%= @selected.strftime("%B %-d, %Y") %>
      </p>
    </div>

    <%# ── Month navigation ── %>
    <div style="background:#FFFFFF; display:flex; align-items:center; justify-content:space-between; padding:14px 20px; border-bottom:1px solid #EDE1D5;">
      <%= link_to period_tracking_index_path(date: prev_month.to_s),
            style: "display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:50%; background:#EDE1D5; text-decoration:none;" do %>
        <svg width="18" height="18" fill="none" stroke="#933a35" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
      <% end %>
      <span style="font-weight:700; font-size:16px; color:#3d2b28;"><%= @month.strftime("%B %Y") %></span>
      <%= link_to period_tracking_index_path(date: next_month.to_s),
            style: "display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:50%; background:#EDE1D5; text-decoration:none;" do %>
        <svg width="18" height="18" fill="none" stroke="#933a35" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
      <% end %>
    </div>

    <%# ── Weekday headers ── %>
    <div style="background:#FFFFFF; display:grid; grid-template-columns:repeat(7,1fr); padding:12px 8px 4px;">
      <% %w[Mo Tu We Th Fr Sa Su].each do |d| %>
        <div style="text-align:center; font-size:11px; font-weight:600; color:#6B6B6B;"><%= d %></div>
      <% end %>
    </div>

    <%# ── Calendar grid + form ── %>
    <%= form_with url: period_tracking_index_path, method: :patch, local: true do |f| %>
      <div style="background:#FFFFFF; padding:4px 8px 16px;">
        <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:2px 0;">
          <% grid_days.each do |day| %>
            <% if day.nil? %>
              <div></div>
            <% else %>
              <%
                is_selected = day == @selected
                is_today    = day == today
                is_future   = day > today
                cell_bg     = is_selected ? @phase_col : (is_today ? "#EDE1D5" : "transparent")
                text_col    = is_selected ? "#FFFFFF"  : (is_future ? "#AFAFAF" : "#3d2b28")
                fw          = (is_selected || is_today) ? "700" : "400"
              %>
              <% if is_future %>
                <div style="display:flex; align-items:center; justify-content:center; height:40px; width:40px; margin:auto; border-radius:50%; background:<%= cell_bg %>; color:<%= text_col %>; font-size:14px; font-weight:<%= fw %>;">
                  <%= day.day %>
                </div>
              <% else %>
                <label style="display:flex; align-items:center; justify-content:center; height:40px; width:40px; margin:auto; border-radius:50%; cursor:pointer; background:<%= cell_bg %>; color:<%= text_col %>; font-size:14px; font-weight:<%= fw %>;">
                  <%= f.radio_button :date, day.to_s, checked: is_selected, style: "display:none;" %>
                  <%= day.day %>
                </label>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# ── Selected date summary ── %>
      <div style="margin:16px; background:#FFFFFF; border-radius:16px; padding:16px 20px;">
        <p style="font-size:13px; font-weight:600; color:#3d2b28; margin:0 0 4px;">Period start date</p>
        <p style="font-size:16px; font-weight:700; color:<%= @phase_col %>; margin:0 0 6px;">
          <%= @selected.strftime("%A, %-d %B %Y") %>
        </p>
        <p style="font-size:12px; color:#6B6B6B; margin:0;">Tap any past date to select it, then save.</p>
      </div>

      <%# ── Save button ── %>
      <div style="padding:0 16px;">
        <%= f.submit editing ? "Update period start" : "Save period start",
              style: "width:100%; background:<%= @phase_col %>; color:#FFFFFF; padding:16px; border-radius:12px; border:none; font-size:16px; font-weight:600; font-family:'Montserrat',sans-serif; cursor:pointer;" %>
      </div>

    <% end %>

  </div>
</div>
