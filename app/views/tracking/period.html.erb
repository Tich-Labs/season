<% editing = @existing.present? %>
<% content_for(:page_title) { editing ? "Edit Period" : "Log Period" } %>
<% content_for(:header_left) do %>
  <a href="/tracking" class="text-brand-primary text-sm font-medium no-underline p-2">
    &lt; back
  </a>
<% end %>

<%
  today      = Time.zone.today
  first_day  = @month
  last_day   = @month.end_of_month
  start_pad  = (first_day.wday == 0 ? 6 : first_day.wday - 1)
  grid_days  = (0...(start_pad + last_day.day)).map { |i| i < start_pad ? nil : first_day + (i - start_pad) }
  grid_days += Array.new((7 - grid_days.size % 7) % 7, nil)
  prev_month = @month.prev_month
  next_month = @month.next_month
%>

<div class="bg-brand-background min-h-screen pb-20">
  <div class="max-w-app mx-auto">

    <%# ── Phase-coloured header ── %>
    <div class="p-6 pb-5" style="background:<%= @phase_col %>;">
      <p class="text-white/80 text-xs font-medium uppercase tracking-wider m-0 mb-1">
        <%= editing ? "Edit period start" : "When did your period start?" %>
      </p>
      <p class="text-white text-2xl font-bold m-0 leading-tight">
        <%= @selected.strftime("%B %-d, %Y") %>
      </p>
    </div>

    <%# ── Month navigation ── %>
    <div class="bg-white flex items-center justify-between p-3.5 border-b border-brand-field">
      <%= link_to "/tracking/period?date=#{prev_month}",
            class: "flex items-center justify-center w-9 h-9 rounded-full bg-brand-field no-underline" do %>
        <svg width="18" height="18" fill="none" stroke="#933a35" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
      <% end %>
      <span class="font-bold text-base text-brand-dark"><%= @month.strftime("%B %Y") %></span>
      <%= link_to "/tracking/period?date=#{next_month}",
            class: "flex items-center justify-center w-9 h-9 rounded-full bg-brand-field no-underline" do %>
        <svg width="18" height="18" fill="none" stroke="#933a35" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
      <% end %>
    </div>

    <%# ── Weekday headers ── %>
    <div class="bg-white grid grid-cols-7 p-3 pb-1">
      <% %w[Mo Tu We Th Fr Sa Su].each do |d| %>
        <div class="text-center text-xs font-semibold text-brand-secondary"><%= d %></div>
      <% end %>
    </div>

    <%# ── Calendar grid (each day is a link) ── %>
    <div class="bg-white p-1 pb-4 px-2">
      <div class="grid grid-cols-7 gap-y-0">
        <% grid_days.each do |day| %>
          <% if day.nil? %>
            <div></div>
          <% else %>
            <%
              is_selected = day == @selected
              is_today    = day == today
              is_future   = day > today
              cell_bg     = is_selected ? @phase_col : (is_today ? "#EDE1D5" : "transparent")
              text_col    = is_selected ? "#FFFFFF"  : (is_future ? "#AFAFAF" : "#3d2b28")
              fw          = (is_selected || is_today) ? "700" : "400"
            %>
            <% if is_future %>
              <div class="flex items-center justify-center h-10 w-10 mx-auto rounded-full text-sm" style="background:<%= cell_bg %>; color:<%= text_col %>; font-weight:<%= fw %>;">
                <%= day.day %>
              </div>
            <% else %>
              <a href="/tracking/period?selected_date=<%= day %>" data-turbo="false"
                 class="flex items-center justify-center h-10 w-10 mx-auto rounded-full text-sm no-underline" style="background:<%= cell_bg %>; color:<%= text_col %>; font-weight:<%= fw %>;">
                <%= day.day %>
              </a>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# ── Selected date summary + Save button ── %>
    <div class="m-4 bg-white rounded-2xl p-5">
      <p class="text-xs font-semibold text-brand-dark m-0 mb-1">Period start date</p>
      <p class="text-base font-bold m-0 mb-1.5" style="color:<%= @phase_col %>;">
        <%= @selected.strftime("%A, %-d %B %Y") %>
      </p>
      <p class="text-xs text-brand-secondary m-0">Tap any past date to select it, then save.</p>
    </div>

    <% btn_text = editing ? "Update period start" : "Save period start" %>
    <div class="px-4">
      <a href="/tracking/period?save=1&date=<%= @selected %>" data-turbo="false"
         class="block text-center no-underline text-white rounded-xl p-4 text-base font-semibold" style="background:<%= @phase_col %>;">
        <%= btn_text %>
      </a>
    </div>
  </div>
</div>
