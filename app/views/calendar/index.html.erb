<% content_for(:page_title) { @date.strftime("%B") } %>
<% content_for(:header_left) do %>
  <button class="p-2" data-action="click->menu#open">
    <svg class="w-6 h-6 text-brand-primary" viewBox="0 0 24 24" fill="currentColor">
      <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" />
    </svg>
  </button>
<% end %>
<% content_for(:header_center_dropdown) do %>
  <div class="relative" id="view-dropdown" data-controller="calendar-index">
    <button type="button" class="p-1" data-action="click->calendar-index#toggleDropdown">
      <svg class="w-5 h-5 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </button>
    <div class="absolute left-0 top-full mt-1 w-40 bg-white rounded-lg shadow-lg hidden z-50"
         id="view-dropdown-menu">
      <%= link_to "Day View", daily_view_path(Time.zone.today), class: "block px-4 py-2 text-sm text-[#933a35] hover:bg-[#f5ede8]", data: { turbo_action: "replace" } %>
      <%= link_to "Week View", calendar_weekly_path, class: "block px-4 py-2 text-sm text-[#933a35] hover:bg-[#f5ede8]", data: { turbo_action: "replace" } %>
      <%= link_to "Month View", user_root_path, class: "block px-4 py-2 text-sm text-[#933a35] hover:bg-[#f5ede8]", data: { turbo_action: "replace" } %>
    </div>
  </div>
<% end %>
<% content_for(:header_right) do %>
  <div class="flex items-center gap-3">
    <%= link_to informations_path do %>
      <svg class="w-6 h-6 text-brand-primary" viewBox="0 0 25 25" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.4998 22.9168C18.2289 22.9168 22.9164 18.2293 22.9164 12.5001C22.9164 6.77094 18.2289 2.08344 12.4998 2.08344C6.7706 2.08344 2.0831 6.77094 2.0831 12.5001C2.0831 18.2293 6.7706 22.9168 12.4998 22.9168Z" />
        <path d="M12.4998 8.33344V13.5418" stroke-width="1.7" />
        <path d="M12.4957 16.6667H12.5051" stroke-width="2" />
      </svg>
    <% end %>
  </div>
<% end %>

<%# ── No-cycle banner (shown when user has no period data) ── %>
<% if current_user.onboarding_completed? && current_user.last_period_start.nil? %>
  <div style="background:#FDF0EE; padding:12px 16px; text-align:center; border-bottom:1px solid #933a35;">
    <p style="color:#933a35; font-size:14px; margin:0 0 8px;">
      We haven't received your period data yet. Add your last period start date to see your cycle phases.
    </p>
    <a href="/tracking/period"
       class="inline-block bg-[#933a35] text-white rounded-full px-4 py-2 text-sm font-semibold"
       style="text-decoration:none;">
      Log period start
    </a>
  </div>
<% end %>

<div style="background:#FAF7F4; min-height:100vh; padding-bottom:80px;">
  <div style="max-width:430px; width:100%; margin:0 auto; padding:12px 16px 0;">

    <%# ── Greeting ── %>
    <div style="margin-bottom:14px;">
      <p style="color:#933a35; font-size:36px; font-style:normal; font-weight:500; margin:0 0 2px; line-height:1.1; font-family:'Montserrat',sans-serif;">
        Hello <%= current_user.first_name || "there" %>
      </p>
      <p style="color:#933a35; font-size:24px; font-weight:300; margin:0; line-height:1.3; font-family:'Montserrat',sans-serif;">
        <% if @current_season %>You are in <%= @current_season %><% else %>This is your month<% end %>
      </p>
    </div>

    <%# ── Streak ── %>
    <% if @streak > 0 %>
      <div style="display:flex; align-items:center; gap:8px; background:#ffffff; padding:10px 12px; border-radius:8px; margin-bottom:14px;">
        <span style="font-size:18px;">🔥</span>
        <span style="color:#933a35; font-size:14px; font-weight:500;"><%= @streak %> day streak</span>
      </div>
    <% end %>

    <%# ── Filter chips (no JS — plain GET links) ── %>
    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;">
      <% [["all", "All"], ["events", "Events"], ["tracking", "Tracked"], ["cycle", "Cycle"]].each do |value, label| %>
        <% active = @mode == value %>
        <%= link_to label,
              user_root_path(date: @date.to_s, mode: value),
              style: "padding:5px 14px; border-radius:20px; font-size:12px; font-weight:600; text-decoration:none; " \
                     "background:#{active ? '#933a35' : '#FFFFFF'}; " \
                     "color:#{active ? '#FFFFFF' : '#933a35'}; " \
                     "border:1px solid #933a35;" %>
      <% end %>
    </div>

    <%# ── Day-of-week headers ── %>
    <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:0; margin-bottom:6px;">
      <% %w[Mo Tu We Th Fr Sa Su].each do |d| %>
        <div style="text-align:center; color:#6B6B6B; font-size:11px; font-weight:600; letter-spacing:0.04em; padding:4px 0;">
          <%= d %>
        </div>
      <% end %>
    </div>

    <%# ── Phase Legend ── %>
    <% if @cycle_by_date.present? %>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-bottom:12px;">
        <div style="display:flex; align-items:center; gap:4px;">
          <span style="width:10px; height:10px; border-radius:50%; background:#933a35;"></span>
          <span style="font-size:11px; color:#6B6B6B;">Menstrual</span>
        </div>
        <div style="display:flex; align-items:center; gap:4px;">
          <span style="width:10px; height:10px; border-radius:50%; background:#D18D83;"></span>
          <span style="font-size:11px; color:#6B6B6B;">Follicular</span>
        </div>
        <div style="display:flex; align-items:center; gap:4px;">
          <span style="width:10px; height:10px; border-radius:50%; background:#F5C6AD;"></span>
          <span style="font-size:11px; color:#6B6B6B;">Ovulation</span>
        </div>
        <div style="display:flex; align-items:center; gap:4px;">
          <span style="width:10px; height:10px; border-radius:50%; background:#EDE1D5;"></span>
          <span style="font-size:11px; color:#6B6B6B;">Luteal</span>
        </div>
        <button onclick="document.getElementById('season-info-modal').style.display='flex'"
                style="background:none; border:none; cursor:pointer; padding:0 4px;">
          <svg width="16" height="16" fill="none" stroke="#6B6B6B" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" />
          </svg>
        </button>
      </div>
    <% end %>

    <%# ── Calendar grid: 85px rows, 0 column-gap so phase bands merge ── %>
    <div style="display:grid; grid-template-columns:repeat(7,1fr); grid-auto-rows:85px; gap:8px 0;">

      <%# Leading blank cells so day 1 lands on the right weekday (Mon=0) %>
      <% first_weekday = @date.beginning_of_month.wday == 0 ? 6 : @date.beginning_of_month.wday - 1 %>
      <% first_weekday.times { concat(tag.div) } %>

      <%# Day cells — all data lookups are O(1) via pre-built hashes/sets %>
      <% (@date.beginning_of_month..@date.end_of_month).each do |date| %>
        <%= render "calendar/day_cell",
              date:             date,
              current_month:    @month,
              events_by_date:   @events_by_date,
              tracked_days_set: @tracked_days_set,
              cycle_by_date:    @cycle_by_date,
              mode:             @mode %>
      <% end %>
    </div>

  </div>
</div>

<%# Season Info Modal %>
<%
  phase = @current_phase
  season = @current_season || CycleCalculatorService::SEASON_NAMES[phase]
  cycle_day = current_user.streak&.current_streak

  season_info = case season
  when "Winter"
    { title: "Winter", colour: "#933a35", emoji: "❄️",
      description: "This is your menstruation phase — a time for rest and reflection.",
      tips: ["Rest and prioritize sleep", "Gentle movement like yoga", "Stay hydrated"] }
  when "Spring"
    { title: "Spring", colour: "#D18D83", emoji: "🌸",
      description: "You're in the follicular phase — energy and creativity are rising!",
      tips: ["Start new projects", "High energy workouts", "Social activities"] }
  when "Summer"
    { title: "Summer", colour: "#F5C6AD", emoji: "☀️",
      description: "You're ovulating — peak energy and confidence!",
      tips: ["Network and collaborate", "Creative brainstorming", "Focus on relationships"] }
  when "Autumn"
    { title: "Autumn", colour: "#EDE1D5", emoji: "🍂",
      description: "You're in the luteal phase — time for introspection and planning.",
      tips: ["Organize and plan", "Self-care routines", "Reflect on goals"] }
  else
    { title: "Your Cycle", colour: "#933a35", emoji: "🌙",
      description: "Track your cycle to see your phase.",
      tips: [] }
  end
%>

<div id="season-info-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:100; align-items:center; justify-content:center;">
  <div style="background:#FAF7F4; border-radius:16px; padding:24px; width:90%; max-width:340px; margin:16px;">
    <div style="text-align:center; margin-bottom:16px;">
      <div style="width:60px; height:60px; border-radius:50%; background:<%= season_info[:colour] %>; display:inline-flex; align-items:center; justify-content:center; font-size:28px; margin-bottom:12px;">
        <%= season_info[:emoji] %>
      </div>
      <h3 style="color:#933a35; font-size:20px; font-weight:600; margin:0;"><%= season_info[:title] %></h3>
      <p style="color:#D18D83; font-size:14px; margin:4px 0 0;">You're in <%= season_info[:title].downcase %> phase</p>
    </div>

    <p style="color:#933a35; font-size:14px; line-height:1.5; margin:0 0 16px; text-align:center;">
      <%= season_info[:description] %>
    </p>

    <% if season_info[:tips].any? %>
      <div style="background:#FFFFFF; border-radius:12px; padding:12px; margin-bottom:16px;">
        <p style="color:#933a35; font-size:12px; font-weight:600; margin:0 0 8px;">Tips for this phase</p>
        <ul style="margin:0; padding-left:16px;">
          <% season_info[:tips].each do |tip| %>
            <li style="color:#6B6B6B; font-size:13px; margin-bottom:4px;"><%= tip %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <button onclick="document.getElementById('season-info-modal').style.display='none'"
            style="width:100%; background:#933a35; color:white; border:none; border-radius:12px; padding:14px; font-size:16px; font-weight:500; cursor:pointer;">
      Got it
    </button>
  </div>
</div>
