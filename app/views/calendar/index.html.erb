<% content_for(:page_title) { @date.strftime("%B") } %>
<% content_for(:header_left) do %>
  <button class="p-2" data-action="click->menu#open">
    <svg class="w-6 h-6 text-brand-primary" viewBox="0 0 24 24" fill="currentColor">
      <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" />
    </svg>
  </button>
<% end %>
<% content_for(:header_center_dropdown) do %>
  <div class="relative" id="view-dropdown" data-controller="calendar-index">
    <button type="button" class="p-1" data-action="click->calendar-index#toggleDropdown">
      <svg class="w-5 h-5 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </button>
    <div class="absolute left-0 top-full mt-1 w-40 bg-white rounded-lg shadow-lg hidden z-50"
         id="view-dropdown-menu">
      <%= link_to "Day View", daily_view_path(Time.zone.today), class: "block px-4 py-2 text-sm text-brand-primary hover:bg-brand-field", data: { turbo_action: "replace" } %>
      <%= link_to "Week View", calendar_weekly_path, class: "block px-4 py-2 text-sm text-brand-primary hover:bg-brand-field", data: { turbo_action: "replace" } %>
      <%= link_to "Month View", user_root_path, class: "block px-4 py-2 text-sm text-brand-primary hover:bg-brand-field", data: { turbo_action: "replace" } %>
    </div>
  </div>
<% end %>
<% content_for(:header_right) do %>
  <div class="flex items-center gap-3">
    <%= link_to informations_path do %>
      <svg class="w-6 h-6 text-brand-primary" viewBox="0 0 25 25" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.4998 22.9168C18.2289 22.9168 22.9164 18.2293 22.9164 12.5001C22.9164 6.77094 18.2289 2.08344 12.4998 2.08344C6.7706 2.08344 2.0831 6.77094 2.0831 12.5001C2.0831 18.2293 6.7706 22.9168 12.4998 22.9168Z" />
        <path d="M12.4998 8.33344V13.5418" stroke-width="1.7" />
        <path d="M12.4957 16.6667H12.5051" stroke-width="2" />
      </svg>
    <% end %>
  </div>
<% end %>

<%# ── No-cycle banner (shown when user has no period data) ── %>
<% if current_user.onboarding_completed? && current_user.last_period_start.nil? %>
  <div class="bg-brand-error px-4 py-3 text-center border-b border-brand-primary">
    <p class="text-brand-primary text-sm mb-2">
      We haven't received your period data yet. Add your last period start date to see your cycle phases.
    </p>
    <a href="/tracking/period"
       class="inline-block bg-brand-primary text-white rounded-full px-4 py-2 text-sm font-semibold">
      Log period start
    </a>
  </div>
<% end %>

<div class="bg-brand-background min-h-screen pb-20">
  <div class="max-w-app mx-auto px-4 pt-3">

    <%# ── Greeting ── %>
    <div class="mb-3.5">
      <p class="text-brand-primary text-4xl font-medium m-0 mb-0.5 leading-tight font-montserrat">
        Hello <%= current_user.first_name || "there" %>
      </p>
      <p class="text-brand-primary text-2xl font-light m-0 leading-snug font-montserrat">
        <% if @current_season %>You are in <%= @current_season %><% else %>This is your month<% end %>
      </p>
    </div>

    <%# ── Streak ── %>
    <% if @streak > 0 %>
      <div class="flex items-center gap-2 bg-white px-3 py-2.5 rounded-lg mb-3.5">
        <span class="text-lg">🔥</span>
        <span class="text-brand-primary text-sm font-medium"><%= @streak %> day streak</span>
      </div>
    <% end %>

    <%# ── Filter chips (no JS — plain GET links) ── %>
    <div class="flex gap-2 flex-wrap mb-4">
      <% [["all", "All"], ["events", "Events"], ["tracking", "Tracked"], ["cycle", "Cycle"]].each do |value, label| %>
        <% active = @mode == value %>
        <%= link_to label,
              user_root_path(date: @date.to_s, mode: value),
              class: "px-3.5 py-1.5 rounded-full text-xs font-semibold no-underline " +
                     (active ? "bg-brand-primary text-white" : "bg-white text-brand-primary border border-brand-primary") %>
      <% end %>
    </div>

    <%# ── Day-of-week headers ── %>
    <div class="grid grid-cols-7 gap-0 mb-1.5">
      <% %w[Mo Tu We Th Fr Sa Su].each do |d| %>
        <div class="text-center text-brand-secondary text-xs font-semibold tracking-wider py-1">
          <%= d %>
        </div>
      <% end %>
    </div>

    <%# ── Phase Legend ── %>
    <% if @cycle_by_date.present? %>
      <div class="flex gap-3 justify-center flex-wrap mb-3">
        <% [["Menstrual", "#933a35"], ["Follicular", "#D18D83"], ["Ovulation", "#F5C6AD"], ["Luteal", "#EDE1D5"]].each do |label, color| %>
          <div class="flex items-center gap-1">
            <span class="w-2.5 h-2.5 rounded-full" style="background: <%= color %>;"></span>
            <span class="text-xs text-brand-secondary"><%= label %></span>
          </div>
        <% end %>
        <button class="bg-none border-none cursor-pointer px-1"
                onclick="openSeasonModal()"
                aria-label="Learn about your current phase">
          <svg class="w-4 h-4 text-brand-secondary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" />
          </svg>
        </button>
      </div>
    <% end %>

    <%# ── Calendar grid: 85px rows, 0 column-gap so phase bands merge ── %>
    <div class="grid grid-cols-7 auto-rows-calendar gap-x-0 gap-y-2">

      <%# Leading blank cells so day 1 lands on the right weekday (Mon=0) %>
      <% first_weekday = @date.beginning_of_month.wday == 0 ? 6 : @date.beginning_of_month.wday - 1 %>
      <% first_weekday.times { concat(tag.div) } %>

      <%# Day cells — all data lookups are O(1) via pre-built hashes/sets %>
      <% (@date.beginning_of_month..@date.end_of_month).each do |date| %>
        <%= render "calendar/day_cell",
              date:             date,
              current_month:    @month,
              events_by_date:   @events_by_date,
              tracked_days_set: @tracked_days_set,
              cycle_by_date:    @cycle_by_date,
              mode:             @mode %>
      <% end %>
    </div>

  </div>
</div>

<%# Season Info Modal %>
<%
  phase = @current_phase
  season = @current_season || CycleCalculatorService::SEASON_NAMES[phase]
  cycle_day = current_user.streak&.current_streak

  season_info = case season
  when "Winter"
    { title: "Winter", colour: "#933a35", emoji: "❄️",
      description: "This is your menstruation phase — a time for rest and reflection.",
      tips: ["Rest and prioritize sleep", "Gentle movement like yoga", "Stay hydrated"] }
  when "Spring"
    { title: "Spring", colour: "#D18D83", emoji: "🌸",
      description: "You're in the follicular phase — energy and creativity are rising!",
      tips: ["Start new projects", "High energy workouts", "Social activities"] }
  when "Summer"
    { title: "Summer", colour: "#F5C6AD", emoji: "☀️",
      description: "You're ovulating — peak energy and confidence!",
      tips: ["Network and collaborate", "Creative brainstorming", "Focus on relationships"] }
  when "Autumn"
    { title: "Autumn", colour: "#EDE1D5", emoji: "🍂",
      description: "You're in the luteal phase — time for introspection and planning.",
      tips: ["Organize and plan", "Self-care routines", "Reflect on goals"] }
  else
    { title: "Your Cycle", colour: "#933a35", emoji: "🌙",
      description: "Track your cycle to see your phase.",
      tips: [] }
  end
%>

<%= render "shared/modal_backdrop", id: "season-info-backdrop" %>

<div id="season-info-modal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="season-modal-title"
     class="fixed inset-0 z-50 flex items-center justify-center hidden">
  <div class="bg-brand-background rounded-2xl p-6 w-11/12 max-w-sm">
    <div class="text-center mb-4">
      <div class="w-16 h-16 rounded-full inline-flex items-center justify-center text-2xl mb-3" style="background: <%= season_info[:colour] %>;">
        <span aria-label="<%= season_info[:title].downcase %> phase emoji"><%= season_info[:emoji] %></span>
      </div>
      <h2 id="season-modal-title" class="text-brand-primary text-xl font-semibold m-0"><%= season_info[:title] %></h2>
      <p class="text-brand-secondary text-sm mt-1 mb-0">You're in <%= season_info[:title].downcase %> phase</p>
    </div>

    <p class="text-brand-primary text-sm leading-relaxed m-0 mb-4 text-center">
      <%= season_info[:description] %>
    </p>

    <% if season_info[:tips].any? %>
      <div class="bg-white rounded-lg p-3 mb-4">
        <p class="text-brand-primary text-xs font-semibold m-0 mb-2">Tips for this phase</p>
        <ul class="m-0 pl-4">
          <% season_info[:tips].each do |tip| %>
            <li class="text-brand-secondary text-xs mb-1"><%= tip %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <button id="season-modal-close"
            onclick="closeSeasonModal()"
            class="w-full bg-brand-primary text-white border-none rounded-lg px-4 py-3.5 text-base font-medium cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary">
      Got it
    </button>
  </div>
</div>

<script>
function closeSeasonModal() {
  const modal = document.getElementById('season-info-modal');
  const backdrop = document.getElementById('season-info-backdrop');
  modal.classList.add('hidden');
  backdrop.classList.add('hidden');
}

function openSeasonModal() {
  const modal = document.getElementById('season-info-modal');
  const backdrop = document.getElementById('season-info-backdrop');
  modal.classList.remove('hidden');
  backdrop.classList.remove('hidden');
  // Focus trap: set initial focus to close button
  setTimeout(() => document.getElementById('season-modal-close').focus(), 0);
}

// Close modal with Escape key
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && !document.getElementById('season-info-modal').classList.contains('hidden')) {
    closeSeasonModal();
  }
});

// Close modal by clicking backdrop
document.getElementById('season-info-backdrop')?.addEventListener('click', closeSeasonModal);
</script>
