<% content_for(:page_title) { "Week" } %>
<% content_for(:header_right) do %>
  <div class="flex items-center gap-2">
    <div class="flex items-center gap-1">
      <%= link_to calendar_weekly_path(date: @prev_week.to_s),
            aria: { label: "Previous week" },
            class: "w-10 h-10 flex items-center justify-center text-brand-primary" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polyline points="15 18 9 12 15 6" /></svg>
      <% end %>
      <span class="text-brand-primary text-sm font-medium px-2"><%= @week_start.strftime("%b %d") %> - <%= @week_end.strftime("%b %d") %></span>
      <%= link_to calendar_weekly_path(date: @next_week.to_s),
            aria: { label: "Next week" },
            class: "w-10 h-10 flex items-center justify-center text-brand-primary" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6" /></svg>
      <% end %>
    </div>
    <%= link_to informations_path do %>
      <svg class="w-6 h-6 text-brand-primary" viewBox="0 0 25 25" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.4998 22.9168C18.2289 22.9168 22.9164 18.2293 22.9164 12.5001C22.9164 6.77094 18.2289 2.08344 12.4998 2.08344C6.7706 2.08344 2.0831 6.77094 2.0831 12.5001C2.0831 18.2293 6.7706 22.9168 12.4998 22.9168Z" />
        <path d="M12.4998 8.33344V13.5418" stroke-width="1.7" />
        <path d="M12.4957 16.6667H12.5051" stroke-width="2" />
      </svg>
    <% end %>
  </div>
<% end %>

<%
  phase_colours = {
    "menstrual" => "#933a35",
    "follicular" => "#D18D83",
    "ovulation" => "#F5C6AD",
    "luteal" => "#EDE1D5"
  }
  hour_px = 48
  timeline_hours = (6..22).to_a
%>

<div class="bg-brand-background min-h-screen pb-20">
  <div class="max-w-app mx-auto">

    <%# ── Week header ── %>
    <div class="grid grid-cols-7 gap-0 px-2 py-3 pb-2 border-b border-brand-field bg-white">
      <% week_days = %w[Mo Tu We Th Fr Sa Su] %>
      <% @week_dates.each_with_index do |day, i| %>
        <% is_today = day == Time.zone.today %>
        <% phase = @cycle_by_date[day]&.dig(:phase) %>
        <% colour = phase_colours[phase] || "#933a35" %>
        <% is_weekend = i >= 5 %>
        <div class="text-center">
          <div class="text-xs text-brand-secondary font-medium mb-1"><%= week_days[i] %></div>
          <% if is_today %>
            <div class="w-7 h-7 rounded-full inline-flex items-center justify-center text-white text-sm font-bold" style="background: <%= colour %>;">
              <%= day.day %>
            </div>
          <% else %>
            <div class="text-sm font-medium" style="color: <%= is_weekend ? '#D18D83' : '#933a35' %>;">
              <%= day.day %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# ── Week legend ── %>
    <% if current_user.last_period_start %>
      <div class="px-4 py-2 flex gap-3 justify-center flex-wrap">
        <% phase_colours.each do |phase, colour| %>
          <div class="flex items-center gap-1">
            <span class="w-2 h-2 rounded-full" style="background: <%= colour %>;"></span>
            <span class="text-xs text-brand-secondary capitalize"><%= phase %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Timeline grid ── %>
    <div class="relative overflow-y-auto" style="max-height: 60vh;">
      <div style="display:grid; grid-template-columns:40px 1fr; gap:0;">

        <%# Time column %>
        <div class="border-r border-brand-field">
          <% timeline_hours.each do |hour| %>
            <div class="border-b" style="height: <%= hour_px %>px; border-color: #F5EDE8;">
              <span class="text-xs text-brand-secondary block px-1 py-0.5">
                <%= format("%02d:00", hour) %>
              </span>
            </div>
          <% end %>
        </div>

        <%# Days columns %>
        <div style="display:grid; grid-template-columns:repeat(7,1fr);">
          <% @week_dates.each_with_index do |day, day_idx| %>
            <% phase = @cycle_by_date[day]&.dig(:phase) %>
            <% colour = phase_colours[phase] || "#FAF7F4" %>
            <% events = @events_by_date[day] || [] %>
            <% is_weekend = day_idx >= 5 %>

            <div class="relative" style="border-right: <%= is_weekend ? '2px' : '1px' %> solid <%= is_weekend ? '#F5C6AD' : '#EDE1D5' %>;">
              <%# Hour grid lines %>
              <% timeline_hours.each do |hour| %>
                <div class="border-b" style="height: <%= hour_px %>px; border-color: #F5EDE8;"></div>
              <% end %>

              <%# Phase background band (24h) %>
              <div class="absolute inset-0 pointer-events-none" style="background: <%= colour %>; opacity: 0.15;"></div>

              <%# Events positioned on timeline %>
              <% events.each do |event| %>
                <% start_hour = event.start_time&.hour || 9 %>
                <% end_hour = event.end_time&.hour || 10 %>
                <% top_px = (start_hour - 6) * hour_px + (event.start_time&.min || 0) * hour_px / 60 %>
                <% height_px = [(end_hour - start_hour) * hour_px, hour_px].max %>
                <%= link_to calendar_event_path(event),
                      class: "absolute block overflow-hidden rounded text-xs text-brand-primary no-underline shadow-sm",
                      style: "left: 2px; right: 2px; top: #{top_px}px; height: #{height_px}px; background: #FFFFFF; border-left: 3px solid #{colour}; padding: 1rem 0.375rem;" do %>
                  <span class="font-bold block overflow-hidden text-ellipsis whitespace-nowrap">
                    <%= event.title %>
                  </span>
                  <% if event.start_time %>
                    <span class="text-xs text-brand-secondary block">
                      <%= event.start_time.strftime("%H:%M") %>
                    </span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
