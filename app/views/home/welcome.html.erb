<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:space-between; padding:60px 32px 48px; max-width:430px; margin:0 auto;">

  <!-- Logo centered upper half -->
  <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;">
    <%= image_tag "screen1logo.png",
        class: "w-[234px] h-[255px] object-contain",
        alt: "Season" %>
    <%= image_tag "Season-Wortmarke 1.svg",
        style: "width:280px; height:auto; display:block; margin:0 auto;",
        alt: "Season" %>
  </div>

  <!-- Text and buttons lower half -->
  <div style="width:100%; text-align:center;">
    <p style="color:#933a35; font-size:16px; font-weight:400; margin-bottom:6px;">
      <%= t('home.welcome_title', default: 'Welcome to Season!') %>
    </p>
    <p style="color:#933a35; font-size:14px; font-weight:300; margin-bottom:40px; line-height:1.5;">
      <%= t('home.welcome_subtitle', default: 'Maximize your productivity with the help of your cycle.') %>
    </p>

    <%= link_to t('home.lets_go', default: 'Lets go'),
        new_user_registration_path,
        style: "display:block; background:#933a35; color:#ffffff; text-align:center; padding:18px; border-radius:8px; font-weight:500; font-size:16px; text-decoration:none; margin-bottom:20px;" %>

    <%= link_to t('home.have_account', default: 'I already have an account'),
        new_user_session_path,
        style: "display:block; color:#933a35; text-align:center; font-weight:500; font-size:15px; text-decoration:none;" %>
  </div>

</div>
