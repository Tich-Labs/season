<div class="text-center mb-6">
  <p class="text-gray-500 text-sm uppercase tracking-wide">Today</p>
  <h2 class="font-serif text-4xl text-season-charcoal"><%= Date.today.strftime("%B %d") %></h2>
</div>

<div class="bg-white rounded-3xl p-6 shadow-sm mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="font-serif text-xl text-season-charcoal">Cycle Day <%= @cycle_day || "--" %></h3>
    <span class="text-sm text-gray-500"><%= current_user.cycle_length || 28 %> day cycle</span>
  </div>
  
  <% if @period_start %>
    <div class="bg-season-terra/10 rounded-2xl p-4 text-center mb-4">
      <p class="text-season-terra font-medium">Your period is here</p>
      <p class="text-sm text-gray-500">Take it easy today</p>
    </div>
  <% else %>
    <div class="text-center py-4">
      <p class="text-2xl font-semibold text-season-terra"><%= @days_until_period %></p>
      <p class="text-sm text-gray-500">days until your next period</p>
    </div>
  <% end %>
  
  <div class="flex justify-center">
    <div class="w-32 h-32 rounded-full border-4 border-season-terra flex items-center justify-center">
      <div class="text-center">
        <span class="text-3xl font-bold text-season-terra"><%= @cycle_day || "--" %></span>
        <span class="text-xs text-gray-500 block">of <%= current_user.cycle_length || 28 %></span>
      </div>
    </div>
  </div>
</div>

<div class="bg-white rounded-3xl shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
    <h3 class="font-serif text-lg text-season-charcoal"><%= @start_date.strftime("%B %Y") %></h3>
    <div class="flex gap-2">
      <%= link_to "?month=#{[@calendar_month - 1, 1].max}&year=#{@calendar_month == 1 ? @calendar_year - 1 : @calendar_year}", class: "p-2 text-gray-400 hover:text-season-terra" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      <% end %>
      <%= link_to "?month=#{[@calendar_month + 1, 12].min}&year=#{@calendar_month == 12 ? @calendar_year + 1 : @calendar_year}", class: "p-2 text-gray-400 hover:text-season-terra" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      <% end %>
    </div>
  </div>
  
  <div class="px-4 pb-4">
    <div class="grid grid-cols-7 gap-1 text-center mb-2">
      <% %w[S M T W T F S].each do |day| %>
        <div class="text-xs text-gray-400 py-2"><%= day %></div>
      <% end %>
    </div>
    
    <div class="grid grid-cols-7 gap-1">
      <% @first_day_of_week.times do %>
        <div></div>
      <% end %>
      
      <% (1..@days_in_month).each do |day| %>
        <% date = Date.new(@calendar_year, @calendar_month, day) %>
        <% is_today = date == Date.today %>
        <% is_period_day = @period_days&.include?(day) %>
        
        <div class="aspect-square flex items-center justify-center relative">
          <div class="w-10 h-10 rounded-full flex items-center justify-center <%= is_today ? 'bg-season-terra text-white' : '' %> <%= is_period_day && !is_today ? 'bg-season-terra/20 text-season-terra' : '' %>">
            <span class="<%= is_today ? 'font-bold' : '' %>"><%= day %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="mt-6 flex justify-center gap-6">
  <div class="flex items-center gap-2">
    <div class="w-3 h-3 rounded-full bg-season-terra"></div>
    <span class="text-sm text-gray-500">Period</span>
  </div>
  <div class="flex items-center gap-2">
    <div class="w-3 h-3 rounded-full bg-season-terra/30"></div>
    <span class="text-sm text-gray-500">Fertile</span>
  </div>
</div>
