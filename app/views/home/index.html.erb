<div class="bg-white">
    <div class="px-6 py-16 lg:px-8 lg:py-24">
        <div class="mx-auto max-w-2xl text-center">
            <%= image_tag "screen1logo.png", alt: "Season", class: "mx-auto h-6 w-auto sm:h-10" %>
            <%= image_tag "Season-Wortmarke 1.svg", alt: "Season", class: "mx-auto h-6 w-auto sm:h-10 mt-4" %>
            <p class="mt-8 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8">Track your cycle, understand your power</p>
            <% if authenticated? %>
            <p class="mt-8 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8">Current user: <%= current_user.id %></p>
            <% end %>
            <div class="mt-10 flex items-center justify-center">
                <div class="text-center" id="countdown">
                    <div class="flex gap-20 justify-center items-baseline">
                        <div class="flex flex-col items-center px-6">
                            <span class="text-8xl font-light" style="color: #5a2423;" id="days">0</span>
                            <span class="text-sm mt-6 font-medium" style="color: #333333;">Days</span>
                        </div>
                        <span class="text-6xl font-light" style="color: #333333;">:</span>
                        <div class="flex flex-col items-center px-6">
                            <span class="text-8xl font-light" style="color: #5a2423;" id="hours">0</span>
                            <span class="text-sm mt-6 font-medium" style="color: #333333;">Hours</span>
                        </div>
                        <span class="text-6xl font-light" style="color: #333333;">:</span>
                        <div class="flex flex-col items-center px-6">
                            <span class="text-8xl font-light" style="color: #5a2423;" id="minutes">0</span>
                            <span class="text-sm mt-6 font-medium" style="color: #333333;">Mins</span>
                        </div>
                        <span class="text-6xl font-light" style="color: #333333;">:</span>
                        <div class="flex flex-col items-center px-6">
                            <span class="text-8xl font-light" style="color: #5a2423;" id="seconds">0</span>
                            <span class="text-sm mt-6 font-medium" style="color: #333333;">Secs</span>
                        </div>
                    </div>
                </div>
            </div>
            <script>
                function updateCountdown() {
                    // Set target date (e.g., end of month or specific launch date)
                    const targetDate = new Date("2026-04-30T00:00:00").getTime();
                    const now = new Date().getTime();
                    const distance = targetDate - now;

                    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    document.getElementById("days").textContent = String(days).padStart(2, '0');
                    document.getElementById("hours").textContent = String(hours).padStart(2, '0');
                    document.getElementById("minutes").textContent = String(minutes).padStart(2, '0');
                    document.getElementById("seconds").textContent = String(seconds).padStart(2, '0');

                    if (distance < 0) {
                        document.getElementById("countdown").innerHTML = "<p class='text-lg' style='color: #50715c;'>Coming soon</p>";
                    }
                }
                updateCountdown();
                setInterval(updateCountdown, 1000);
            </script>
        </div>
    </div>
</div>
