<div class="min-h-screen bg-white flex flex-col items-center justify-between px-8 py-12">
  <!-- Logo & Content Section -->
  <div class="flex-1 flex flex-col items-center justify-center w-full">
    <!-- Element Image (above logo) -->
    <div class="mb-8">
      <img 
        src="<%= image_path('Element 1 2.svg') rescue image_path('screen1logo.png') %>" 
        alt="Season element"
        class="w-48 h-auto object-contain"
      >
    </div>
    
    <!-- Season Logo -->
    <img 
      src="<%= image_path('Season-Wortmarke 1.svg') %>" 
      alt="<%= t('home.logo_alt') %>"
      class="h-60 object-contain mb-12"
    >
    
    <!-- Heading -->
    <h1 class="text-2xl font-medium text-[#933a35] text-center">
      <%= t('home.welcome_title') %>
    </h1>
    
    <!-- Subtitle -->
    <p class="text-base text-[#933a35] text-center mt-3 px-6 leading-relaxed">
      <%= t('home.welcome_subtitle') %>
    </p>
  </div>

  <!-- Button Section (bottom) -->
  <div class="w-full space-y-4 pb-4">
    <!-- CTA Button -->
    <%= link_to t('home.lets_go'), new_user_registration_path, 
        class: "w-full bg-[#933a35] text-white rounded-lg min-h-[52px] font-medium flex items-center justify-center text-center no-underline text-xl" %>
    
    <!-- Sign In Link -->
    <%= link_to t('home.have_account'), new_user_session_path,
        class: "text-[#933a35] font-medium text-center block mt-4 text-xl" %>
  </div>
</div>

