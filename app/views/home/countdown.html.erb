<%# Season V2 countdown page — public, no auth required.
    Uses launch layout (no app bar / burger menu).
    Spacing mirrors welcome.html.erb: max-width 430px, padding 60px 32px 48px.
    Countdown Stimulus controller: data-countdown-target-date-value %>

<div style="background:#FAF7F4; min-height:100vh; display:flex; flex-direction:column; align-items:center; padding:48px 32px 48px; max-width:430px; margin:0 auto;">

  <%# ── Logo block — larger, more prominent ── %>
    <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;">
    <%= image_tag "screen1logo.png",
        class: "w-[234px] h-[255px] object-contain",
        alt: "Season" %>
    <%= image_tag "Season-Wortmarke 1.svg",
        style: "width:280px; height:auto; display:block; margin:0 auto;",
        alt: "Season" %>
  </div>

  <%# ── Install / CTA Button ── %>
  <div data-controller="install" style="width:100%; display:flex; flex-direction:column; align-items:center; margin-bottom:28px;">
    <button type="button"
            data-install-target="button"
            data-action="click->install#install"
            style="display:block; width:100%; max-width:280px; padding:16px 24px; background:#933a35; color:#FFFFFF; font-size:16px; font-weight:600; text-align:center; border:none; border-radius:12px; box-shadow:0 4px 12px rgba(147,58,53,0.25); cursor:pointer;">
      Experience Season V2
    </button>

    <%# iOS manual install hint — hidden until button tapped ── %>
    <div data-install-target="iosHint"
         style="display:none; margin-top:16px; background:#FFFFFF; border-radius:12px; padding:16px 20px; max-width:280px; box-shadow:0 2px 16px rgba(147,58,53,0.10); text-align:center;">
      <p style="color:#933a35; font-size:14px; font-weight:600; margin:0 0 8px;">Add Season to your Home Screen</p>
      <p style="color:#6B6B6B; font-size:13px; line-height:1.5; margin:0;">
        Tap <strong>Share</strong> <span style="font-size:16px;">⬆</span> at the bottom of Safari,
        then choose <strong>"Add to Home Screen"</strong>.
      </p>
    </div>
  </div>

  <%# ── Phase dots ── %>
  <div style="display:flex; align-items:center; gap:8px; margin-bottom:32px;">
    <span style="width:10px; height:10px; border-radius:50%; background:#933a35; display:inline-block;"></span>
    <span style="width:10px; height:10px; border-radius:50%; background:#D18D83; display:inline-block;"></span>
    <span style="width:10px; height:10px; border-radius:50%; background:#F5C6AD; display:inline-block;"></span>
    <span style="width:10px; height:10px; border-radius:50%; background:#EDE1D5; display:inline-block;"></span>
  </div>

  <%# ── Hero headline ── %>
  <div style="text-align:center; margin-bottom:32px;">
    <h1 style="color:#933a35; font-size:24px; font-weight:700; line-height:1.3; margin:0 0 10px;">
      Season V2 is almost here.
    </h1>
    <p style="color:#6B6B6B; font-size:14px; font-weight:400; line-height:1.6; margin:0;">
      We heard you. Smart reminders, a polished calendar,
      and your Superpower — all reimagined.
    </p>
  </div>

  <%# ── Countdown timer ── %>
  <div style="background:#FFFFFF; border-radius:16px; padding:24px 20px; width:100%; display:flex; justify-content:center; gap:12px; box-shadow:0 2px 20px rgba(147,58,53,0.08); margin-bottom:10px;"
       data-controller="countdown"
       data-countdown-target-date-value="2026-04-14T00:00:00+02:00">
    <% [["days", "Days"], ["hours", "Hours"], ["minutes", "Min"], ["seconds", "Sec"]].each do |target, label| %>
      <div style="display:flex; flex-direction:column; align-items:center; width:64px;">
        <div style="width:64px; height:64px; border-radius:12px; background:#F5EDE8; color:#933a35; display:flex; align-items:center; justify-content:center; font-size:28px; font-weight:900; font-variant-numeric:tabular-nums;"
             data-countdown-target="<%= target %>">00</div>
        <span style="margin-top:6px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#6B6B6B;"><%= label %></span>
      </div>
    <% end %>
  </div>
  <p style="color:#D18D83; font-size:13px; font-weight:500; margin:0 0 36px; text-align:center;">Launching April 14, 2026</p>

  <%# ── Feature preview cards ── %>
  <div style="width:100%; margin-bottom:8px;">
    <p style="color:#933a35; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 16px;">What's new in V2</p>

    <%# Calendar %>
    <div style="background:#FFFFFF; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; box-shadow:0 1px 8px rgba(147,58,53,0.06); margin-bottom:10px;">
      <div style="width:44px; height:44px; border-radius:10px; background:#F5EDE8; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <div>
        <p style="color:#933a35; font-size:15px; font-weight:600; margin:0 0 4px;">Calendar</p>
        <p style="color:#6B6B6B; font-size:13px; font-weight:400; line-height:1.5; margin:0;">Your cycle, your appointments — always one glance ahead.</p>
      </div>
    </div>

    <%# Forecast %>
    <div style="background:#FFFFFF; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; box-shadow:0 1px 8px rgba(147,58,53,0.06); margin-bottom:10px;">
      <div style="width:44px; height:44px; border-radius:10px; background:#F5EDE8; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </div>
      <div>
        <p style="color:#933a35; font-size:15px; font-weight:600; margin:0 0 4px;">Forecast</p>
        <p style="color:#6B6B6B; font-size:13px; font-weight:400; line-height:1.5; margin:0;">Know how you'll feel — physically and emotionally — before the day begins.</p>
      </div>
    </div>

    <%# Smart Reminders — highlighted card %>
    <div style="background:#933a35; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; position:relative; overflow:hidden; margin-bottom:0;">
      <div style="position:absolute; top:10px; right:12px;">
        <span style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; background:rgba(255,255,255,0.2); color:#fff; padding:2px 8px; border-radius:20px;">New</span>
      </div>
      <div style="width:44px; height:44px; border-radius:10px; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
      </div>
      <div>
        <p style="color:#FFFFFF; font-size:15px; font-weight:600; margin:0 0 4px;">Smart Reminders</p>
        <p style="color:rgba(255,255,255,0.85); font-size:13px; font-weight:400; line-height:1.5; margin:0;">Pill, supplement &amp; cycle reminders — timed to your phase.</p>
      </div>
    </div>
  </div>

  <%# ── What happens next ── %>
  <div style="background:#FFFFFF; border-radius:12px; padding:20px; width:100%; box-shadow:0 1px 8px rgba(147,58,53,0.06); margin-top:24px;">
    <p style="color:#933a35; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 16px;">What happens next</p>
    <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:14px;">
      <li style="display:flex; align-items:flex-start; gap:12px;">
        <span style="width:22px; height:22px; border-radius:50%; background:#F5EDE8; color:#933a35; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px;">1</span>
        <p style="color:#6B6B6B; font-size:13px; line-height:1.5; margin:0;"><strong style="color:#933a35;">Season V2 goes live April 14</strong> — Smart reminders, polished calendar &amp; your Superpower.</p>
      </li>
      <li style="display:flex; align-items:flex-start; gap:12px;">
        <span style="width:22px; height:22px; border-radius:50%; background:#F5EDE8; color:#933a35; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px;">2</span>
        <p style="color:#6B6B6B; font-size:13px; line-height:1.5; margin:0;"><strong style="color:#933a35;">UI polish</strong> — Tracking and calendar screens aligned with your feedback.</p>
      </li>
      <li style="display:flex; align-items:flex-start; gap:12px;">
        <span style="width:22px; height:22px; border-radius:50%; background:#F5EDE8; color:#933a35; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px;">3</span>
        <p style="color:#6B6B6B; font-size:13px; line-height:1.5; margin:0;"><strong style="color:#933a35;">Check your inbox</strong> — A personal invite link to the improved app is on its way.</p>
      </li>
    </ul>
  </div>

  <%# ── Support footer ── %>
  <div style="margin-top:40px; text-align:center;">
    <p style="color:#D18D83; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 6px;">Questions?</p>
    <a href="mailto:support@season.vision" style="color:#933a35; font-size:15px; font-weight:500; text-decoration:none;">support@season.vision</a>
  </div>

  <%# ── Phase dots footer ── %>
  <div style="display:flex; align-items:center; gap:6px; margin-top:32px;">
    <span style="width:6px; height:6px; border-radius:50%; background:#933a35; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#D18D83; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#F5C6AD; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#EDE1D5; display:inline-block;"></span>
  </div>

</div>
