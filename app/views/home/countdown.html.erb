<%# Season V2 countdown page — public, no auth required.
    Uses launch layout (no app bar / burger menu).
    Countdown Stimulus controller: data-countdown-target-date-value
    Launch signup form for email collection %>

<div style="background:#FAF7F4; min-height:100vh; display:flex; flex-direction:column; align-items:center; padding:48px 32px 48px; max-width:430px; margin:0 auto;">

  <%# ── Logo block — larger, more prominent ── %>
  <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;">
    <%= image_tag "screen1logo.png",
        class: "w-[234px] h-[255px] object-contain",
        alt: "Season" %>
    <%= image_tag "season-wortmarke-1.svg",
        style: "width:280px; height:auto; display:block; margin:0 auto;",
        alt: "Season" %>
  </div>

  <%# ── Feature slideshow — 7 slides, translateX carousel, phone frame SVG overlay ── %>
  <div class="w-full mb-5"
       data-controller="feature-slides"
       data-action="touchstart->feature-slides#touchStart touchend->feature-slides#touchEnd">

    <%# Card wrapper: padding + shadow + rounded corners. overflow-hidden clips slide bg to corners. %>
    <div class="bg-white rounded-xl overflow-hidden p-4" style="box-shadow:0 2px 16px rgba(147,58,53,0.10);">

      <%# Viewport: clips track to one slide width %>
      <div class="overflow-hidden rounded-xl">

        <%# Track: slides laid out horizontally %>
        <div class="flex will-change-transform" data-feature-slides-target="track">

<%# ── Slide 1: Introduction (no phone, mascot illustration) ── %>
          <div class="flex-shrink-0 bg-[#ede1d5] flex flex-col items-center px-6 py-8 min-h-[320px]">
            <%= image_tag "slides/intro-mascot.png",
                class: "w-28 h-28 object-contain mb-6",
                alt: "SEASON mascot" %>
            <div class="text-center flex-1 flex flex-col justify-center">
              <h2 class="font-['Montserrat'] font-semibold text-xl text-[#933a35] text-center mb-3 leading-tight">
                Find Your Superpower with SEASON
              </h2>
              <p class="font-['Montserrat'] text-sm text-[#933a35] text-center leading-relaxed mb-2 max-w-xs">
                Your cycle is more than your period. Design your everyday life in harmony with your hormonal cycle.
              </p>
              <p class="font-['Montserrat'] text-xs text-[#933a35] text-center font-semibold leading-relaxed max-w-xs">
                Plan, work, love and live according to your cycle.
              </p>
            </div>
          </div>

        <%# ── Phone slides 2–7: shared macro ── %>
        <%# Each uses real app screenshot inside the SVG phone frame overlay.
            Phone frame SVG has fill-rule:evenodd so the screen area is transparent.
            Screen offsets (% of 206×428 viewBox): left 3.4%, top 1.4%, w 93.2%, h 97.3%
            Border-radius scaled from Figma 41px on 206px → 38px on 190px -%>

        <% [
          {
            screen: "slides/screen-calendar.png",
            title: "The Calendar",
            body:  "Your home base. See your cycle, appointments and forecast — tap any day or add new events."
          },
          {
            screen: "slides/screen-cycle-colors.png",
            title: "Your Cycle Colors",
            body:  "Each color represents a cycle phase — Menstruation, Ovulation, Follicular, and Luteal."
          },
          {
            screen: "slides/screen-track-day.png",
            title: "Track Your Day",
            body:  "Log mood, energy, symptoms and superpowers. Feed the app data for the most accurate forecast."
          },
          {
            screen: "slides/screen-appointments.png",
            title: "Create Appointments",
            body:  "Tap + in the calendar to add appointments with icons and details. Sync your calendar in settings."
          },
          {
            screen: "slides/screen-forecast.png",
            title: "Your Forecast",
            body:  "Tap a day in your calendar then swipe left for a deep-dive forecast. Tap any tile for more detail."
          },
          {
            screen: "slides/screen-youre-set.png",
            title: "You're All Set!",
            body:  "Explore the app, track your cycle, and let us know what you think. Welcome to SEASON."
          }
        ].each do |slide| %>
          <div class="flex-shrink-0 bg-white flex flex-col items-center pt-8 pb-8 px-6">
            <%# Phone mockup: SVG frame overlays the screenshot %>
            <div class="relative mx-auto" style="width:190px; height:394px;">
              <%# App screenshot sits behind the frame %>
              <div class="absolute overflow-hidden"
                   style="left:3.4%; top:1.4%; width:93.2%; height:97.3%; border-radius:38px; background:#fff;">
                <%= image_tag slide[:screen],
                    class: "w-full h-full object-cover",
                    alt: slide[:title] %>
              </div>
              <%# Phone frame SVG on top (fill-rule:evenodd gives transparent screen cutout) %>
              <%= image_tag "slides/phone-frame.svg",
                  class: "absolute inset-0 w-full h-full pointer-events-none select-none",
                  alt: "" %>
            </div>
            <h2 class="font-['Montserrat'] font-semibold text-[22px] text-[#933a35] text-center mt-8 mb-2 leading-tight">
              <%= slide[:title] %>
            </h2>
            <p class="font-['Montserrat'] text-[15px] text-[#933a35] text-center leading-relaxed max-w-xs">
              <%= slide[:body] %>
            </p>
          </div>
        <% end %>

      </div><%# end track %>
      </div><%# end viewport (overflow-hidden, no padding) %>
    </div><%# end card wrapper (p-4, shadow) %>

    <%# Progress dots — #50715b, active = wide pill, inactive = small circle %>
    <div class="flex items-center justify-center gap-[10px] mt-4">
      <% 7.times do |i| %>
        <button type="button"
                data-feature-slides-target="dot"
                data-feature-slides-index="<%= i %>"
                data-action="click->feature-slides#goTo"
                class="h-3 rounded-full bg-[#50715b] transition-all duration-300 <%= i == 0 ? 'w-[52px]' : 'w-3 opacity-30' %>">
        </button>
      <% end %>
    </div>

  </div><%# end feature-slides %>

  <%# ── Notify Me Modal (hidden until button click) ── %>
  <div data-controller="launch-signup"
       id="notify-modal"
       style="display:none; position:fixed; inset:0; z-index:50; background:rgba(0,0,0,0.45); align-items:flex-end; justify-content:center; padding:0;"
       data-launch-signup-target="modal">
    <div style="background:#FAF7F4; border-radius:24px 24px 0 0; padding:32px 24px 40px; width:100%; max-width:430px; position:relative;">

      <%# Drag handle %>
      <div style="width:40px; height:4px; background:#D1C4C2; border-radius:2px; margin:0 auto 24px;"></div>

      <%# Close %>
      <button type="button"
              data-action="click->launch-signup#closeModal"
              style="position:absolute; top:20px; right:20px; background:none; border:none; color:#6B6B6B; font-size:20px; line-height:1; cursor:pointer; padding:4px 8px;"
              aria-label="Close">&times;</button>

      <%# Heading %>
      <h2 style="font-family:Montserrat,sans-serif; font-size:20px; font-weight:700; color:#933a35; margin:0 0 6px;">Get notified at launch</h2>
      <p style="font-family:Montserrat,sans-serif; font-size:14px; color:#6B6B6B; margin:0 0 24px; line-height:1.5;">We'll send you one email on April 14th — nothing else.</p>

      <%# Form — stacked %>
      <form action="/launch-signup" method="POST" data-launch-signup-target="form">
        <label for="notify-email" style="font-family:Montserrat,sans-serif; font-size:12px; font-weight:600; color:#933a35; text-transform:uppercase; letter-spacing:0.06em; display:block; margin-bottom:6px;">Email address</label>
        <input type="email"
               id="notify-email"
               name="email"
               placeholder="your@email.com"
               autocomplete="email"
               required
               style="width:100%; box-sizing:border-box; padding:14px 16px; background:#FFFFFF; border:1.5px solid #E8D8D6; border-radius:10px; font-size:15px; color:#333; outline:none; margin-bottom:14px;"
               data-launch-signup-target="email">
        <button type="submit"
                data-action="click->launch-signup#submit"
                style="width:100%; padding:15px; background:#933a35; color:#FFFFFF; border:none; border-radius:10px; font-family:Montserrat,sans-serif; font-size:15px; font-weight:700; cursor:pointer; letter-spacing:0.02em;">
          Notify Me
        </button>
      </form>

      <div data-launch-signup-target="success" style="display:none; margin-top:16px; background:#F0F9F4; border-radius:10px; padding:14px 16px;">
        <p style="font-family:Montserrat,sans-serif; color:#50715b; font-size:14px; font-weight:600; margin:0;">&#10003; You're on the list! See you on April 14th.</p>
      </div>
      <div data-launch-signup-target="error" style="display:none; margin-top:12px; background:#FDF0EE; border-radius:10px; padding:12px 16px;">
        <p style="font-family:Montserrat,sans-serif; color:#933a35; font-size:13px; margin:0;" data-launch-signup-target="errorMessage"></p>
      </div>
    </div>
  </div>

  <%# ── Countdown timer ── %>
  <div style="background:#FFFFFF; border-radius:16px; padding:20px 16px; width:100%; display:flex; justify-content:center; gap:8px; box-shadow:0 2px 20px rgba(147,58,53,0.08); margin-bottom:10px;"
       data-controller="countdown"
       data-countdown-target-date-value="2026-04-19T00:00:00+02:00">
    <% [["days", "Days"], ["hours", "Hours"], ["minutes", "Min"], ["seconds", "Sec"]].each do |target, label| %>
      <div style="display:flex; flex-direction:column; align-items:center; width:60px;">
        <div style="width:56px; height:56px; border-radius:10px; background:#F5EDE8; color:#933a35; display:flex; align-items:center; justify-content:center; font-size:24px; font-weight:900; font-variant-numeric:tabular-nums;"
             data-countdown-target="<%= target %>">00</div>
        <span style="margin-top:4px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#6B6B6B;"><%= label %></span>
      </div>
    <% end %>
  </div>
  <p style="color:#D18D83; font-size:13px; font-weight:500; margin:0 0 20px; text-align:center;">Launching April 14, 2026</p>

  <%# ── Notify Me button ── %>
  <button type="button"
          onclick="const m=document.getElementById('notify-modal'); m.style.display='flex';"
          style="width:100%; background:#933a35; color:#FFFFFF; border:none; border-radius:12px; padding:14px 20px; font-size:15px; font-weight:600; font-family:Montserrat,sans-serif; cursor:pointer; margin-bottom:32px;">
    Get notified when we launch
  </button>

  <%# ── Feature preview cards ── %>
  <div style="width:100%; margin-bottom:8px;">
    <p style="color:#933a35; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 16px;">What's new in V2</p>

    <%# Calendar (not new - existing feature) %>
    <div style="background:#FFFFFF; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; box-shadow:0 1px 8px rgba(147,58,53,0.06); margin-bottom:10px;">
      <div style="width:44px; height:44px; border-radius:10px; background:#F5EDE8; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
        </svg>
      </div>
      <div>
        <p style="color:#933a35; font-size:15px; font-weight:600; margin:0 0 4px;">Calendar</p>
        <p style="color:#6B6B6B; font-size:13px; font-weight:400; line-height:1.5; margin:0;">Your cycle, appointments — always one glance ahead.</p>
      </div>
    </div>

    <%# Forecast %>
    <div style="background:#FFFFFF; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; box-shadow:0 1px 8px rgba(147,58,53,0.06); margin-bottom:10px;">
      <div style="width:44px; height:44px; border-radius:10px; background:#F5EDE8; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" />
        </svg>
      </div>
      <div>
        <p style="color:#933a35; font-size:15px; font-weight:600; margin:0 0 4px;">Forecast</p>
        <p style="color:#6B6B6B; font-size:13px; font-weight:400; line-height:1.5; margin:0;">Know how you'll feel — before the day begins.</p>
      </div>
    </div>

    <%# Smart Reminders — highlighted card %>
    <div style="background:#933a35; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; position:relative; overflow:hidden; margin-bottom:0;">
      <div style="position:absolute; top:10px; right:12px;">
        <span style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; background:rgba(255,255,255,0.2); color:#fff; padding:2px 8px; border-radius:20px;">New</span>
      </div>
      <div style="width:44px; height:44px; border-radius:10px; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
          <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
      </div>
      <div>
        <p style="color:#FFFFFF; font-size:15px; font-weight:600; margin:0 0 4px;">Smart Reminders</p>
        <p style="color:rgba(255,255,255,0.85); font-size:13px; font-weight:400; line-height:1.5; margin:0;">Pill &amp; supplement reminders — timed to your phase.</p>
      </div>
    </div>
  </div>

  <%# ── Support footer ── %>
  <div style="margin-top:40px; text-align:center;">
    <p style="color:#D18D83; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 6px;">Questions?</p>
    <a href="mailto:support@season.vision" style="color:#933a35; font-size:15px; font-weight:500; text-decoration:none;">info@season.vision</a>
  </div>

  <%# ── Phase dots footer ── %>
  <div style="display:flex; align-items:center; gap:6px; margin-top:32px;">
    <span style="width:6px; height:6px; border-radius:50%; background:#933a35; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#D18D83; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#F5C6AD; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#EDE1D5; display:inline-block;"></span>
  </div>

</div>
