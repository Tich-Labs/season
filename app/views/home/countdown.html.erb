<%# Season V2 countdown page — public, no auth required.
    Uses launch layout (no app bar / burger menu).
    Countdown Stimulus controller: data-countdown-target-date-value
    Launch signup form for email collection %>

<div style="background:#FAF7F4; min-height:100vh; display:flex; flex-direction:column; align-items:center; padding:48px 32px 48px; max-width:430px; margin:0 auto;">

  <%# ── Logo block — larger, more prominent ── %>
  <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;">
    <%= image_tag "screen1logo.png",
        class: "w-[234px] h-[255px] object-contain",
        alt: "Season" %>
    <%= image_tag "season-wortmarke-1.svg",
        style: "width:280px; height:auto; display:block; margin:0 auto;",
        alt: "Season" %>
  </div>

  <%# ── Feature slideshow ── %>
  <div class="w-full mb-5"
       data-controller="feature-slides"
       data-action="touchstart->feature-slides#touchStart touchend->feature-slides#touchEnd">

    <%# Slide container %>
    <div class="relative overflow-hidden rounded-2xl"
         style="box-shadow:0 1px 8px rgba(147,58,53,0.06);">

      <%# ── Slide 1: Introduction ── %>
      <div data-feature-slides-target="slide" class="hidden bg-[#ede1d5] rounded-2xl px-6 pt-8 pb-6 flex flex-col items-center text-center">
        <div class="w-24 h-24 mb-4 flex items-center justify-center">
          <svg viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <ellipse cx="48" cy="58" rx="22" ry="26" fill="#933a35" fill-opacity="0.15" stroke="#933a35" stroke-width="2"/>
            <path d="M36 58 C36 46 60 46 60 58" stroke="#933a35" stroke-width="2" fill="none"/>
            <circle cx="42" cy="52" r="3" fill="#933a35"/>
            <circle cx="54" cy="52" r="3" fill="#933a35"/>
            <path d="M48 32 C44 24 38 22 38 30 C38 36 44 38 48 44 C52 38 58 36 58 30 C58 22 52 24 48 32Z" fill="#933a35" fill-opacity="0.6" stroke="#933a35" stroke-width="1.5"/>
          </svg>
        </div>
        <h2 class="font-['Montserrat'] font-semibold text-2xl text-[#933a35] mb-3 leading-tight">
          Find Your Superpower with SEASON
        </h2>
        <p class="font-['Montserrat'] text-base text-[#933a35] leading-relaxed mb-2">
          Your cycle is more than your period. Design your everyday life in harmony with your hormonal cycle.
        </p>
        <p class="font-['Montserrat'] text-sm text-[#933a35] font-semibold leading-relaxed">
          Plan, work, love and live according to your cycle.
        </p>
      </div>

      <%# ── Slide 2: The Calendar ── %>
      <div data-feature-slides-target="slide" class="hidden bg-white rounded-2xl px-6 pt-8 pb-6 flex flex-col items-center text-center">
        <div class="mb-4 relative" style="width:140px; height:280px;">
          <div class="absolute inset-0 rounded-[28px] border-4 border-gray-800 bg-white overflow-hidden shadow-lg">
            <div class="w-full h-full bg-[#FAF7F4] flex flex-col">
              <div class="bg-[#ede1d5] px-3 py-2 flex items-center justify-between">
                <span class="text-[#933a35] text-[9px] font-semibold font-['Montserrat']">SEASON</span>
                <span class="text-[#933a35] text-[9px] font-['Montserrat']">April 2026</span>
              </div>
              <div class="grid grid-cols-7 gap-px px-1 mt-1">
                <% %w[M T W T F S S].each do |d| %>
                  <div class="text-[7px] text-center text-[#6B6B6B] font-semibold"><%= d %></div>
                <% end %>
                <% (1..28).each do |n| %>
                  <div class="text-[7px] text-center py-px rounded-full <%= n == 14 ? 'bg-[#933a35] text-white' : 'text-[#333]' %>"><%= n %></div>
                <% end %>
              </div>
            </div>
          </div>
          <div class="absolute top-1 left-1/2 -translate-x-1/2 w-10 h-1.5 bg-gray-800 rounded-full"></div>
        </div>
        <h2 class="font-['Montserrat'] font-semibold text-2xl text-[#933a35] mb-3 leading-tight">The Calendar</h2>
        <p class="font-['Montserrat'] text-base text-[#933a35] leading-relaxed">
          Your home base. See your cycle, appointments and forecast — tap any day or add new events.
        </p>
      </div>

      <%# ── Slide 3: Cycle Colors ── %>
      <div data-feature-slides-target="slide" class="hidden bg-white rounded-2xl px-6 pt-8 pb-6 flex flex-col items-center text-center">
        <div class="mb-4 relative" style="width:140px; height:280px;">
          <div class="absolute inset-0 rounded-[28px] border-4 border-gray-800 bg-white overflow-hidden shadow-lg">
            <div class="w-full h-full bg-[#FAF7F4] flex flex-col">
              <div class="bg-[#ede1d5] px-3 py-2">
                <span class="text-[#933a35] text-[9px] font-semibold font-['Montserrat']">SEASON</span>
              </div>
              <div class="grid grid-cols-7 gap-px px-1 mt-1">
                <% (1..28).each do |n| %>
                  <% color = if n <= 5 then '#933a35' elsif n <= 14 then '#7fa38a' elsif n <= 18 then '#b8d5c2' else '#e8c5d0' end %>
                  <div class="text-[7px] text-center py-px rounded-sm text-white font-bold" style="background-color:<%= color %>"><%= n %></div>
                <% end %>
              </div>
              <div class="mt-2 px-2 space-y-1">
                <div class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm flex-shrink-0" style="background:#933a35;"></span><span class="text-[7px] text-[#333]">Menstruation</span></div>
                <div class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm flex-shrink-0" style="background:#50715b;"></span><span class="text-[7px] text-[#333]">Ovulation</span></div>
                <div class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm flex-shrink-0" style="background:#7fa38a;"></span><span class="text-[7px] text-[#333]">Follicular</span></div>
                <div class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm flex-shrink-0" style="background:#e8c5d0;"></span><span class="text-[7px] text-[#333]">Luteal</span></div>
              </div>
            </div>
          </div>
          <div class="absolute top-1 left-1/2 -translate-x-1/2 w-10 h-1.5 bg-gray-800 rounded-full"></div>
        </div>
        <h2 class="font-['Montserrat'] font-semibold text-2xl text-[#933a35] mb-3 leading-tight">Your Cycle Colors</h2>
        <p class="font-['Montserrat'] text-base text-[#933a35] leading-relaxed">
          Each color represents a cycle phase — Menstruation, Ovulation, Follicular, and Luteal.
        </p>
      </div>

      <%# ── Slide 4: Track Your Day ── %>
      <div data-feature-slides-target="slide" class="hidden bg-white rounded-2xl px-6 pt-8 pb-6 flex flex-col items-center text-center">
        <div class="mb-4 relative" style="width:140px; height:280px;">
          <div class="absolute inset-0 rounded-[28px] border-4 border-gray-800 bg-white overflow-hidden shadow-lg">
            <div class="w-full h-full bg-[#FAF7F4] flex flex-col gap-1 p-2">
              <div class="bg-[#ede1d5] rounded-lg px-2 py-1.5 flex items-center gap-1">
                <span class="text-[8px] font-semibold text-[#933a35] font-['Montserrat']">Today</span>
                <span class="text-[7px] text-[#6B6B6B] font-['Montserrat']">Day 12</span>
              </div>
              <% [["😊","Mood","Great"],["⚡","Energy","High"],["😴","Sleep","7h"],["💪","Superpower","Focus"]].each do |icon, label, val| %>
                <div class="bg-white rounded-lg px-2 py-1 flex items-center justify-between">
                  <div class="flex items-center gap-1">
                    <span class="text-[10px]"><%= icon %></span>
                    <span class="text-[7px] text-[#333] font-['Montserrat']"><%= label %></span>
                  </div>
                  <span class="text-[7px] text-[#933a35] font-semibold font-['Montserrat']"><%= val %></span>
                </div>
              <% end %>
            </div>
          </div>
          <div class="absolute top-1 left-1/2 -translate-x-1/2 w-10 h-1.5 bg-gray-800 rounded-full"></div>
        </div>
        <h2 class="font-['Montserrat'] font-semibold text-2xl text-[#933a35] mb-3 leading-tight">Track Your Day</h2>
        <p class="font-['Montserrat'] text-base text-[#933a35] leading-relaxed">
          Log mood, energy, symptoms and superpowers. Feed the app data to get the most accurate forecast.
        </p>
      </div>

      <%# ── Slide 5: Create Appointments ── %>
      <div data-feature-slides-target="slide" class="hidden bg-white rounded-2xl px-6 pt-8 pb-6 flex flex-col items-center text-center">
        <div class="mb-4 relative" style="width:140px; height:280px;">
          <div class="absolute inset-0 rounded-[28px] border-4 border-gray-800 bg-white overflow-hidden shadow-lg">
            <div class="w-full h-full bg-[#FAF7F4] flex flex-col gap-1 p-2">
              <div class="bg-[#ede1d5] rounded-lg px-2 py-1.5">
                <span class="text-[8px] font-semibold text-[#933a35] font-['Montserrat']">New Appointment</span>
              </div>
              <% [["📋","Title","Dr. Check-up"],["📅","Date","Apr 14"],["🏷️","Icon","🏥"],["📝","Notes","Bring report"]].each do |icon, label, val| %>
                <div class="bg-white rounded-lg px-2 py-1.5">
                  <div class="text-[6px] text-[#6B6B6B] font-['Montserrat'] mb-0.5"><%= label %></div>
                  <div class="text-[7px] text-[#333] font-['Montserrat']"><%= val %></div>
                </div>
              <% end %>
              <div class="mt-auto bg-[#933a35] rounded-lg py-1.5 text-center">
                <span class="text-[8px] font-semibold text-white font-['Montserrat']">Save</span>
              </div>
            </div>
          </div>
          <div class="absolute top-1 left-1/2 -translate-x-1/2 w-10 h-1.5 bg-gray-800 rounded-full"></div>
        </div>
        <h2 class="font-['Montserrat'] font-semibold text-2xl text-[#933a35] mb-3 leading-tight">Create Appointments</h2>
        <p class="font-['Montserrat'] text-base text-[#933a35] leading-relaxed">
          Tap + in the calendar to add appointments with icons and details. Sync your calendar in settings.
        </p>
      </div>

      <%# ── Slide 6: Your Forecast ── %>
      <div data-feature-slides-target="slide" class="hidden bg-white rounded-2xl px-6 pt-8 pb-6 flex flex-col items-center text-center">
        <div class="mb-4 relative" style="width:140px; height:280px;">
          <div class="absolute inset-0 rounded-[28px] border-4 border-gray-800 bg-white overflow-hidden shadow-lg">
            <div class="w-full h-full bg-[#FAF7F4] flex flex-col gap-1 p-2">
              <div class="bg-[#ede1d5] rounded-lg px-2 py-1.5">
                <span class="text-[8px] font-semibold text-[#933a35] font-['Montserrat']">Forecast · Apr 14</span>
              </div>
              <% [["🌟","Superpower","Creative"],["⚡","Energy","High"],["🧠","Focus","Strong"],["💬","Social","Outgoing"],["💖","Mood","Optimistic"]].each do |icon, label, val| %>
                <div class="bg-white rounded-lg px-2 py-1 flex items-center justify-between">
                  <div class="flex items-center gap-1">
                    <span class="text-[10px]"><%= icon %></span>
                    <span class="text-[7px] text-[#333] font-['Montserrat']"><%= label %></span>
                  </div>
                  <span class="text-[7px] text-[#933a35] font-semibold font-['Montserrat']"><%= val %></span>
                </div>
              <% end %>
            </div>
          </div>
          <div class="absolute top-1 left-1/2 -translate-x-1/2 w-10 h-1.5 bg-gray-800 rounded-full"></div>
        </div>
        <h2 class="font-['Montserrat'] font-semibold text-2xl text-[#933a35] mb-3 leading-tight">Your Forecast</h2>
        <p class="font-['Montserrat'] text-base text-[#933a35] leading-relaxed">
          Tap a day in your calendar then swipe left for a deep-dive into your forecast. Tap any tile for more detail.
        </p>
      </div>

      <%# ── Slide 7: You're All Set ── %>
      <div data-feature-slides-target="slide" class="hidden bg-[#ede1d5] rounded-2xl px-6 pt-8 pb-6 flex flex-col items-center text-center">
        <div class="w-24 h-24 mb-4 flex items-center justify-center">
          <svg viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <circle cx="48" cy="48" r="36" fill="#933a35" fill-opacity="0.12" stroke="#933a35" stroke-width="2"/>
            <path d="M30 48 L42 60 L66 36" stroke="#933a35" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="font-['Montserrat'] font-semibold text-2xl text-[#933a35] mb-3 leading-tight">
          You're All Set!
        </h2>
        <p class="font-['Montserrat'] text-base text-[#933a35] leading-relaxed mb-2">
          Explore the app, track your cycle, and let us know what you think.
        </p>
        <p class="font-['Montserrat'] text-sm text-[#933a35] font-semibold leading-relaxed">
          We're so excited to have you here — welcome to SEASON.
        </p>
      </div>

    </div><%# end slide container %>

    <%# Progress dots %>
    <div class="flex items-center justify-center gap-[10px] mt-4">
      <% 7.times do |i| %>
        <button type="button"
                data-feature-slides-target="dot"
                data-feature-slides-index="<%= i %>"
                data-action="click->feature-slides#goTo"
                class="h-3 rounded-full bg-[#50715b] transition-all duration-300 <%= i == 0 ? 'w-[52px]' : 'w-3 opacity-30' %>">
        </button>
      <% end %>
    </div>

    <%# Prev / Next arrows (hidden on small) %>
    <div class="flex justify-between items-center mt-3 px-1">
      <button type="button"
              data-action="click->feature-slides#prev"
              class="text-[#933a35] text-sm font-semibold font-['Montserrat'] opacity-60 px-2 py-1">
        &#8592;
      </button>
      <button type="button"
              data-action="click->feature-slides#next"
              class="text-[#933a35] text-sm font-semibold font-['Montserrat'] opacity-60 px-2 py-1">
        &#8594;
      </button>
    </div>

  </div><%# end feature-slides controller %>

  <%# ── Notify Me Section ── %>
  <div style="width:100%; background:#933a35; border-radius:16px; padding:20px; margin-bottom:20px;">
    <h2 style="color:#FFFFFF; font-size:16px; font-weight:600; margin:0 0 8px;">Get notified when we launch</h2>
    <p style="color:rgba(255,255,255,0.8); font-size:13px; margin:0 0 16px;">Be the first to know on April 14th</p>

    <div data-controller="launch-signup">
      <form action="/launch-signup" method="POST" data-launch-signup-target="form" style="display:flex; gap:8px;">
        <input type="email"
               name="email"
               placeholder="your@email.com"
               autocomplete="email"
               required
               style="flex:1; padding:12px 16px; border:none; border-radius:8px; font-size:14px; outline:none;"
               data-launch-signup-target="email">
        <button type="submit"
                data-action="click->launch-signup#submit"
                style="padding:12px 20px; background:#FFFFFF; color:#933a35; border:none; border-radius:8px; font-size:14px; font-weight:600; cursor:pointer;">
          Notify Me
        </button>
      </form>

      <div data-launch-signup-target="success" style="display:none; margin-top:12px;">
        <p style="color:#FFFFFF; font-size:14px; margin:0;">✓ You're on the list! We'll email you on April 14th.</p>
      </div>

      <div data-launch-signup-target="error" style="display:none; margin-top:12px;">
        <p style="color:#FFCCCC; font-size:13px; margin:0;" data-launch-signup-target="errorMessage"></p>
      </div>
    </div>
  </div>

  <%# ── Phase dots ── %>
  <div style="display:flex; align-items:center; gap:8px; margin-bottom:24px;">
    <span style="width:10px; height:10px; border-radius:50%; background:#933a35; display:inline-block;"></span>
    <span style="width:10px; height:10px; border-radius:50%; background:#D18D83; display:inline-block;"></span>
    <span style="width:10px; height:10px; border-radius:50%; background:#F5C6AD; display:inline-block;"></span>
    <span style="width:10px; height:10px; border-radius:50%; background:#EDE1D5; display:inline-block;"></span>
  </div>

  <%# ── Countdown timer ── %>
  <div style="background:#FFFFFF; border-radius:16px; padding:20px 16px; width:100%; display:flex; justify-content:center; gap:8px; box-shadow:0 2px 20px rgba(147,58,53,0.08); margin-bottom:10px;"
       data-controller="countdown"
       data-countdown-target-date-value="2026-04-14T00:00:00+02:00">
    <% [["days", "Days"], ["hours", "Hours"], ["minutes", "Min"], ["seconds", "Sec"]].each do |target, label| %>
      <div style="display:flex; flex-direction:column; align-items:center; width:60px;">
        <div style="width:56px; height:56px; border-radius:10px; background:#F5EDE8; color:#933a35; display:flex; align-items:center; justify-content:center; font-size:24px; font-weight:900; font-variant-numeric:tabular-nums;"
             data-countdown-target="<%= target %>">00</div>
        <span style="margin-top:4px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#6B6B6B;"><%= label %></span>
      </div>
    <% end %>
  </div>
  <p style="color:#D18D83; font-size:13px; font-weight:500; margin:0 0 32px; text-align:center;">Launching April 14, 2026</p>

  <%# ── Feature preview cards ── %>
  <div style="width:100%; margin-bottom:8px;">
    <p style="color:#933a35; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 16px;">What's new in V2</p>

    <%# Calendar (not new - existing feature) %>
    <div style="background:#FFFFFF; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; box-shadow:0 1px 8px rgba(147,58,53,0.06); margin-bottom:10px;">
      <div style="width:44px; height:44px; border-radius:10px; background:#F5EDE8; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
        </svg>
      </div>
      <div>
        <p style="color:#933a35; font-size:15px; font-weight:600; margin:0 0 4px;">Calendar</p>
        <p style="color:#6B6B6B; font-size:13px; font-weight:400; line-height:1.5; margin:0;">Your cycle, appointments — always one glance ahead.</p>
      </div>
    </div>

    <%# Forecast %>
    <div style="background:#FFFFFF; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; box-shadow:0 1px 8px rgba(147,58,53,0.06); margin-bottom:10px;">
      <div style="width:44px; height:44px; border-radius:10px; background:#F5EDE8; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="#933a35" stroke-width="1.5" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" />
        </svg>
      </div>
      <div>
        <p style="color:#933a35; font-size:15px; font-weight:600; margin:0 0 4px;">Forecast</p>
        <p style="color:#6B6B6B; font-size:13px; font-weight:400; line-height:1.5; margin:0;">Know how you'll feel — before the day begins.</p>
      </div>
    </div>

    <%# Smart Reminders — highlighted card %>
    <div style="background:#933a35; border-radius:12px; padding:18px 20px; display:flex; align-items:flex-start; gap:16px; position:relative; overflow:hidden; margin-bottom:0;">
      <div style="position:absolute; top:10px; right:12px;">
        <span style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; background:rgba(255,255,255,0.2); color:#fff; padding:2px 8px; border-radius:20px;">New</span>
      </div>
      <div style="width:44px; height:44px; border-radius:10px; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
          <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
      </div>
      <div>
        <p style="color:#FFFFFF; font-size:15px; font-weight:600; margin:0 0 4px;">Smart Reminders</p>
        <p style="color:rgba(255,255,255,0.85); font-size:13px; font-weight:400; line-height:1.5; margin:0;">Pill &amp; supplement reminders — timed to your phase.</p>
      </div>
    </div>
  </div>

  <%# ── Support footer ── %>
  <div style="margin-top:40px; text-align:center;">
    <p style="color:#D18D83; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 6px;">Questions?</p>
    <a href="mailto:support@season.vision" style="color:#933a35; font-size:15px; font-weight:500; text-decoration:none;">support@season.vision</a>
  </div>

  <%# ── Phase dots footer ── %>
  <div style="display:flex; align-items:center; gap:6px; margin-top:32px;">
    <span style="width:6px; height:6px; border-radius:50%; background:#933a35; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#D18D83; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#F5C6AD; display:inline-block;"></span>
    <span style="width:6px; height:6px; border-radius:50%; background:#EDE1D5; display:inline-block;"></span>
  </div>

</div>
