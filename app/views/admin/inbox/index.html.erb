<% content_for :page_title, "Inbox" %>

<%# Breadcrumbs %>
<% breadcrumb_items = [] %>
<% breadcrumb_items << { label: "Admin", url: admin_root_path } %>
<% breadcrumb_items << { label: "Inbox", url: admin_inbox_path } %>
<% case action_name %>
<% when "feedback" %>
  <% breadcrumb_items << { label: "Feedback", url: nil } %>
<% when "bugs" %>
  <% breadcrumb_items << { label: "Bugs", url: nil } %>
<% when "support" %>
  <% breadcrumb_items << { label: "Support", url: nil } %>
<% end %>

<div class="mb-4 flex items-center gap-2 text-sm">
  <% breadcrumb_items.each_with_index do |item, idx| %>
    <% if idx > 0 %><span class="text-gray-400">/</span><% end %>
    <% if item[:url] %>
      <a href="<%= item[:url] %>" class="text-[#933a35] hover:underline"><%= item[:label] %></a>
    <% else %>
      <span class="text-gray-600 font-medium"><%= item[:label] %></span>
    <% end %>
  <% end %>
</div>

<%# Stats always visible %>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Total</p>
    <p class="text-2xl font-bold text-[#933a35] mt-1"><%= @stats[:total] %></p>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Feedback</p>
    <p class="text-2xl font-bold text-blue-600 mt-1"><%= @stats[:feedback] %></p>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Bugs</p>
    <p class="text-2xl font-bold text-red-600 mt-1"><%= @stats[:bugs] %></p>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Support</p>
    <p class="text-2xl font-bold text-purple-600 mt-1"><%= @stats[:support] %></p>
  </div>
</div>

<%# CSV export %>
<div class="flex justify-end mb-6">
  <a class="px-3 py-1.5 rounded-full text-xs font-medium bg-green-700 text-white hover:bg-green-800 transition-colors"
     href="<%= admin_inbox_export_csv_path(filter: action_name == "overview" ? nil : action_name) %>">↓ CSV</a>
</div>

<%# Data table %>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date / time</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Message</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% if @messages.any? %>
        <% @messages.each do |msg| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <%= msg.created_at.strftime("%Y-%m-%d %H:%M") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= msg.user.email %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% badge = case msg.type
                         when 'feedback'  then { label: 'Feedback', bg: 'bg-blue-100',        text: 'text-blue-700' }
                         when 'bug_report' then { label: 'Bug',      bg: 'bg-red-100',         text: 'text-red-700' }
                         when 'support'   then { label: 'Support',   bg: 'bg-[#ede1d5]',       text: 'text-[#933a35]' }
                         end %>
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium <%= badge[:bg] %> <%= badge[:text] %>"><%= badge[:label] %></span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600 max-w-md truncate">
              <%= msg.message %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="4" class="px-6 py-8 text-center text-sm text-gray-500">
            No messages yet
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
