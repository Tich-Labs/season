<div class="w-full max-w-sm mx-auto px-4">

  <%# Wordmark %>
  <div class="text-center mb-8">
    <span class="text-[#933a35] text-3xl font-bold tracking-widest uppercase">Season</span>
    <span class="block text-[#6B6B6B] text-sm font-medium tracking-widest uppercase mt-1">Admin</span>
  </div>

  <%# Card %>
  <div class="bg-white rounded-2xl shadow-sm p-8">

    <% if @error == :rate_limited %>
      <div class="bg-[#FDF0EE] rounded-xl px-4 py-3 mb-6 text-sm text-[#933a35] flex items-center gap-2">
        <span class="font-bold text-base">!</span>
        Too many login attempts. Please try again in 15 minutes.
      </div>
    <% elsif @error %>
      <div class="bg-[#FDF0EE] rounded-xl px-4 py-3 mb-6 text-sm text-[#933a35] flex items-center gap-2">
        <span class="font-bold text-base">!</span>
        Invalid email or password, or account is not an admin.
      </div>
    <% end %>

    <%= form_with url: admin_login_path, method: :post, local: true do |f| %>

      <div class="mb-4">
        <label class="block text-xs font-semibold text-[#6B6B6B] uppercase tracking-wider mb-1" for="email">Email</label>
        <%= f.email_field :email,
            id: "email",
            autofocus: true,
            autocomplete: "username",
            placeholder: "admin@example.com",
            class: "w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-[#3d2b28] text-sm outline-none border-0" %>
      </div>

      <div class="mb-6">
        <label class="block text-xs font-semibold text-[#6B6B6B] uppercase tracking-wider mb-1" for="password">Password</label>
        <%= f.password_field :password,
            id: "password",
            autocomplete: "current-password",
            placeholder: "••••••••",
            class: "w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-[#3d2b28] text-sm outline-none border-0" %>
      </div>

      <%= f.submit "Sign in to Admin",
          class: "w-full bg-[#933a35] text-white font-semibold rounded-xl py-3 text-sm cursor-pointer border-0 hover:bg-[#7a2f2a] transition-colors" %>

    <% end %>
  </div>

  <p class="text-center text-xs text-[#6B6B6B] mt-6">
    <%= link_to "← Back to app", root_path, class: "text-[#933a35] hover:underline" %>
  </p>

</div>
