<% content_for :page_title, "Users" %>

<div class="space-y-4">

  <%# ── Toolbar ── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
    <div class="flex items-center gap-3 flex-wrap">
      <%= search_form_for @q, url: admin_users_path, html: { class: "flex gap-2 flex-1 min-w-[260px]" } do |f| %>
        <%= f.search_field :name_or_public_id_cont,
            placeholder: "Search name or User ID…",
            class: "flex-1 bg-gray-100 rounded-lg px-3 py-2 text-sm border-0 focus:ring-2 focus:ring-[#933a35] focus:outline-none" %>
        <%= f.submit "Search",
            class: "bg-[#933a35] text-white px-4 py-2 rounded-lg text-sm font-medium cursor-pointer hover:bg-[#7a2f2a] transition-colors" %>
      <% end %>

      <div class="flex items-center gap-2 flex-wrap">
        <%= link_to "All", admin_users_path,
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-[#f5ede8] text-[#933a35] hover:bg-[#ede1d5] transition-colors" %>
        <%= link_to "English", admin_users_path(q: { language_eq: "en" }),
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-[#f5ede8] text-[#933a35] hover:bg-[#ede1d5] transition-colors" %>
        <%= link_to "German", admin_users_path(q: { language_eq: "de" }),
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-[#f5ede8] text-[#933a35] hover:bg-[#ede1d5] transition-colors" %>
        <%= link_to "↓ CSV", admin_users_path(format: :csv),
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-green-700 text-white hover:bg-green-800 transition-colors" %>
      </div>
    </div>
  </div>

  <%# ── Stats bar ── %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Total Users</p>
      <p class="text-2xl font-bold text-[#933a35] mt-1"><%= @total_count %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Onboarded</p>
      <p class="text-2xl font-bold text-green-700 mt-1"><%= User.where(onboarding_completed: true).count %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide">English</p>
      <p class="text-2xl font-bold text-gray-700 mt-1"><%= User.where(language: "en").count %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide">German</p>
      <p class="text-2xl font-bold text-gray-700 mt-1"><%= User.where(language: "de").count %></p>
    </div>
  </div>

  <%# ── Users table ── %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-[#f5ede8] text-left">
          <th class="px-4 py-3 text-xs font-semibold text-[#933a35] uppercase tracking-wide">User ID</th>
          <th class="px-4 py-3 text-xs font-semibold text-[#933a35] uppercase tracking-wide">Language</th>
          <th class="px-4 py-3 text-xs font-semibold text-[#933a35] uppercase tracking-wide">Onboarding</th>
          <th class="px-4 py-3 text-xs font-semibold text-[#933a35] uppercase tracking-wide">Signed Up</th>
          <th class="px-4 py-3 text-xs font-semibold text-[#933a35] uppercase tracking-wide">Streak</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @users.each do |user| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3 font-medium text-[#933a35]">
              <%= link_to user.public_id.to_s[0..7], admin_user_path(user), class: "hover:underline font-mono text-xs" %>
            </td>
            <td class="px-4 py-3 text-gray-600 uppercase text-xs"><%= user.language || "en" %></td>
            <td class="px-4 py-3">
              <% if user.onboarding_completed? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Complete</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-50 text-[#933a35]">Pending</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-gray-600"><%= user.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="px-4 py-3 text-[#933a35] font-medium"><%= user.streak&.current_streak || 0 %> 🔥</td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%# Simple pagination (controller uses offset/limit, no pagy gem) %>
    <div class="px-4 py-3 flex items-center justify-between border-t border-gray-100 text-sm text-gray-500">
      <span>Showing <%= @users.length %> of <%= @total_count %> users</span>
      <div class="flex gap-2">
        <% if @page > 1 %>
          <%= link_to "← Prev", admin_users_path(page: @page - 1),
              class: "px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-[#933a35] hover:bg-gray-50 transition-colors" %>
        <% end %>
        <span class="px-3 py-1.5">Page <%= @page %></span>
        <% if @users.length == 20 %>
          <%= link_to "Next →", admin_users_path(page: @page + 1),
              class: "px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-[#933a35] hover:bg-gray-50 transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>

</div>
