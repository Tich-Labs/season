<div style="background:#FAF7F4; min-height:100vh; padding:20px;">

  <h1 style="color:#933a35; font-size:24px; font-weight:700; margin-bottom:20px;">Users</h1>

  <!-- Search -->
  <div style="background:#ffffff; padding:16px; border-radius:12px; margin-bottom:16px;">
    <%= search_form_for @q, url: admin_users_path do |f| %>
      <div style="display:flex; gap:8px;">
        <%= f.search_field :name_or_email_cont,
            placeholder: "Search name or email...",
            style: "flex:1; background:#EDE1D5; border-radius:8px; padding:12px; border:none; font-size:14px; color:#933a35;" %>
        <%= f.submit "Search",
            style: "background:#933a35; color:#ffffff; padding:12px 20px; border-radius:8px; border:none; font-size:14px; font-weight:500; cursor:pointer;" %>
      </div>
    <% end %>

    <!-- Filters -->
    <div style="display:flex; gap:8px; margin-top:12px;">
      <%= link_to "All", admin_users_path,
          style: "padding:8px 16px; border-radius:20px; font-size:12px; background:#EDE1D5; color:#933a35; text-decoration:none;" %>
      <%= link_to "English", admin_users_path(q: { language_eq: 'en' }),
          style: "padding:8px 16px; border-radius:20px; font-size:12px; background:#EDE1D5; color:#933a35; text-decoration:none;" %>
      <%= link_to "German", admin_users_path(q: { language_eq: 'de' }),
          style: "padding:8px 16px; border-radius:20px; font-size:12px; background:#EDE1D5; color:#933a35; text-decoration:none;" %>
      <%= link_to "CSV", admin_users_path(format: :csv),
          style: "padding:8px 16px; border-radius:20px; font-size:12px; background:#2E6B3E; color:#ffffff; text-decoration:none;" %>
    </div>
  </div>

  <!-- Users table -->
  <div style="background:#ffffff; border-radius:12px; overflow:hidden;">
    <table style="width:100%; border-collapse:collapse;">
      <thead>
        <tr style="background:#EDE1D5;">
          <th style="padding:12px; text-align:left; font-size:12px; color:#933a35; font-weight:600;">Name</th>
          <th style="padding:12px; text-align:left; font-size:12px; color:#933a35; font-weight:600;">Email</th>
          <th style="padding:12px; text-align:left; font-size:12px; color:#933a35; font-weight:600;">Language</th>
          <th style="padding:12px; text-align:left; font-size:12px; color:#933a35; font-weight:600;">Onboarding</th>
          <th style="padding:12px; text-align:left; font-size:12px; color:#933a35; font-weight:600;">Signed Up</th>
          <th style="padding:12px; text-align:left; font-size:12px; color:#933a35; font-weight:600;">Streak</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr style="border-bottom:1px solid #EDE1D5;">
            <td style="padding:12px; font-size:14px; color:#933a35;">
              <%= link_to user.name || '—', admin_user_path(user), style: "color:#933a35; text-decoration:none;" %>
            </td>
            <td style="padding:12px; font-size:14px; color:#6B6B6B;"><%= user.email %></td>
            <td style="padding:12px; font-size:14px; color:#6B6B6B;"><%= user.language || 'en' %></td>
            <td style="padding:12px;">
              <span style="padding:4px 8px; border-radius:4px; font-size:12px; background:<%= user.onboarding_completed? ? '#DFE7DD' : '#FDF0EE' %>; color:<%= user.onboarding_completed? ? '#2E6B3E' : '#933a35' %>;">
                <%= user.onboarding_completed? ? 'Complete' : 'Pending' %>
              </span>
            </td>
            <td style="padding:12px; font-size:14px; color:#6B6B6B;"><%= user.created_at.strftime('%Y-%m-%d') %></td>
            <td style="padding:12px; font-size:14px; color:#933a35; font-weight:500;">
              <%= user.streak&.current_streak || 0 %> 🔥
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if @pagy %>
    <div style="display:flex; justify-content:center; gap:8px; margin-top:16px;">
      <% if @pagy.prev %>
        <%= link_to "← Prev", admin_users_path(page: @pagy.prev),
            style: "padding:8px 16px; background:#ffffff; color:#933a35; border-radius:8px; text-decoration:none;" %>
      <% end %>
      <span style="padding:8px 16px; color:#6B6B6B; font-size:14px;">Page <%= @pagy.page %> of <%= @pagy.pages %></span>
      <% if @pagy.next %>
        <%= link_to "Next →", admin_users_path(page: @pagy.next),
            style: "padding:8px 16px; background:#ffffff; color:#933a35; border-radius:8px; text-decoration:none;" %>
      <% end %>
    </div>
  <% end %>

</div>
