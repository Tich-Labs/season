<% content_for :page_title, "Edit Informations Content" %>

<div class="space-y-6 max-w-3xl">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="text-xl font-bold text-gray-900"><%= @content.phase.capitalize %> / <%= @content.locale.upcase %></h2>
        <p class="text-sm text-gray-500 mt-1">Edit the content shown on the Informations page for this phase.</p>
      </div>
      <%= link_to "Back", admin_cycle_phase_contents_path, class: "text-sm text-[#933a35] hover:underline" %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <%= form_with model: [:admin, @content], local: true do |f| %>
      <div class="grid grid-cols-1 gap-6">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Phase</label>
            <input value="<%= @content.phase.capitalize %>" disabled class="w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-sm text-[#3d2b28] border-0">
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Locale</label>
            <input value="<%= @content.locale.upcase %>" disabled class="w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-sm text-[#3d2b28] border-0">
          </div>
        </div>

        <div>
          <%= f.label :season_name, "Season name", class: "block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" %>
          <%= f.text_field :season_name, class: "w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-sm text-[#3d2b28] border-0" %>
        </div>

        <div>
          <%= f.label :mood_text, "Emotional world", class: "block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" %>
          <%= f.text_area :mood_text, rows: 3, class: "w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-sm text-[#3d2b28] border-0" %>
        </div>

        <div>
          <%= f.label :sport_text, "Sport / movement", class: "block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" %>
          <%= f.text_area :sport_text, rows: 3, class: "w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-sm text-[#3d2b28] border-0" %>
        </div>

        <div>
          <%= f.label :nutrition_text, "That will do you good", class: "block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" %>
          <%= f.text_area :nutrition_text, rows: 3, class: "w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-sm text-[#3d2b28] border-0" %>
        </div>

        <div>
          <%= f.label :superpower_text, "Superpower text", class: "block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" %>
          <%= f.text_area :superpower_text, rows: 2, class: "w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-sm text-[#3d2b28] border-0" %>
        </div>

        <div>
          <%= f.label :take_care_text, "Take care text", class: "block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" %>
          <%= f.text_area :take_care_text, rows: 3, class: "w-full bg-[#EDE1D5] rounded-xl px-4 py-3 text-sm text-[#3d2b28] border-0" %>
        </div>
      </div>

      <div class="mt-6 flex justify-end gap-3">
        <%= link_to "Cancel", admin_cycle_phase_contents_path, class: "px-4 py-2 rounded-xl bg-gray-100 text-gray-700 text-sm hover:bg-gray-200 transition-colors" %>
        <%= f.submit "Save changes", class: "px-5 py-2 rounded-xl bg-[#933a35] text-white text-sm font-semibold hover:bg-[#7a2f2a] transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
