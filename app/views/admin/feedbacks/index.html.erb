<% content_for :page_title, "Feedback & Bugs" %>

<div class="space-y-4">

  <%# Toolbar %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
    <div class="flex items-center gap-3 flex-wrap">
      <div class="flex items-center gap-2 flex-wrap">
        <%= link_to "All", admin_feedbacks_path,
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-[#f5ede8] text-[#933a35] hover:bg-[#ede1d5] transition-colors" %>
        <%= link_to "Feedback", admin_feedbacks_path(type: "feedback"),
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-[#f5ede8] text-[#933a35] hover:bg-[#ede1d5] transition-colors" %>
        <%= link_to "Bug Reports", admin_feedbacks_path(type: "bug_report"),
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-[#f5ede8] text-[#933a35] hover:bg-[#ede1d5] transition-colors" %>
        <%= link_to "Support", admin_feedbacks_path(type: "support"),
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-[#f5ede8] text-[#933a35] hover:bg-[#ede1d5] transition-colors" %>
        <%= link_to "↓ CSV", export_csv_admin_feedbacks_path,
            class: "px-3 py-1.5 rounded-full text-xs font-medium bg-green-700 text-white hover:bg-green-800 transition-colors" %>
      </div>
    </div>
  </div>

  <%# Stats %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Total</p>
      <p class="text-2xl font-bold text-[#933a35] mt-1"><%= Feedback.count %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Feedback</p>
      <p class="text-2xl font-bold text-blue-600 mt-1"><%= Feedback.feedback_type_feedback.count %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Bugs</p>
      <p class="text-2xl font-bold text-red-600 mt-1"><%= Feedback.feedback_type_bug_report.count %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-5 py-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide">Support</p>
      <p class="text-2xl font-bold text-purple-600 mt-1"><%= Feedback.feedback_type_support.count %></p>
    </div>
  </div>

  <%# Table %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase">User</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="text-left px-4 py-3 text-xs font-medium text-gray-500 uppercase">Message</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @feedbacks.each do |f| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-sm text-gray-600"><%= f.created_at.strftime("%b %d, %H:%M") %></td>
            <td class="px-4 py-3 text-sm text-gray-900"><%= f.user.email %></td>
            <td class="px-4 py-3">
              <% if f.feedback_type_bug_report? %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700">Bug</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Feedback</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 max-w-xs truncate" title="<%= f.message %>"><%= f.message %></td>
          </tr>
        <% end %>
        <% if @feedbacks.empty? %>
          <tr>
            <td colspan="4" class="px-4 py-8 text-center text-gray-500">No feedback yet</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <div class="flex justify-center">
    <%= paginate @feedbacks %>
  </div>

</div>
