<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:space-between; padding:60px 32px 48px; max-width:430px; margin:0 auto;">

  <!-- Logo -->
  <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;">
    <%= image_tag "screen1logo.png",
        style: "width:180px; height:auto;",
        alt: "Season" %>
    <%= image_tag "season-wortmarke-1.svg",
        style: "width:200px; height:auto; margin-top:16px;",
        alt: "Season" %>
  </div>

  <!-- Invite form -->
  <div style="width:100%;">
    <p style="color:#933a35; font-size:22px; font-weight:500; text-align:center; margin-bottom:8px;">
      Welcome to Season!
    </p>
    <p style="color:#6B6B6B; font-size:16px; text-align:center; margin-bottom:32px;">
      Create your password to get started
    </p>

    <%= form_with url: invite_path(params[:token]), method: :patch do |f| %>
      <% if @user&.errors.any? %>
        <div style="background:#FDF0EE; border-radius:8px; padding:12px; margin-bottom:16px;">
          <p style="color:#933a35; font-size:14px;"><%= @user.errors.full_messages.join(", ") %></p>
        </div>
      <% end %>

      <div style="position:relative; margin-bottom:16px;" data-controller="password-visibility">
        <%= f.password_field :password,
            placeholder: "Create password...",
            required: true,
            autocomplete: "new-password",
            style: "width:100%; background:#EDE1D5; border-radius:8px; padding:14px 50px 14px 21px; height:52px; border:none; font-size:18px; color:#933a35; outline:none; box-sizing:border-box;",
            data: { "password-visibility-target": "input" } %>
        <button type="button" aria-label="Toggle password visibility" data-action="click->password-visibility#toggle" style="position:absolute; right:16px; top:50%; transform:translateY(-50%); background:none; border:none; padding:0; cursor:pointer;">
          <svg data-password-visibility-target="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
          <svg data-password-visibility-target="eyeClosed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
        </button>
      </div>

      <div style="position:relative; margin-bottom:24px;" data-controller="password-visibility">
        <%= f.password_field :password_confirmation,
            placeholder: "Confirm password...",
            required: true,
            autocomplete: "new-password",
            style: "width:100%; background:#EDE1D5; border-radius:8px; padding:14px 50px 14px 21px; height:52px; border:none; font-size:18px; color:#933a35; outline:none; box-sizing:border-box;",
            data: { "password-visibility-target": "input" } %>
        <button type="button" aria-label="Toggle password visibility" data-action="click->password-visibility#toggle" style="position:absolute; right:16px; top:50%; transform:translateY(-50%); background:none; border:none; padding:0; cursor:pointer;">
          <svg data-password-visibility-target="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
          <svg data-password-visibility-target="eyeClosed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
        </button>
      </div>

      <%= f.submit "GET STARTED",
          style: "width:100%; height:52px; background:#933a35; color:#ffffff; font-size:18px; font-weight:500; border-radius:8px; border:none; cursor:pointer;" %>
    <% end %>
  </div>

</div>
