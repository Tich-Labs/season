<%# GDPR Consent screen - Article 9 %>
<% content_for(:header_left) do %>
  <%= link_to user_root_path, class: "p-2 flex items-center" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </svg>
  <% end %>
<% end %>

<div class="bg-white min-h-screen">
  <div class="max-w-app mx-auto px-4 pb-20">

    <%# Header %>
    <div class="py-5 border-b border-[#DDD0CB] mb-4">
      <h2 class="text-brand-primary text-lg font-bold">Data & Privacy</h2>
    </div>

    <%# Intro %>
    <div class="bg-brand-error rounded-xl p-4 mb-5">
      <p class="text-brand-primary text-sm font-medium m-0">
        Your health data is processed only with your explicit consent.
      </p>
    </div>

    <%# Consent Form %>
    <%= form_with url: consent_settings_path, method: :post, local: true do %>
      <%# Health Data Processing %>
      <label class="flex items-start gap-3 p-4 bg-white border border-[#DDD0CB] rounded-xl mb-3 cursor-pointer">
        <input type="checkbox" name="consents[health_data_processing]"
               <%= current_user.consent?("health_data_processing") ? "checked" : "" %>
               class="w-5 h-5 accent-brand-primary mt-0.5 flex-shrink-0">
        <div class="flex-1">
          <span class="block text-brand-primary text-sm font-semibold">Health Data</span>
          <span class="block text-brand-secondary text-xs mt-1">
            Cycle dates, symptoms, mood, energy, and other health information you log.
          </span>
        </div>
      </label>

      <%# Symptom Tracking %>
      <label class="flex items-start gap-3 p-4 bg-white border border-[#DDD0CB] rounded-xl mb-3 cursor-pointer">
        <input type="checkbox" name="consents[symptom_tracking]"
               <%= current_user.consent?("symptom_tracking") ? "checked" : "" %>
               class="w-5 h-5 accent-brand-primary mt-0.5 flex-shrink-0">
        <div class="flex-1">
          <span class="block text-brand-primary text-sm font-semibold">Symptom Tracking</span>
          <span class="block text-brand-secondary text-xs mt-1">
            Daily symptom logs including pain, mood, energy, sleep, and discharge.
          </span>
        </div>
      </label>

      <%# Cycle Tracking %>
      <label class="flex items-start gap-3 p-4 bg-white border border-[#DDD0CB] rounded-xl mb-3 cursor-pointer">
        <input type="checkbox" name="consents[cycle_tracking]"
               <%= current_user.consent?("cycle_tracking") ? "checked" : "" %>
               class="w-5 h-5 accent-brand-primary mt-0.5 flex-shrink-0">
        <div class="flex-1">
          <span class="block text-brand-primary text-sm font-semibold">Cycle Tracking</span>
          <span class="block text-brand-secondary text-xs mt-1">
            Menstrual dates, cycle phases, and predictions.
          </span>
        </div>
      </label>

      <%# Menstrual Data %>
      <label class="flex items-start gap-3 p-4 bg-white border border-[#DDD0CB] rounded-xl mb-5 cursor-pointer">
        <input type="checkbox" name="consents[menstrual_data]"
               <%= current_user.consent?("menstrual_data") ? "checked" : "" %>
               class="w-5 h-5 accent-brand-primary mt-0.5 flex-shrink-0">
        <div class="flex-1">
          <span class="block text-brand-primary text-sm font-semibold">Menstrual Data</span>
          <span class="block text-brand-secondary text-xs mt-1">
            Period start/end dates and flow intensity.
          </span>
        </div>
      </label>

      <button type="submit" class="w-full bg-brand-primary text-white rounded-xl p-4 text-base font-medium">
        Save Preferences
      </button>
    <% end %>

    <%# Info text %>
    <div class="mt-6 p-4 bg-brand-background rounded-xl">
      <p class="text-brand-secondary text-xs leading-relaxed m-0">
        <strong class="text-brand-primary">Your Rights:</strong><br>
        You can withdraw consent at any time. Your data will be deleted according to our retention policy.
      </p>
    </div>

    <%# Link to Privacy Policy %>
    <%= link_to "View Privacy Policy", privacy_legal_path,
          class: "block text-center text-brand-primary text-sm mt-4 underline" %>

  </div>
</div>
