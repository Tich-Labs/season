<% content_for(:page_title) { "Informations" } %>
<% content_for(:header_dark) { "true" } %>
<% content_for(:header_color) { "#933a35" } %>

<% phase_colour = @meta[:colour] %>

<div class="bg-white min-h-screen pb-20">
  <div class="max-w-app mx-auto px-4 pt-6 pb-10">

    <%# Section 1: Phase title + hormone note %>
    <div class="mb-12">
      <div class="flex items-center justify-between gap-4 mb-3">
        <h1 class="text-base font-bold" style="color: <%= phase_colour %>;">
          <%= @phase == "menstrual" ? "Menstruation" : @phase.capitalize %> / <%= @meta[:season] %>
        </h1>
        <p class="text-sm font-normal shrink-0" style="color: <%= phase_colour %>; opacity: 0.7;">
          <%= @meta[:days] %>
        </p>
      </div>
      <div class="border-t border-gray-200 mb-4"></div>
      <% hormone_text = @meta[:note].presence %>
      <% if hormone_text %>
        <p class="text-base font-medium leading-relaxed" style="color: <%= phase_colour %>;">
          <%= hormone_text %>
        </p>
      <% end %>
    </div>

    <%# Section 2: Emotional world %>
    <div class="mb-12">
      <h2 class="text-base font-bold mb-3" style="color: <%= phase_colour %>;">Emotional world</h2>
      <div class="border-t border-gray-200 mb-4"></div>
      <% if @content&.mood_text.present? %>
        <p class="text-base font-medium leading-relaxed" style="color: <%= phase_colour %>;">
          <%= @content.mood_text %>
        </p>
      <% end %>
    </div>

    <%# Section 3: That will do you good %>
    <div class="mb-12">
      <h2 class="text-base font-bold mb-3" style="color: <%= phase_colour %>;">That will do you good</h2>
      <div class="border-t border-gray-200 mb-4"></div>
      <% if @content&.take_care_text.present? %>
        <p class="text-base font-medium leading-relaxed" style="color: <%= phase_colour %>;">
          <%= @content.take_care_text %>
        </p>
      <% end %>
    </div>

  </div>
</div>
