<% content_for(:page_title) { @meta[:season] } %>
<% content_for(:header_left) do %>
  <%= link_to informations_path,
        style: "color:#933a35; font-size:15px; font-weight:500; text-decoration:none; padding:8px 4px; font-family:'Montserrat',sans-serif; letter-spacing:0.04em;" do %>
    &lt; back
  <% end %>
<% end %>

<div style="background:#FAF7F4; min-height:100vh; padding-bottom:80px; font-family:'Montserrat',sans-serif;">

  <%# Hero header — phase colour background %>
  <div style="background:<%= @meta[:colour] %>; padding:32px 24px 28px;">
    <div style="max-width:430px; margin:0 auto;">
      <div style="display:flex; align-items:flex-start; justify-content:space-between;">
        <div>
          <p style="color:<%= @meta[:text_colour] %>; font-size:12px; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 6px; opacity:0.8;">
            <%= @meta[:days] %>
          </p>
          <h1 style="color:<%= @meta[:text_colour] %>; font-size:32px; font-weight:700; margin:0 0 4px; line-height:1.1;">
            <%= @meta[:season] %>
          </h1>
          <p style="color:<%= @meta[:text_colour] %>; font-size:16px; font-weight:400; margin:0; opacity:0.9; text-transform:capitalize;">
            <%= @phase %> phase
          </p>
        </div>
        <span style="font-size:52px; line-height:1; margin-top:-4px;"><%= @meta[:emoji] %></span>
      </div>

      <%# Hormone note %>
      <div style="margin-top:20px; background:rgba(255,255,255,0.18); border-radius:10px; padding:12px 14px;">
        <p style="color:<%= @meta[:text_colour] %>; font-size:13px; font-weight:500; margin:0; line-height:1.5; opacity:0.95;">
          🔬 <%= @meta[:hormone_note] %>
        </p>
      </div>
    </div>
  </div>

  <div style="max-width:430px; margin:0 auto; padding:20px 16px 0;">

    <% if @content %>

      <%# ── Emotional world section ── %>
      <div style="background:#FFFFFF; border-radius:16px; padding:20px; margin-bottom:16px; box-shadow:0 2px 8px rgba(0,0,0,0.05);">
        <h2 style="color:#933a35; font-size:16px; font-weight:700; margin:0 0 14px; letter-spacing:0.02em;">
          Emotional world
        </h2>

        <div style="display:flex; flex-direction:column; gap:12px;">
          <%# Superpower %>
          <div style="display:flex; gap:12px; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:<%= @meta[:colour] %>22; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-size:18px;">⚡</span>
            </div>
            <div>
              <p style="color:#933a35; font-size:12px; font-weight:600; margin:0 0 3px; text-transform:uppercase; letter-spacing:0.06em;">Superpower</p>
              <p style="color:#3D3D3D; font-size:14px; font-weight:400; margin:0; line-height:1.5;"><%= @content.superpower_text %></p>
            </div>
          </div>

          <div style="height:1px; background:#F5F0EC;"></div>

          <%# Mood %>
          <div style="display:flex; gap:12px; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:<%= @meta[:colour] %>22; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-size:18px;">💭</span>
            </div>
            <div>
              <p style="color:#933a35; font-size:12px; font-weight:600; margin:0 0 3px; text-transform:uppercase; letter-spacing:0.06em;">Mood</p>
              <p style="color:#3D3D3D; font-size:14px; font-weight:400; margin:0; line-height:1.5;"><%= @content.mood_text %></p>
            </div>
          </div>
        </div>
      </div>

      <%# ── That will do you good section ── %>
      <div style="background:#FFFFFF; border-radius:16px; padding:20px; margin-bottom:16px; box-shadow:0 2px 8px rgba(0,0,0,0.05);">
        <h2 style="color:#933a35; font-size:16px; font-weight:700; margin:0 0 14px; letter-spacing:0.02em;">
          That will do you good
        </h2>

        <div style="display:flex; flex-direction:column; gap:12px;">

          <%# Sport %>
          <div style="display:flex; gap:12px; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:<%= @meta[:colour] %>22; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-size:18px;">🏃</span>
            </div>
            <div>
              <p style="color:#933a35; font-size:12px; font-weight:600; margin:0 0 3px; text-transform:uppercase; letter-spacing:0.06em;">Movement</p>
              <p style="color:#3D3D3D; font-size:14px; font-weight:400; margin:0; line-height:1.5;"><%= @content.sport_text %></p>
            </div>
          </div>

          <div style="height:1px; background:#F5F0EC;"></div>

          <%# Nutrition %>
          <div style="display:flex; gap:12px; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:<%= @meta[:colour] %>22; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-size:18px;">🥗</span>
            </div>
            <div>
              <p style="color:#933a35; font-size:12px; font-weight:600; margin:0 0 3px; text-transform:uppercase; letter-spacing:0.06em;">Nutrition</p>
              <p style="color:#3D3D3D; font-size:14px; font-weight:400; margin:0; line-height:1.5;"><%= @content.nutrition_text %></p>
            </div>
          </div>

          <div style="height:1px; background:#F5F0EC;"></div>

          <%# Self-care %>
          <div style="display:flex; gap:12px; align-items:flex-start;">
            <div style="width:36px; height:36px; border-radius:50%; background:<%= @meta[:colour] %>22; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-size:18px;">🌿</span>
            </div>
            <div>
              <p style="color:#933a35; font-size:12px; font-weight:600; margin:0 0 3px; text-transform:uppercase; letter-spacing:0.06em;">Self-care</p>
              <p style="color:#3D3D3D; font-size:14px; font-weight:400; margin:0; line-height:1.5;"><%= @content.take_care_text %></p>
            </div>
          </div>

        </div>
      </div>

    <% else %>
      <p style="color:#6B6B6B; font-size:14px; text-align:center; margin-top:32px;">No content available yet.</p>
    <% end %>

    <%# Phase navigation %>
    <%
      phases_order = %w[menstrual follicular ovulation luteal]
      current_idx  = phases_order.index(@phase)
      prev_phase   = current_idx > 0 ? phases_order[current_idx - 1] : nil
      next_phase   = current_idx < phases_order.length - 1 ? phases_order[current_idx + 1] : nil
    %>
    <div style="display:flex; justify-content:space-between; gap:12px; margin-top:8px; padding-bottom:8px;">
      <% if prev_phase %>
        <%= link_to informations_phase_path(prev_phase),
              style: "flex:1; background:#FFFFFF; border-radius:12px; padding:12px 16px; text-decoration:none; display:flex; align-items:center; gap:8px; box-shadow:0 1px 4px rgba(0,0,0,0.06);" do %>
          <span style="color:#933a35; font-size:16px;">←</span>
          <span style="color:#933a35; font-size:13px; font-weight:500; text-transform:capitalize;"><%= prev_phase %></span>
        <% end %>
      <% else %>
        <div style="flex:1;"></div>
      <% end %>
      <% if next_phase %>
        <%= link_to informations_phase_path(next_phase),
              style: "flex:1; background:#FFFFFF; border-radius:12px; padding:12px 16px; text-decoration:none; display:flex; align-items:center; justify-content:flex-end; gap:8px; box-shadow:0 1px 4px rgba(0,0,0,0.06);" do %>
          <span style="color:#933a35; font-size:13px; font-weight:500; text-transform:capitalize;"><%= next_phase %></span>
          <span style="color:#933a35; font-size:16px;">→</span>
        <% end %>
      <% else %>
        <div style="flex:1;"></div>
      <% end %>
    </div>

  </div>
</div>
