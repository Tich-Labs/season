<% content_for(:page_title) { "Informations" } %>
<% content_for(:header_dark) { "true" } %>
<% content_for(:header_color) { "#933a35" } %>

<div class="bg-brand-background min-h-screen pb-20">
  <div class="max-w-app mx-auto px-4 pt-6 pb-10">

    <%# Header %>
    <div class="mb-6">
      <h1 class="text-3xl font-semibold text-brand-primary tracking-tight">Your cycle phases</h1>
      <p class="mt-2 text-sm text-brand-secondary max-w-xl">Learn about each phase of your cycle and how it affects your body and mind.</p>
    </div>

    <%# Phase cards %>
    <div class="space-y-4">
      <% @phases.each do |item| %>
        <% meta    = item[:meta] %>
        <% content = item[:content] %>

        <%= link_to informations_phase_path(item[:phase]), class: "block rounded-[26px] overflow-hidden bg-white border border-gray-200 shadow-sm transition hover:shadow-md" do %>
          <div class="p-5" style="background:<%= meta[:colour] %>;">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-white/85 mb-2"><%= meta[:days] %></p>
                <h2 class="text-xl font-bold text-white mb-1"><%= meta[:season] %></h2>
                <p class="text-sm text-white/90 capitalize"><%= item[:phase] %> phase</p>
              </div>
              <span class="text-4xl leading-none"><%= meta[:emoji] %></span>
            </div>
          </div>

          <div class="border-t border-gray-100 p-5">
            <% if content %>
              <p class="text-sm text-brand-secondary"><span class="font-semibold text-brand-primary">Emotional world:</span> <%= content.mood_text %></p>
            <% end %>
            <div class="mt-4 flex justify-end">
              <span class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-primary">Read more →</span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
