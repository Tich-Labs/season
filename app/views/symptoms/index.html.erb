<div style="background:#FAF7F4; min-height:100%; padding-bottom:16px;"
     data-controller="symptom"
     data-symptom-url-value="<%= symptoms_path %>"
     data-date="<%= @date %>">

  <!-- Header -->
  <div style="background:#ffffff; padding:20px 24px 16px; border-bottom:1px solid #EDE1D5;">
    <div style="max-width:430px; margin:0 auto;">
      <div style="display:flex; align-items:center; justify-content:space-between;">
        <a href="<%= tracking_index_path %>" style="color:#933a35; font-size:18px;">&lt; back</a>
        <h1 style="color:#933a35; font-size:20px; font-weight:700;">SYMPTOMS</h1>
        <div style="width:40px;"></div>
      </div>
      <p style="color:#6B6B6B; font-size:14px; text-align:center; margin-top:8px;"><%= @date.strftime("%d %B %Y") %></p>
    </div>
  </div>

  <div style="max-width:430px; margin:0 auto; padding:16px;">

    <!-- Phase indicator -->
    <% if @phase %>
      <div style="background:#ffffff; border-radius:12px; padding:16px; margin-bottom:16px; text-align:center;">
        <p style="color:#6B6B6B; font-size:14px;">You are in</p>
        <p style="color:#933a35; font-size:20px; font-weight:700;"><%= @phase.titleize %> phase</p>
        <% if @season %>
          <p style="color:#6B6B6B; font-size:14px; margin-top:4px;"><%= @season %></p>
        <% end %>
      </div>
    <% end %>

    <!-- Symptom form -->
    <div style="background:#ffffff; border-radius:12px; padding:20px;">
      <div style="display:flex; flex-direction:column; gap:24px;">
        <% [
          ["mood", "Mood", "😊"],
          ["energy", "Energy", "⚡"],
          ["pain", "Pain", "🤕"],
          ["sleep", "Sleep", "😴"],
          ["physical", "Physical", "💪"],
          ["mental", "Mental", "🧠"],
          ["cravings", "Cravings", "🍫"],
          ["discharge", "Discharge", "💧"]
        ].each do |field, label, emoji| %>
          <div class="dot-group">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
              <span style="font-size:18px;"><%= emoji %></span>
              <label style="color:#933a35; font-size:15px; font-weight:600;"><%= label %></label>
            </div>
            <div style="display:flex; gap:6px;">
              <% (1..5).each do |i| %>
                <button class="dot"
                  data-action="click->symptom#save"
                  data-field="<%= field %>"
                  data-value="<%= i %>"
                  style="flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; cursor:pointer; padding:8px; border-radius:8px; background:<%= @log.send(field) == i ? '#FDF0EE' : '#EDE1D5' %>; border:none;">
                  <span style="color:#933a35; font-size:12px; font-weight:500;"><%= i %></span>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Sexual intercourse - toggle -->
        <div class="symptom-row" style="display:flex; justify-content:space-between; align-items:center; padding:12px; background:#EDE1D5; border-radius:8px;">
          <span style="color:#933a35; font-size:15px; font-weight:600;">Sexual intercourse</span>
          <input type="checkbox"
            data-action="change->symptom#save"
            data-field="sexual_intercourse"
            data-value="true"
            <%= @log.sexual_intercourse ? 'checked' : '' %>
            style="width:24px; height:24px; accent-color:#933a35;">
        </div>

        <!-- Notes -->
        <div>
          <label style="color:#933a35; font-size:15px; font-weight:600; display:block; margin-bottom:8px;">
            📝 Notes
          </label>
          <textarea name="symptom_log[notes]" rows="3"
                    placeholder="How are you feeling?"
                    style="width:100%; background:#EDE1D5; border-radius:8px; padding:12px 16px; border:none; font-size:15px; color:#933a35; outline:none; box-sizing:border-box; resize:none;"><%= @log.notes %></textarea>
        </div>
      </div>
    </div>

  </div>
</div>
