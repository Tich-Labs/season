<%
  phase_meta   = CycleCalculatorService::PHASE_META[@phase] || {}
  phase_colour = phase_meta[:colour] || "#933a35"
  phase_label  = @phase ? @phase.capitalize : "Unknown"
  phase_season = phase_meta[:season]

  # Phase-specific symptom name
  discharge_label = @phase == "menstrual" ? "Bleeding" : "vaginal discharge"

  # Completion flags (for checkmarks)
  mood_done         = @log.mood_text.present?
  physical_done     = @log.any_physical_symptom?
  mental_done       = @log.any_mental_symptom?
  discharge_done    = @log.discharge.present?
  bleeding_done     = @log.bleeding.present?
  intercourse_done  = @log.sexual_intercourse?
  cravings_done     = @log.cravings.present?
  sleep_done        = @log.sleep.present?
  temperature_done  = @log.temperature.present?
  weight_done       = @log.weight.present?
  notes_done        = @log.notes.present?
%>
<% content_for(:page_title) { "My Symptoms" } %>
<% content_for(:header_dark) { "true" } %>
<% content_for(:header_color) { phase_colour } %>

<div class="bg-white min-h-screen pb-24"
     data-controller="symptom"
     data-symptom-url-value="<%= symptoms_path %>"
     data-date="<%= @date %>">

  <%# ── Date picker drum ──────────────────────────────────────────────── %>
  <div class="relative flex justify-center pt-6 pb-2" data-controller="date-picker">
    <button class="bg-brand-field rounded-full px-6 py-2 text-brand-primary font-medium text-base
                   flex items-center gap-2 focus:outline-none"
            data-action="click->date-picker#toggle"
            aria-label="Select date">
      <%= @date.strftime("%-d %B") %>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
           stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
        <polyline points="6 9 12 15 18 9" />
      </svg>
    </button>

    <%# Dropdown drum list %>
    <div class="hidden absolute top-12 z-50 bg-brand-field rounded-2xl shadow-xl w-48"
         data-date-picker-target="dropdown">
      <%# Close chevron %>
      <div class="flex justify-end px-4 pt-3 pb-0">
        <button data-action="click->date-picker#close" aria-label="Close date picker"
                class="text-brand-primary focus:outline-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
               stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="18 15 12 9 6 15" />
          </svg>
        </button>
      </div>
      <%# Scrollable date list — 30 days back through today %>
      <ul class="overflow-y-auto max-h-48 text-center pb-3 scrollbar-hide" data-date-picker-target="list" style="scroll-snap-type:y mandatory;">
        <% ((Date.today - 29)..Date.today).each do |d| %>
          <li class="<%= d == @date ? 'bg-white/60 rounded-lg mx-2' : '' %>" style="scroll-snap-align:center;">
            <%= link_to d.strftime("%-d %B"), symptoms_path(date: d),
                  class: "block py-2 font-['Montserrat'] #{d == @date ? 'font-bold text-base text-brand-primary' : 'font-normal text-sm text-brand-primary opacity-50'}",
                  data: (d == @date ? { selected: true } : {}) %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <%# ── Phase label ───────────────────────────────────────────────────── %>
  <div class="text-center pt-6 pb-5">
    <p class="text-brand-primary text-lg font-medium font-['Montserrat']">You are in your</p>
    <p class="font-extrabold text-3xl leading-tight font-['Montserrat']" style="color:<%= phase_colour %>;">
      <%= phase_label %> Phase
    </p>
  </div>

  <%# ── Symptom list (flat accordions) ────────────────────────────────── %>
  <div class="px-5">

    <%# Helper: scale dots row — renders 1-5 buttons for a given field %>
    <%# 1. Mood %>
    <details class="group border-b border-[#F0E8DF]" id="section-mood">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Mood</span>
        </div>
        <% if mood_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>
      <div class="pb-5 grid grid-cols-3 gap-4" role="group" aria-label="Mood picker">
        <% MoodPickerService.all.each do |mood_opt| %>
          <% selected = @log.mood_text == mood_opt[:name] %>
          <% border_colour = mood_opt[:color] %>
          <button class="flex flex-col items-center justify-center gap-2 transition-all duration-150 focus:outline-none"
                  data-action="click->symptom#save" data-field="mood_text" data-value="<%= mood_opt[:name] %>"
                  aria-label="<%= mood_opt[:name] %>" aria-pressed="<%= selected %>"
                  style="cursor:pointer; opacity: <%= selected ? '1' : '0.7' %>; transform: <%= selected ? 'scale(1.1)' : 'scale(1)' %>;">
            <%# Emoji SVG from icons/emojis folder %>
            <div class="w-16 h-16 flex items-center justify-center">
              <%= image_tag "icons/emojis/#{mood_opt[:svg]}", alt: "", class: "w-full h-full" %>
            </div>
            <span class="text-xs font-medium text-center" style="color: <%= border_colour %>;">
              <%= mood_opt[:name] %>
            </span>
          </button>
        <% end %>
      </div>
    </details>

    <%# 2. Physical %>
    <details class="group border-b border-[#F0E8DF]" id="section-physical">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Physical</span>
        </div>
        <% if physical_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>

      <div class="pb-2" role="group" aria-label="Physical symptoms">
        <% SymptomLog::PHYSICAL_SYMPTOMS.each do |symptom| %>
          <%= render "symptoms/symptom_slider_row",
                symptom: symptom,
                val: (@log.physical_symptoms || {})[symptom[:key]],
                log_url: log_physical_symptom_path %>
        <% end %>
      </div>
    </details>

    <%# 3. Mental %>
    <details class="group border-b border-[#F0E8DF]" id="section-mental">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Mental</span>
        </div>
        <% if mental_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>
      <div class="pb-2" role="group" aria-label="Mental symptoms">
        <% SymptomLog::MENTAL_SYMPTOMS.each do |symptom| %>
          <%= render "symptoms/symptom_slider_row",
                symptom: symptom,
                val: (@log.mental_symptoms || {})[symptom[:key]],
                log_url: log_mental_symptom_path %>
        <% end %>
      </div>
    </details>

    <%# 4. vaginal discharge / Bleeding (menstrual phase) %>
    <details class="group border-b border-[#F0E8DF]" id="section-discharge">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;"><%= discharge_label %></span>
        </div>
        <% if discharge_done || bleeding_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>
      <div class="pb-5">
        <% if @phase == "menstrual" %>
          <%# Bleeding flow options (Light, Medium, Heavy, Disaster) %>
          <div class="grid grid-cols-4 gap-4 px-2" role="group" aria-label="Bleeding flow">
            <% BleedingService.all.each_with_index do |bleeding_opt, idx| %>
              <%
                selected = @log.bleeding == bleeding_opt[:name]
                num_small_drops = idx  # 0, 1, 2, 3 small drops
              %>
              <button class="bleeding-btn flex flex-col items-center gap-3 p-3 rounded-2xl transition-all duration-200"
                      data-action="click->symptom#saveBleedingFlow"
                      data-flow="<%= bleeding_opt[:name] %>"
                      data-url="<%= log_bleeding_symptom_path %>"
                      aria-label="<%= bleeding_opt[:name] %> bleeding" aria-pressed="<%= selected %>"
                      style="cursor:pointer; 
                             border: 2px solid <%= selected ? bleeding_opt[:color] : '#EDE1D5' %>; 
                             background: <%= selected ? 'rgba(147, 58, 53, 0.05)' : '#FFFFFF' %>;
                             transform: <%= selected ? 'scale(1.08)' : 'scale(1)' %>;
                             box-shadow: <%= selected ? '0 4px 12px rgba(147, 58, 53, 0.15)' : 'none' %>;">
                
                <%# Droplet visualization — progressive fill with intensity %>
                <div class="relative w-16 h-16 flex items-center justify-center">
                  <%
                    # Main droplet opacity: Light (0.3) → Medium (0.5) → Heavy (0.7) → Disaster (0.9)
                    main_opacity = 0.3 + (idx * 0.2)
                    # Small droplet opacity: Light (0) → Medium (0.5) → Heavy (0.75) → Disaster (1.0)
                    small_opacity = idx > 0 ? 0.5 + ((idx - 1) * 0.25) : 0
                  %>
                  <%# Main droplet — outline to filled progression %>
                  <%= image_tag "m3/bleeding/drop.svg", alt: "", class: "w-6 h-8 absolute", style: "opacity: #{main_opacity};" %>
                  
                  <%# Small droplets — progressively filled based on intensity %>
                  <% if num_small_drops >= 1 %>
                    <% drop1_opacity = 0.5 + (idx > 0 ? 0 : -0.3) %>
                    <%= image_tag "m3/bleeding/drop.svg", alt: "", class: "w-3 h-4 absolute", style: "top: 0px; right: 4px; opacity: #{small_opacity};" %>
                  <% end %>
                  <% if num_small_drops >= 2 %>
                    <%= image_tag "m3/bleeding/drop.svg", alt: "", class: "w-3 h-4 absolute", style: "bottom: 2px; right: 0px; opacity: #{small_opacity};" %>
                  <% end %>
                  <% if num_small_drops >= 3 %>
                    <%= image_tag "m3/bleeding/drop.svg", alt: "", class: "w-3 h-4 absolute", style: "bottom: 2px; left: 0px; opacity: #{small_opacity};" %>
                  <% end %>
                </div>
                
                <%# Label %>
                <span class="text-sm font-semibold text-center w-full leading-tight" 
                      style="color:<%= selected ? bleeding_opt[:color] : '#999' %>; 
                             letter-spacing: 0.3px;
                             transition: color 200ms;">
                  <%= bleeding_opt[:name] %>
                </span>
              </button>
            <% end %>
          </div>
        <% else %>
          <%# Vaginal discharge scale (1-5) for non-menstrual phases %>
          <div class="flex justify-end mb-2">
            <%= link_to "Detail →", symptom_discharge_path,
                  class: "text-xs font-medium", style: "color:#{phase_colour}; text-decoration:none;" %>
          </div>
          <div class="flex gap-2" role="group" aria-label="Vaginal discharge 1 to 5">
            <% (1..5).each do |i| %>
              <% selected = @log.discharge == i; bg = selected ? phase_colour : "#EDE1D5"; fg = selected ? "#ffffff" : "#6B6B6B" %>
              <button class="dot flex-1 py-2.5 rounded-xl text-sm font-bold transition-colors duration-150"
                      data-action="click->symptom#save" data-field="discharge" data-value="<%= i %>"
                      aria-label="Vaginal discharge <%= i %>" aria-pressed="<%= selected %>"
                      style="background:<%= bg %>; color:<%= fg %>; border:none; cursor:pointer;"><%= i %></button>
            <% end %>
          </div>
        <% end %>
      </div>
    </details>

    <%# 5. Sexual intercourse %>
    <div class="border-b border-[#F0E8DF] py-4 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <svg class="shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
             fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <polyline points="9 18 15 12 9 6" />
        </svg>
        <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Sexual Intercourse</span>
      </div>
      <%
        tog_on = @log.sexual_intercourse?
        tog_bg = tog_on ? phase_colour : "#EDE1D5"
        tog_tx = tog_on ? "translate-x-5" : "translate-x-0"
      %>
      <% if intercourse_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      <label class="relative inline-flex items-center cursor-pointer" aria-label="Sexual intercourse">
        <input type="checkbox" class="sr-only"
               data-action="change->symptom#save"
               data-field="sexual_intercourse"
               data-value="true"
               <%= tog_on ? "checked" : "" %>>
        <div class="relative w-11 h-6 rounded-full transition-colors duration-200"
             style="background:<%= tog_bg %>;">
          <span class="absolute top-[2px] left-[2px] w-5 h-5 bg-white rounded-full
                       shadow transition-transform duration-200 <%= tog_tx %>"></span>
        </div>
      </label>
    </div>

    <%# 6. Cravings %>
    <details class="group border-b border-[#F0E8DF]" id="section-cravings">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Cravings</span>
        </div>
        <% if cravings_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>
      <div class="pb-5 flex gap-2" role="group" aria-label="Cravings 1 to 5">
        <% (1..5).each do |i| %>
          <% selected = @log.cravings == i; bg = selected ? phase_colour : "#EDE1D5"; fg = selected ? "#ffffff" : "#6B6B6B" %>
          <button class="dot flex-1 py-2.5 rounded-xl text-sm font-bold transition-colors duration-150"
                  data-action="click->symptom#save" data-field="cravings" data-value="<%= i %>"
                  aria-label="Cravings <%= i %>" aria-pressed="<%= selected %>"
                  style="background:<%= bg %>; color:<%= fg %>; border:none; cursor:pointer;"><%= i %></button>
        <% end %>
      </div>
    </details>

    <%# 7. Sleep %>
    <details class="group border-b border-[#F0E8DF]" id="section-sleep">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Sleep</span>
        </div>
        <% if sleep_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>
      <div class="pb-5 flex gap-2" role="group" aria-label="Sleep 1 to 5">
        <% (1..5).each do |i| %>
          <% selected = @log.sleep == i; bg = selected ? phase_colour : "#EDE1D5"; fg = selected ? "#ffffff" : "#6B6B6B" %>
          <button class="dot flex-1 py-2.5 rounded-xl text-sm font-bold transition-colors duration-150"
                  data-action="click->symptom#save" data-field="sleep" data-value="<%= i %>"
                  aria-label="Sleep <%= i %>" aria-pressed="<%= selected %>"
                  style="background:<%= bg %>; color:<%= fg %>; border:none; cursor:pointer;"><%= i %></button>
        <% end %>
      </div>
    </details>

    <%# 8. Temperature %>
    <details class="group border-b border-[#F0E8DF]" id="section-temperature">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Temperature</span>
        </div>
        <% if temperature_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>
      <div class="pb-5">
        <input id="symptom_temperature" type="number" step="0.1" min="35" max="42" autocomplete="off"
               name="symptom_log[temperature]" data-field="temperature"
               data-action="input->symptom#saveNumber"
               value="<%= @log.temperature %>" placeholder="36.5 °C"
               class="w-full rounded-xl px-4 py-3 text-sm border-0 outline-none font-['Montserrat']"
               style="background:#EDE1D5; color:#3d2b28;">
      </div>
    </details>

    <%# 9. Weight %>
    <details class="group border-b border-[#F0E8DF]" id="section-weight">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Weight</span>
        </div>
        <% if weight_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>
      <div class="pb-5">
        <input id="symptom_weight" type="number" step="0.1" min="30" max="200" autocomplete="off"
               name="symptom_log[weight]" data-field="weight"
               data-action="input->symptom#saveNumber"
               value="<%= @log.weight %>" placeholder="65.0 kg"
               class="w-full rounded-xl px-4 py-3 text-sm border-0 outline-none font-['Montserrat']"
               style="background:#EDE1D5; color:#3d2b28;">
      </div>
    </details>

    <%# 10. Notes regarding today %>
    <details class="group border-b border-[#F0E8DF]" id="section-notes">
      <summary class="flex items-center justify-between py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
        <div class="flex items-center gap-3">
          <svg class="transition-transform duration-200 group-open:rotate-90 shrink-0"
               xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               fill="none" stroke="<%= phase_colour %>" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="font-medium text-[22px] tracking-[0.66px]" style="color:<%= phase_colour %>;">Notes regarding today</span>
        </div>
        <% if notes_done %><%= render 'symptoms/bi_check', colour: phase_colour %><% end %>
      </summary>
      <div class="pb-5">
        <label for="symptom_notes" class="sr-only">Notes regarding today</label>
        <textarea id="symptom_notes" name="symptom_log[notes]" rows="4"
                  placeholder="Enter your notes here..."
                  data-action="input->symptom#saveNotes"
                  aria-label="Notes regarding today"
                  class="w-full rounded-xl px-4 py-3 text-sm border-0 resize-none outline-none font-['Montserrat']"
                  style="background:#EDE1D5; color:#3d2b28;"><%= @log.notes %></textarea>
      </div>
    </details>

    <%# Submit %>
    <div class="pt-6 pb-8">
      <%= link_to tracking_index_path,
            class: "block w-full text-white text-center rounded-lg py-4 text-xl font-medium tracking-wide font-['Montserrat']",
            style: "background:#{phase_colour}; text-decoration:none;" do %>
        Submit
      <% end %>
    </div>

  </div>
</div>
