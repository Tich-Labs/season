<% content_for(:page_title) { "My Symptoms" } %>
<% content_for(:header_left) do %>
  <%= link_to tracking_index_path,
        style: "color:#933a35; font-size:15px; font-weight:500; text-decoration:none; padding:8px 4px; font-family:'Montserrat',sans-serif;" do %>
    &lt; back
  <% end %>
<% end %>

<%
  phase_meta   = CycleCalculatorService::PHASE_META[@phase] || {}
  phase_colour = phase_meta[:colour] || "#933a35"
  phase_season = phase_meta[:season] || ""
%>

<div class="min-h-screen pb-24" style="background:#FAF7F4;"
     data-controller="symptom"
     data-symptom-url-value="<%= symptoms_path %>"
     data-date="<%= @date %>">

  <%# ── Phase colour banner ─────────────────────────────────────────── %>
  <div class="w-full py-5 px-4" style="background:<%= phase_colour %>;">
    <div class="max-w-[430px] mx-auto">
      <% if @phase %>
        <p class="text-white text-xs font-medium opacity-80 mb-0.5 uppercase tracking-wide">
          You are in your
        </p>
        <p class="text-white text-2xl font-bold leading-tight">
          <%= phase_season %> &mdash; <%= @phase.capitalize %>
        </p>
      <% end %>
      <p class="text-white text-sm opacity-70 mt-1">
        <%= @date.strftime("%A, %-d %B %Y") %>
      </p>
    </div>
  </div>

  <div class="max-w-[430px] mx-auto px-4 pt-5">

    <%
      # Accordion sections: [section_id, section_label, emoji, fields]
      # fields: [field_name, label, emoji, type]  type = :scale | :toggle | :discharge
      sections = [
        ["mood", "Mood", "😊", [
          ["mood",    "Mood",   "😊", :scale],
          ["energy",  "Energy", "⚡", :scale],
          ["sleep",   "Sleep",  "😴", :scale]
        ]],
        ["physical", "Physical", "💪", [
          ["pain",               "Pain",              "🤕", :scale],
          ["physical",           "Physical",          "💪", :scale],
          ["cravings",           "Cravings",          "🍫", :scale],
          ["discharge",          "Discharge",         "💧", :discharge],
          ["sexual_intercourse", "Sexual intercourse","❤️", :toggle],
          ["temperature",        "Temperature (°C)",  "🌡️", :number],
          ["weight",             "Weight (kg)",       "⚖️", :number]
        ]],
        ["mental", "Mental", "🧠", [
          ["mental", "Mental", "🧠", :scale]
        ]]
      ]
    %>

    <%# ── Accordion ───────────────────────────────────────────────────── %>
    <div class="flex flex-col gap-3 mb-4">
      <% sections.each do |section_id, section_label, section_emoji, fields| %>
        <details class="group rounded-2xl overflow-hidden" style="background:#ffffff;"
                 <%= "open" if section_id == "mood" %>>
          <summary class="flex justify-between items-center px-5 py-4 cursor-pointer list-none
                          [&::-webkit-details-marker]:hidden select-none"
                   style="color:#3d2b28;">
            <span class="flex items-center gap-2 font-semibold text-base">
              <span aria-hidden="true"><%= section_emoji %></span>
              <%= section_label %>
            </span>
            <%# Chevron rotates when open %>
            <svg class="transition-transform duration-200 group-open:rotate-180"
                 xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                 fill="none" stroke="#933a35" stroke-width="2.5" viewBox="0 0 24 24"
                 aria-hidden="true">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>

          <div class="px-5 pb-5 flex flex-col gap-5 border-t" style="border-color:#F0E8DF;">

            <% fields.each do |field, label, emoji, type| %>
              <% if type == :scale %>
                <div class="dot-group">
                  <div class="flex items-center gap-2 mb-2">
                    <span aria-hidden="true"><%= emoji %></span>
                    <span class="text-sm font-semibold" style="color:#3d2b28;"><%= label %></span>
                  </div>
                  <div class="flex gap-2" role="group" aria-label="<%= label %> rating 1 to 5">
                    <% (1..5).each do |i| %>
                      <%
                        selected = @log.respond_to?(field) && @log.send(field) == i
                        bg = selected ? phase_colour : "#EDE1D5"
                        text_col = selected ? "#ffffff" : "#6B6B6B"
                      %>
                      <button class="dot flex-1 py-2.5 rounded-xl text-sm font-bold
                                     transition-colors duration-150"
                              data-action="click->symptom#save"
                              data-field="<%= field %>"
                              data-value="<%= i %>"
                              aria-label="<%= label %> <%= i %>"
                              aria-pressed="<%= selected %>"
                              style="background:<%= bg %>; color:<%= text_col %>; border:none; cursor:pointer;">
                        <%= i %>
                      </button>
                    <% end %>
                  </div>
                </div>

              <% elsif type == :discharge %>
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-2">
                      <span aria-hidden="true"><%= emoji %></span>
                      <span class="text-sm font-semibold" style="color:#3d2b28;"><%= label %></span>
                    </div>
                    <%= link_to "Detail →",
                          symptom_discharge_path,
                          class: "text-xs font-medium",
                          style: "color:#{phase_colour}; text-decoration:none;" %>
                  </div>
                  <div class="flex gap-2" role="group" aria-label="Discharge rating 1 to 5">
                    <% (1..5).each do |i| %>
                      <%
                        selected = @log.respond_to?(field) && @log.send(field) == i
                        bg = selected ? phase_colour : "#EDE1D5"
                        text_col = selected ? "#ffffff" : "#6B6B6B"
                      %>
                      <button class="dot flex-1 py-2.5 rounded-xl text-sm font-bold
                                     transition-colors duration-150"
                              data-action="click->symptom#save"
                              data-field="<%= field %>"
                              data-value="<%= i %>"
                              aria-label="Discharge <%= i %>"
                              aria-pressed="<%= selected %>"
                              style="background:<%= bg %>; color:<%= text_col %>; border:none; cursor:pointer;">
                        <%= i %>
                      </button>
                    <% end %>
                  </div>
                </div>

              <% elsif type == :number %>
                <div>
                  <div class="flex items-center gap-2 mb-2">
                    <span aria-hidden="true"><%= emoji %></span>
                    <span class="text-sm font-semibold" style="color:#3d2b28;"><%= label %></span>
                  </div>
                  <input type="number"
                         step="0.1"
                         min="0"
                         autocomplete="off"
                         name="symptom_log[<%= field %>]"
                         data-field="<%= field %>"
                         data-action="input->symptom#saveNumber"
                         value="<%= @log.respond_to?(field) ? @log.send(field) : '' %>"
                         placeholder="—"
                         class="w-full rounded-xl px-4 py-3 text-sm border-0 outline-none"
                         style="background:#EDE1D5; color:#3d2b28; font-family:'Montserrat',sans-serif;">
                </div>

              <% elsif type == :toggle %>
                <div class="flex justify-between items-center pt-1">
                  <div class="flex items-center gap-2">
                    <span aria-hidden="true"><%= emoji %></span>
                    <span class="text-sm font-semibold" style="color:#3d2b28;"><%= label %></span>
                  </div>
                  <%
                    tog_on = @log.respond_to?(field) && @log.send(field)
                    tog_bg = tog_on ? phase_colour : "#EDE1D5"
                    tog_tx = tog_on ? "translate-x-5" : "translate-x-0"
                  %>
                  <label class="relative inline-flex items-center cursor-pointer"
                         aria-label="<%= label %>">
                    <input type="checkbox"
                           class="sr-only"
                           data-action="change->symptom#save"
                           data-field="<%= field %>"
                           data-value="true"
                           <%= tog_on ? "checked" : "" %>>
                    <div class="relative w-11 h-6 rounded-full transition-colors duration-200"
                         style="background:<%= tog_bg %>;">
                      <span class="absolute top-[2px] left-[2px] w-5 h-5 bg-white rounded-full
                                   shadow transition-transform duration-200 <%= tog_tx %>"></span>
                    </div>
                  </label>
                </div>
              <% end %>
            <% end %>

          </div>
        </details>
      <% end %>
    </div>

    <%# ── Notes ──────────────────────────────────────────────────────── %>
    <div class="rounded-2xl px-5 py-5 mb-4" style="background:#ffffff;">
      <label class="flex items-center gap-2 text-sm font-semibold mb-3" style="color:#3d2b28;"
             for="symptom_notes">
        <span aria-hidden="true">📝</span> Notes
      </label>
      <textarea id="symptom_notes"
                name="symptom_log[notes]"
                rows="3"
                placeholder="How are you feeling today?"
                data-action="input->symptom#saveNotes"
                class="w-full rounded-xl px-4 py-3 text-sm border-0 resize-none outline-none"
                style="background:#EDE1D5; color:#3d2b28;"><%= @log.notes %></textarea>
    </div>

  </div>
</div>
