<% content_for(:page_title) { "Streaks" } %>

<div class="bg-brand-background min-h-full pb-1">

  <div class="max-w-app mx-auto px-4">

    <!-- Main streak card -->
    <div class="bg-brand-primary rounded-2xl p-7 mb-3 text-center">
      <p class="text-white opacity-70 text-sm font-medium uppercase tracking-wide mb-2">Current Streak</p>
      <div class="flex items-center justify-center gap-3">
        <span class="text-7xl font-bold text-white leading-none">
          <%= @streak.current_streak || 0 %>
        </span>
        <span class="text-5xl">🔥</span>
      </div>
      <p class="text-white opacity-80 text-base mt-2">
        <%= @streak.current_streak.to_i == 1 ? "day" : "days" %> in a row
      </p>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-2 gap-2.5 mb-3">
      <div class="bg-white rounded-xl p-4 text-center">
        <p class="text-brand-secondary text-xs font-medium uppercase letter-spacing-widest mb-2">Best streak</p>
        <p class="text-brand-primary text-3xl font-bold leading-none">
          <%= @streak.longest_streak || 0 %>
        </p>
        <p class="text-brand-secondary text-sm mt-1">days</p>
      </div>
      <div class="bg-white rounded-xl p-4 text-center">
        <p class="text-brand-secondary text-xs font-medium uppercase letter-spacing-widest mb-2">Total flames</p>
        <p class="text-brand-primary text-3xl font-bold leading-none">
          <%= @streak.total_flames || 0 %>
        </p>
        <p class="text-brand-secondary text-sm mt-1">🔥</p>
      </div>
    </div>

    <!-- Milestones -->
    <div class="bg-white rounded-xl p-5 mb-3">
      <h2 class="text-brand-primary text-lg font-bold mb-4">Milestones</h2>
      <div class="grid grid-cols-5 gap-2">
        <% @milestones.each do |milestone| %>
          <% unlocked = @streak.current_streak.to_i >= milestone %>
          <div class="flex flex-col items-center gap-1">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background:<%= unlocked ? '#2E6B3E' : '#EDE1D5' %>;">
              <% if unlocked %>
                <span class="text-white text-base">✓</span>
              <% else %>
                <span class="text-brand-secondary text-xs"><%= milestone %></span>
              <% end %>
            </div>
            <span class="text-xs font-medium" style="color:<%= unlocked ? '#2E6B3E' : '#6B6B6B' %>;"><%= milestone %>d</span>
          </div>
        <% end %>
      </div>
      <% if @next_milestone && @days_to_next %>
        <p class="text-brand-secondary text-sm text-center mt-3">
          <%= @days_to_next %> more days to <%= @next_milestone %>
        </p>
      <% end %>
    </div>

    <!-- CTA -->
    <a href="<%= tracking_index_path %>"
       class="block w-full bg-brand-primary text-white text-center p-4 rounded-xl text-base font-medium no-underline">
      Track today to keep streak
    </a>

  </div>
</div>
