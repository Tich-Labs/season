<div class="bg-white min-h-screen flex flex-col px-8 pt-16 pb-12 max-w-[430px] mx-auto">

  <%# Back %>
  <%= link_to "< back", new_session_path,
      class: "text-[#933a35] text-base font-normal no-underline" %>

  <%# Title %>
  <h1 class="text-[#933a35] text-[36px] font-bold uppercase tracking-[3.24px] text-center leading-tight mt-8">
    CHANGE<br>PASSWORD
  </h1>

  <%# Form %>
  <div class="mt-20 w-full">
    <%= form_with url: user_password_path, method: :post do |f| %>

      <%# Email field %>
      <div class="mb-4">
        <%= f.email_field :email,
            name: "email",
            autofocus: true,
            placeholder: "E-mail...",
            class: "w-full bg-[rgba(237,225,213,0.5)] rounded-lg px-5 h-[52px] text-[22px] font-medium text-[#933a35] placeholder-[rgba(147,58,53,0.5)] border-0 outline-none" %>
      </div>

      <%# Submit %>
      <div class="mt-4">
        <%= f.submit "Forgot password",
            class: "w-full h-[52px] bg-[#933a35] text-white text-[22px] font-medium tracking-[0.66px] rounded-lg border-0 cursor-pointer hover:bg-[#7a2f2a] transition-colors" %>
      </div>

    <% end %>
  </div>

  <%# Sign up link %>
  <div class="w-full text-center mt-6">
    <%= link_to "I am new... Sign in!", new_registration_path,
        class: "text-[#933a35] text-base font-normal no-underline" %>
  </div>

</div>
