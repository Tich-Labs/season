<div class="bg-white min-h-screen flex flex-col items-center px-4 py-16 max-w-app mx-auto">
  <div class="w-full">
    <%= link_to "&lt; back".html_safe, new_session_path, class: "text-brand-primary text-base font-normal no-underline" %>
  </div>

  <div class="w-full mt-10">
    <h1 class="text-brand-primary text-[36px] font-black uppercase tracking-[0.18em] text-center leading-none">
      Change<br>password
    </h1>
  </div>

  <div class="w-full mt-10">
    <%= form_with url: user_password_path, method: :post do |f| %>
      <div class="mt-8">
        <label for="email" class="sr-only">Email</label>
        <%= f.email_field :email,
            id: "email",
            name: "email",
            autofocus: true,
            placeholder: "E-mail...",
            class: "w-full bg-brand-field rounded-2xl px-5 py-4 h-14 text-[22px] font-semibold text-brand-primary placeholder:text-brand-primary placeholder:opacity-50 outline-none",
            aria: { label: "Email address" } %>
      </div>

      <div class="mt-4">
        <%= f.submit "Forgot password",
            class: "w-full h-14 bg-brand-primary text-white text-[22px] font-semibold tracking-[0.03em] rounded-2xl",
            data: { disable_with: "Sending..." } %>
      </div>
    <% end %>
  </div>

  <div class="w-full text-center mt-6">
    <%= link_to "I am new... Sign up!", new_registration_path, class: "text-brand-primary text-base font-normal no-underline" %>
  </div>
</div>
