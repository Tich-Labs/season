<div class="bg-white min-h-screen flex flex-col items-center justify-between pt-16 pb-12 px-8 max-w-app mx-auto">

  <div></div>

  <div class="w-full flex flex-col items-center">
    <div class="w-55 h-55 rounded-full bg-brand-field overflow-hidden mb-10">
      <%= image_tag("error_screens_login/errorscreen-inbox-full.png", alt: "Inbox full", class: "w-full h-full object-contain") %>
    </div>

    <p class="text-brand-primary text-lg font-normal text-center max-w-72 mb-12">
      Your email inbox is full and isn't accepting our emails
    </p>

    <div class="w-full">
      <a href="<%= new_session_path %>" class="block w-80 h-13 bg-brand-primary text-white text-center leading-13 text-xl font-medium rounded-lg mx-auto no-underline">Go back to login</a>
    </div>
  </div>

  <div></div>

</div>
