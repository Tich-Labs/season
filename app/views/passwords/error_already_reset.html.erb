<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:60px 32px 48px; max-width:430px; margin:0 auto; text-align:center;">

  <!-- Illustration -->
  <div style="width:200px; height:200px; border-radius:50%; background:#F5EDE8; display:flex; align-items:center; justify-content:center; margin-bottom:40px; overflow:hidden;">
    <%= image_tag "error_screens_login/Error-screen already reset password.png",
        alt: "Already reset",
        style: "width:100%; height:100%; object-fit:cover;" %>
  </div>

  <!-- Message -->
  <p style="color:#933a35; font-size:16px; font-weight:400; line-height:1.6; max-width:300px; margin-bottom:48px;">
    We already sent you an email an hour ago to help you reset your password; you'll need to wait an hour before you can try again
  </p>

  <!-- Button -->
  <div style="width:100%;">
    <a href="<%= new_session_path %>"
       style="display:block; width:100%; height:52px; background:#933a35; color:#ffffff; text-align:center; line-height:52px; font-size:18px; font-weight:500; text-decoration:none; border-radius:8px;">
      Go back to login
    </a>
  </div>

</div>
