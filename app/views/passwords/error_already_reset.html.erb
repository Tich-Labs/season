<div class="bg-white min-h-screen flex flex-col items-center justify-center px-8 py-16 max-w-[430px] mx-auto text-center">

  <%# Illustration %>
  <div class="w-[220px] h-[220px] rounded-full bg-[#ede1d5] overflow-hidden mb-10 flex-shrink-0">
    <%= image_tag "error_screens_login/errorscreen-already-reset.png",
        alt: "Already reset",
        class: "w-full h-full object-cover" %>
  </div>

  <%# Message %>
  <p class="text-[#933a35] text-[18px] font-normal tracking-[1.62px] leading-snug max-w-[290px] mb-12">
    We already sent you an email an hour ago to help you reset your password; you'll need to wait an hour before you can try again
  </p>

  <%# Button %>
  <div class="w-full">
    <%= link_to "Go back to login", new_session_path,
        class: "block w-full h-[52px] bg-[#933a35] text-white text-center leading-[52px] text-[22px] font-medium tracking-[0.66px] no-underline rounded-lg hover:bg-[#7a2f2a] transition-colors" %>
  </div>

</div>
