<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:60px 32px 48px; max-width:430px; margin:0 auto;">

  <!-- Logo -->
  <div style="display:flex; justify-content:center; margin-bottom:48px;">
    <%= image_tag "screen1logo.png", alt: "Season", style: "width:200px; height:auto;" %>
  </div>

  <!-- Message -->
  <h1 style="color:#933a35; font-size:30px; font-weight:700; text-align:center; line-height:1.3; margin-bottom:48px;">
    Check your<br>E-Mail inbox
  </h1>

  <!-- Back to login button -->
  <div style="width:100%;">
    <a href="<%= new_session_path %>" style="display:block; width:100%; height:52px; background:#933a35; color:#ffffff; text-align:center; line-height:52px; font-size:18px; font-weight:500; text-decoration:none; border-radius:8px;">
      Back to LogIn
    </a>
  </div>

</div>
