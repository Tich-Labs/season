<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:space-between; padding:60px 32px 48px; max-width:430px; margin:0 auto;">

  <%# Logo %>
  <div style="width:100%; display:flex; justify-content:center;">
    <img src="<%= asset_path('screen1logo.png') %>" alt="Season" style="width:234px; height:auto;">
  </div>

  <%# Message %>
  <div style="width:100%;">
    <h1 style="color:#933a35; font-size:36px; font-weight:700; text-align:center; letter-spacing:3.24px;">
      Check your<br>E-Mail inbox
    </h1>
  </div>

  <%# Button %>
  <div style="width:100%;">
    <a href="<%= new_session_path %>" style="display:block; width:322px; height:52px; background:#933a35; color:#ffffff; text-align:center; line-height:52px; font-size:22px; font-weight:500; letter-spacing:0.66px; text-decoration:none; border-radius:8px; margin:0 auto;">Back to LogIn</a>
  </div>

</div>
