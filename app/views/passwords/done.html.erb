<div class="bg-white min-h-screen flex flex-col items-center justify-center px-8 py-16 max-w-[430px] mx-auto">

  <%# Logo %>
  <div class="flex justify-center mb-12">
    <%= image_tag "screen1logo.png", alt: "Season", class: "w-[234px] h-auto" %>
  </div>

  <%# Message %>
  <h1 class="text-[#933a35] text-[36px] font-bold text-center tracking-[3.24px] leading-snug mb-12">
    Check your<br>E-Mail inbox
  </h1>

  <%# Button %>
  <div class="w-full">
    <%= link_to "Back to LogIn", new_session_path,
        class: "block w-full h-[52px] bg-[#933a35] text-white text-center leading-[52px] text-[22px] font-medium tracking-[0.66px] no-underline rounded-lg hover:bg-[#7a2f2a] transition-colors" %>
  </div>

</div>
