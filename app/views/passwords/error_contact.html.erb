<div class="bg-white min-h-screen flex flex-col justify-between p-16 pt-28 pb-12 max-w-app mx-auto">

  <%# Empty top for spacing %>
  <div></div>

  <%# Content centered %>
  <div class="w-full flex flex-col items-center">
    <div class="w-64 h-64 rounded-full bg-brand-field overflow-hidden mb-10">
      <%= image_tag("error_screens_login/errorscreen-contact-support.png", alt: "Contact support", class: "w-full h-full object-contain") %>
    </div>

    <p class="text-brand-primary text-lg font-normal letter-spacing-wide text-center max-w-xs mb-12">
      Something seems off here—please contact our support team!
    </p>

    <div class="w-full mb-4">
      <a href="mailto:info@season.vision" class="block w-64 h-12 bg-brand-primary text-white text-center leading-12 text-2xl font-medium letter-spacing-wider no-underline rounded-lg mx-auto">contact support</a>
    </div>

    <a href="<%= new_session_path %>" class="text-brand-primary text-base font-normal no-underline">Go back to LogIn</a>
  </div>

  <%# Empty bottom for spacing %>
  <div></div>

</div>
