<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:space-between; padding:60px 32px 48px; max-width:430px; margin:0 auto;">

  <%# Empty top for spacing %>
  <div></div>

  <%# Content centered %>
  <div style="width:100%; display:flex; flex-direction:column; align-items:center;">
    <div style="width:220px; height:220px; border-radius:110px; background:#ede1d5; overflow:hidden; margin-bottom:40px;">
      <img src="<%= asset_path('error_screens_login/errorscreen-contact-support.png') %>" alt="Contact support" style="width:100%; height:100%; object-fit:cover;">
    </div>

    <p style="color:#933a35; font-size:18px; font-weight:400; letter-spacing:1.62px; text-align:center; max-width:290px; margin-bottom:48px;">
      Something seems off here—please contact our support team!
    </p>

    <div style="width:100%; margin-bottom:16px;">
      <a href="mailto:support@season.vision" style="display:block; width:322px; height:52px; background:#933a35; color:#ffffff; text-align:center; line-height:52px; font-size:22px; font-weight:500; letter-spacing:0.66px; text-decoration:none; border-radius:8px; margin:0 auto;">contact support</a>
    </div>

    <a href="<%= new_session_path %>" style="color:#933a35; font-size:16px; font-weight:400; text-decoration:none;">Go back to LogIn</a>
  </div>

  <%# Empty bottom for spacing %>
  <div></div>

</div>
