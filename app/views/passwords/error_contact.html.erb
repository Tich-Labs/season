<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:60px 32px 48px; max-width:430px; margin:0 auto; text-align:center;">

  <!-- Illustration -->
  <div style="width:200px; height:200px; border-radius:50%; background:#F5EDE8; display:flex; align-items:center; justify-content:center; margin-bottom:40px; overflow:hidden;">
    <%= image_tag "error_screens_login/Error Screen contact support.png",
        alt: "Contact support",
        style: "width:100%; height:100%; object-fit:cover;" %>
  </div>

  <!-- Message -->
  <p style="color:#933a35; font-size:16px; font-weight:400; line-height:1.6; max-width:300px; margin-bottom:48px;">
    Something seems off here—please contact our support team!
  </p>

  <!-- Contact support button -->
  <div style="width:100%; margin-bottom:16px;">
    <a href="mailto:support@season.app"
       style="display:block; width:100%; height:52px; background:#933a35; color:#ffffff; text-align:center; line-height:52px; font-size:18px; font-weight:500; text-decoration:none; border-radius:8px; letter-spacing:0.5px;">
      contact support
    </a>
  </div>

  <!-- Back link -->
  <a href="<%= new_session_path %>"
     style="color:#933a35; font-size:16px; font-weight:400; text-decoration:none;">
    Go back to LogIn
  </a>

</div>
