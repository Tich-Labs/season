<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:space-between; padding:60px 32px 48px; max-width:430px; margin:0 auto;">

  <%# Back %>
  <div style="width:100%;">
    <a href="<%= new_session_path %>" style="color:#933a35; font-size:16px; font-weight:400; text-decoration:none;">&lt; back</a>
  </div>

  <%# Title %>
  <div style="width:100%;">
    <h1 style="color:#933a35; font-size:36px; font-weight:700; text-transform:uppercase; letter-spacing:3.24px; text-align:center;">
      NEW<br>PASSWORD
    </h1>
  </div>

  <%# Form %>
  <div style="width:100%;">
    <%= form_with url: user_password_path, method: :patch do |f| %>
      <%= hidden_field_tag :token, params[:token] %>

      <% if @user&.errors&.any? %>
        <div style="background:#FDF0EE; border-radius:12px; padding:12px 16px; margin-top:24px; font-size:14px; color:#933a35;">
          <%= @user.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <div style="margin-top:29px;">
        <label for="password" class="sr-only">New password</label>
        <%= f.password_field :password,
            id: "password",
            name: "password",
            autofocus: true,
            placeholder: "New password...",
            style: "width:100%; background:#EDE1D5; border-radius:8px; padding:14px 21px; height:52px; border:none; font-size:22px; font-weight:500; color:#933a35; outline:none; box-sizing:border-box;",
            "aria-label": "New password" %>
      </div>

      <div style="margin-top:16px;">
        <%= f.submit "Save new password",
            style: "width:322px; height:52px; background:#933a35; color:#ffffff; font-size:22px; font-weight:500; letter-spacing:0.66px; border-radius:8px; border:none; cursor:pointer;",
            "data-disable-with": "Saving..." %>
      </div>
    <% end %>
  </div>

</div>