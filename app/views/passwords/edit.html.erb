<div style="background:#ffffff; min-height:100vh; display:flex; flex-direction:column; padding:60px 32px 48px; max-width:430px; margin:0 auto;">

  <!-- Back -->
  <div style="width:100%;">
    <a href="<%= new_session_path %>" style="color:#933a35; text-decoration:none; font-size:16px; font-weight:400;">
      &lt; back
    </a>
  </div>

  <!-- Title -->
  <div style="width:100%; text-align:center; margin-top:32px;">
    <h1 style="color:#933a35; font-size:36px; font-weight:700; text-transform:uppercase; letter-spacing:3px; line-height:1.15;">
      NEW<br>PASSWORD
    </h1>
  </div>

  <!-- Form -->
  <div style="width:100%; margin-top:80px;">
    <%= form_for(resource, as: resource_name, url: user_password_path, html: { method: :put }) do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <% if resource.errors.any? %>
        <div style="background:#FDF0EE; border-radius:8px; padding:12px 16px; margin-bottom:16px;">
          <p style="color:#933a35; font-size:28px; font-weight:700; margin-bottom:8px;">OOPS!</p>
          <p style="color:#933a35; font-size:16px; font-weight:400;"><%= resource.errors.full_messages.join(", ") %></p>
        </div>
      <% end %>

      <!-- New Password -->
      <div style="margin-bottom:16px;">
        <%= f.password_field :password,
            autofocus: true,
            placeholder: "New password...",
            style: "width:100%; background:#EDE1D5; border-radius:8px; padding:14px 21px; height:52px; border:none; font-size:22px; font-weight:500; color:#933a35; outline:none; box-sizing:border-box;" %>
      </div>

      <!-- Confirm Password -->
      <div style="margin-bottom:16px;">
        <%= f.password_field :password_confirmation,
            placeholder: "Confirm new password...",
            style: "width:100%; background:#EDE1D5; border-radius:8px; padding:14px 21px; height:52px; border:none; font-size:22px; font-weight:500; color:#933a35; outline:none; box-sizing:border-box;" %>
      </div>

      <!-- Submit -->
      <div style="margin-top:16px;">
        <%= f.submit "Save new password",
            style: "width:100%; height:52px; background:#933a35; color:#ffffff; font-size:18px; font-weight:500; letter-spacing:0.5px; border-radius:8px; border:none; cursor:pointer;" %>
      </div>

    <% end %>
  </div>

</div>