<div class="bg-white min-h-screen flex flex-col items-center justify-between py-[60px] px-8 max-w-app mx-auto">

  <div class="w-full">
    <%= link_to "< back", new_session_path, class: "text-brand-primary text-base font-normal no-underline" %>
  </div>

  <div class="w-full">
    <h1 class="text-brand-primary text-[36px] font-bold uppercase tracking-[3.24px] text-center leading-tight">
      NEW<br>PASSWORD
    </h1>
  </div>

  <div class="w-full">
    <%= form_with url: user_password_path, method: :patch do |f| %>
      <%= hidden_field_tag :reset_password_token, params[:reset_password_token] %>
      <%# Tells the browser which account this password belongs to %>
      <input type="hidden" autocomplete="username" value="<%= @user&.email %>">

      <% if @user&.errors&.any? %>
        <div class="bg-brand-error rounded-xl px-4 py-3 mt-6 text-sm text-brand-primary">
          <%= @user.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <div class="mt-[29px] relative" data-controller="password-visibility">
        <label for="password" class="sr-only">New password</label>
        <%= f.password_field :password,
            autofocus: true,
            placeholder: "New password...",
            autocomplete: "new-password",
            class: "w-full bg-brand-field rounded-lg px-[21px] pr-[50px] h-[52px] text-[22px] font-medium text-brand-primary outline-none border-0 box-border",
            "aria-label": "New password",
            data: { "password-visibility-target": "input" } %>
        <button type="button" aria-label="Toggle password visibility" data-action="click->password-visibility#toggle" class="absolute right-4 top-1/2 -translate-y-1/2 bg-transparent border-0 p-0 cursor-pointer">
          <svg data-password-visibility-target="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
          <svg data-password-visibility-target="eyeClosed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
        </button>
      </div>

      <div class="mt-4 relative" data-controller="password-visibility">
        <label for="password_confirmation" class="sr-only">Confirm new password</label>
        <%= f.password_field :password_confirmation,
            placeholder: "Confirm password...",
            autocomplete: "new-password",
            class: "w-full bg-brand-field rounded-lg px-[21px] pr-[50px] h-[52px] text-[22px] font-medium text-brand-primary outline-none border-0 box-border",
            "aria-label": "Confirm new password",
            data: { "password-visibility-target": "input" } %>
        <button type="button" aria-label="Toggle password visibility" data-action="click->password-visibility#toggle" class="absolute right-4 top-1/2 -translate-y-1/2 bg-transparent border-0 p-0 cursor-pointer">
          <svg data-password-visibility-target="eyeOpen" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
          <svg data-password-visibility-target="eyeClosed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(147,58,53,0.5)" stroke-width="1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
        </button>
      </div>

      <div class="mt-4">
        <%= f.submit "Save new password",
            class: "w-[322px] h-[52px] bg-brand-primary text-white text-[22px] font-medium tracking-[0.66px] rounded-lg border-0 cursor-pointer block mx-auto",
            "data-disable-with": "Saving..." %>
      </div>
    <% end %>
  </div>

</div>
