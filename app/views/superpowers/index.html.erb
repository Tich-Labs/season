<% content_for(:page_title) { "Superpowers" } %>
<% content_for(:header_left) do %>
  <%= link_to tracking_index_path, class: "text-brand-primary text-sm font-medium no-underline p-2 font-montserrat" do %>
    &lt; back
  <% end %>
<% end %>

<div class="bg-brand-background min-h-full pb-1">

  <div class="max-w-app mx-auto px-4">

    <!-- Log today's superpowers -->
    <div class="bg-white rounded-xl p-5 mb-3">
      <h2 class="text-brand-primary text-lg font-bold mb-5">Today's superpowers</h2>

      <%= form_with url: superpowers_path, method: :post, local: true do |f| %>
        <% superpowers = [
          ["creativity",    "Creativity",    "🎨"],
          ["intuition",     "Intuition",     "🔮"],
          ["communication", "Communication", "💬"],
          ["focus",         "Focus",         "🎯"],
          ["empathy",       "Empathy",       "❤️"],
          ["leadership",    "Leadership",    "👑"],
          ["productivity",  "Productivity",  "⚡"],
          ["sensuality",    "Sensuality",    "🌸"]
        ] %>

        <div class="flex flex-col gap-5">
          <% superpowers.each do |field, label, emoji| %>
            <div>
              <div class="flex items-center gap-2 mb-2.5">
                <span class="text-lg"><%= emoji %></span>
                <label class="text-brand-primary text-sm font-semibold"><%= label %></label>
              </div>
              <div class="flex gap-2">
                <% 5.times do |i| %>
                  <label class="flex-1 flex flex-col items-center gap-1 cursor-pointer">
                    <input type="radio" name="ratings[<%= field %>]" value="<%= i+1 %>"
                           class="w-5 h-5" style="accent-color:#933a35;">
                    <span class="text-brand-secondary text-xs"><%= i+1 %></span>
                  </label>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <button type="submit"
                class="block w-full bg-brand-primary text-white text-center p-4 rounded-xl text-base font-medium border-none cursor-pointer mt-6">
          Save Superpowers
        </button>
      <% end %>
    </div>

    <!-- Recent logs -->
    <% if @superpower_logs&.any? %>
      <div class="bg-white rounded-xl p-5">
        <h2 class="text-brand-primary text-lg font-bold mb-4">Recent logs</h2>
        <div class="flex flex-col gap-2">
          <% @superpower_logs.last(7).reverse.each do |log| %>
            <a href="<%= superpower_path(log) %>"
               class="flex justify-between items-center p-3 bg-brand-background rounded-lg no-underline">
              <span class="text-brand-primary text-sm font-medium"><%= log.date.strftime("%d %b") %></span>
              <% if log.ratings.present? %>
                <span class="text-brand-secondary text-xs"><%= log.ratings.size %> rated</span>
              <% end %>
              <svg xmlns="http://www.w3.org/2000/svg" width="4" height="4" fill="none" stroke="#933a35" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>
