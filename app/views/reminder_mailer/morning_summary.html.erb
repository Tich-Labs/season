<table width="100%" cellpadding="0" cellspacing="0" style="background:#FAF7F4; padding:32px 16px;">
  <tr><td align="center">
    <table width="100%" cellpadding="0" cellspacing="0" style="max-width:480px;">

      <%# Header %>
      <tr><td style="background:<%= @phase_meta[:colour] %>; border-radius:16px 16px 0 0; padding:28px 28px 24px; text-align:center;">
        <p style="color:rgba(255,255,255,0.8); font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 6px;">
          <%= Date.today.strftime("%A, %B %-d") %>
        </p>
        <h1 style="color:#FFFFFF; font-size:24px; font-weight:700; margin:0 0 4px; line-height:1.2;">
          Good morning, <%= @user.name.split.first %> 🌸
        </h1>
        <p style="color:rgba(255,255,255,0.85); font-size:14px; font-weight:400; margin:0;">
          Here's your Season summary for today
        </p>
      </td></tr>

      <%# Phase banner %>
      <tr><td style="background:#FFFFFF; padding:20px 28px; border-bottom:1px solid #EDE1D5;">
        <table width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td>
              <p style="color:#6B6B6B; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; margin:0 0 4px;">Your cycle phase</p>
              <p style="color:<%= @phase_meta[:colour] %>; font-size:20px; font-weight:700; margin:0;">
                <%= @phase.capitalize %> · <%= @phase_meta[:season] %>
              </p>
              <% if @cycle_day %>
                <p style="color:#6B6B6B; font-size:13px; font-weight:400; margin:4px 0 0;">
                  Day <%= @cycle_day %> of your cycle
                </p>
              <% end %>
            </td>
            <td align="right" width="56">
              <div style="width:52px; height:52px; border-radius:50%; background:<%= @phase_meta[:colour] %>; display:flex; align-items:center; justify-content:center;">
                <span style="color:#FFFFFF; font-size:22px; line-height:52px; display:block; text-align:center;">
                  <%= {"menstrual" => "🌙", "follicular" => "🌱", "ovulation" => "☀️", "luteal" => "🍂"}[@phase] %>
                </span>
              </div>
            </td>
          </tr>
        </table>
      </td></tr>

      <%# Tips grid %>
      <tr><td style="background:#FFFFFF; padding:20px 28px; border-bottom:1px solid #EDE1D5;">
        <p style="color:#6B6B6B; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; margin:0 0 14px;">Today's focus</p>
        <table width="100%" cellpadding="0" cellspacing="0">
          <% [
            ["⚡", "Superpower", {"menstrual" => "Rest & reflect", "follicular" => "New beginnings", "ovulation" => "Connect & create", "luteal" => "Analyse & plan"}[@phase]],
            ["🏃", "Movement", {"menstrual" => "Gentle yoga or walking", "follicular" => "HIIT & strength training", "ovulation" => "High-intensity cardio", "luteal" => "Moderate, steady exercise"}[@phase]],
            ["🥗", "Nutrition", {"menstrual" => "Iron-rich foods & warmth", "follicular" => "Light, fresh foods", "ovulation" => "Raw & vibrant foods", "luteal" => "Complex carbs & magnesium"}[@phase]]
          ].each do |icon, label, tip| %>
            <tr>
              <td style="padding:8px 0; border-bottom:1px solid #EDE1D5; vertical-align:top;" width="36">
                <span style="font-size:20px;"><%= icon %></span>
              </td>
              <td style="padding:8px 0 8px 10px; border-bottom:1px solid #EDE1D5; vertical-align:top;">
                <p style="color:#933a35; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; margin:0 0 2px;"><%= label %></p>
                <p style="color:#3d2b28; font-size:14px; font-weight:500; margin:0;"><%= tip %></p>
              </td>
            </tr>
          <% end %>
        </table>
      </td></tr>

      <%# CTA %>
      <tr><td style="background:#FFFFFF; padding:20px 28px; border-radius:0 0 16px 16px; text-align:center;">
        <a href="<%= root_url %>"
           style="display:inline-block; background:#933a35; color:#FFFFFF; text-decoration:none; font-size:15px; font-weight:600; padding:14px 32px; border-radius:12px; letter-spacing:0.02em;">
          Open Season
        </a>
        <p style="color:#6B6B6B; font-size:12px; margin:16px 0 0;">
          You're receiving this because you enabled morning reminders in Season.
          <%= link_to "Manage reminders", notifications_settings_url, style: "color:#933a35;" %>
        </p>
      </td></tr>

    </table>
  </td></tr>
</table>
