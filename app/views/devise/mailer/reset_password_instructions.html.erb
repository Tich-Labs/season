<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #FAF7F4;">
  <tr>
    <td align="center" style="padding: 48px 20px;">

      <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 480px;">

        <%# Wordmark %>
        <tr>
          <td align="center" style="padding-bottom: 28px;">
            <span style="font-family: Georgia, 'Times New Roman', serif; font-size: 30px; font-weight: bold; color: #933a35; letter-spacing: 0.06em;">Season</span>
          </td>
        </tr>

        <%# Card %>
        <tr>
          <td style="background-color: #ffffff; border-radius: 20px; padding: 40px 36px;">

            <p style="margin: 0 0 8px; font-size: 20px; font-weight: 600; color: #3d2b28;">
              Reset your password
            </p>

            <p style="margin: 0 0 28px; font-size: 15px; color: #6B6B6B; line-height: 1.6;">
              Hi <%= @resource.email %> — someone requested a password reset for your Season account.
            </p>

            <%# Button %>
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td align="center" style="padding-bottom: 28px;">
                  <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>"
                     style="display: inline-block; background-color: #933a35; color: #ffffff; font-size: 16px; font-weight: 600; text-decoration: none; padding: 15px 44px; border-radius: 12px; letter-spacing: 0.01em;">
                    Reset my password
                  </a>
                </td>
              </tr>
            </table>

            <p style="margin: 0 0 16px; font-size: 13px; color: #6B6B6B; line-height: 1.6;">
              This link expires in <strong>6 hours</strong>. If you didn't request a reset, you can safely ignore this email — your password won't change.
            </p>

            <%# Fallback link %>
            <p style="margin: 0; font-size: 12px; color: #9e9e9e; line-height: 1.5; word-break: break-all;">
              Button not working? Copy and paste this link into your browser:<br>
              <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>"
                 style="color: #933a35; text-decoration: underline;">
                <%= edit_password_url(@resource, reset_password_token: @token) %>
              </a>
            </p>

          </td>
        </tr>

        <%# Footer %>
        <tr>
          <td align="center" style="padding-top: 24px;">
            <p style="margin: 0; font-size: 12px; color: #9e9e9e;">
              &copy; <%= Time.current.year %> Season &nbsp;&middot;&nbsp; <a href="mailto:info@season.vision" style="color: #9e9e9e; text-decoration: none;">info@season.vision</a>
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
