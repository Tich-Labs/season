<div class="text-center mb-8">
  <h1 class="font-serif text-3xl text-season-charcoal mb-2">Create Account</h1>
  <p class="text-gray-500">Start tracking your cycle today</p>
</div>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "Email", class: "form-input rounded-xl" %>
  </div>

  <div>
    <%= f.password_field :password, autocomplete: "new-password", placeholder: "Password (#{@minimum_password_length} characters min)", class: "form-input rounded-xl" %>
  </div>

  <div>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm password", class: "form-input rounded-xl" %>
  </div>

  <%= f.submit "Sign up", class: "btn-primary w-full" %>
<% end %>

<div class="mt-6 text-center">
  <p class="text-gray-500">Already have an account? <%= link_to "Sign in", new_session_path(resource_name), class: "text-season-terra font-medium" %></p>
</div>
