<div class="min-h-screen bg-white flex flex-col px-6 max-w-sm mx-auto w-full">

  <!-- Header -->
  <div class="pt-16 pb-8">
    <h1 class="text-3xl font-bold text-[#933a35] uppercase tracking-widest text-center">
      <%= t('devise.registrations.new.title', default: 'Sign Up') %>
    </h1>
  </div>

  <!-- Form -->
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <!-- Name -->
    <div class="mb-3">
      <%= f.text_field :name,
          autofocus: true,
          placeholder: t('devise.registrations.new.name_placeholder', default: 'Name...'),
          class: "w-full bg-[#F5EDE8] rounded-xl px-4 min-h-[56px] border-none text-base placeholder:text-[#C4A79A] outline-none" %>
    </div>

    <!-- Email -->
    <div class="mb-3">
      <%= f.email_field :email,
          placeholder: t('devise.registrations.new.email_placeholder', default: 'E-mail...'),
          class: "w-full bg-[#F5EDE8] rounded-xl px-4 min-h-[56px] border-none text-base placeholder:text-[#C4A79A] outline-none" %>
    </div>

    <!-- Password -->
    <div class="mb-3">
      <%= f.password_field :password,
          placeholder: t('devise.registrations.new.password_placeholder', default: 'Password...'),
          class: "w-full bg-[#F5EDE8] rounded-xl px-4 min-h-[56px] border-none text-base placeholder:text-[#C4A79A] outline-none" %>
    </div>

    <!-- Terms -->
    <div class="flex items-start gap-3 mb-8 mt-2">
      <input type="checkbox" required name="terms_accepted"
        class="mt-1 w-5 h-5 accent-[#933a35]">
      <span class="text-sm text-[#6B6B6B]">
        <%= t('devise.registrations.new.terms', default: "I'll accept the terms and privacy policy") %>
      </span>
    </div>

    <!-- Submit -->
    <div class="mt-auto mb-8">
      <%= f.submit t('devise.registrations.new.submit', default: 'Create account'),
          class: "w-full bg-[#933a35] text-white rounded-xl min-h-[56px] font-semibold text-base cursor-pointer border-none" %>
    </div>
  <% end %>

  <!-- Login link -->
  <div class="text-center mb-8">
    <%= link_to t('devise.registrations.new.have_account', default: 'I already have an account'), 
        new_user_session_path,
        class: "text-[#933a35] font-semibold" %>
  </div>

</div>
