<div class="min-h-screen bg-white flex flex-col px-6 max-w-sm mx-auto w-full">

  <!-- Header -->
  <div class="pt-16 pb-8">
    <h1 class="text-3xl font-bold text-[#933a35] uppercase tracking-widest text-center">
      <%= t('devise.passwords.new.title', default: 'Reset Password') %>
    </h1>
  </div>

  <!-- Form -->
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <!-- Email -->
    <div class="mb-6">
      <%= f.email_field :email,
          autofocus: true,
          placeholder: t('devise.passwords.new.email_placeholder', default: 'E-mail...'),
          class: "w-full bg-[#F5EDE8] rounded-xl px-4 min-h-[56px] border-none text-base placeholder:text-[#C4A79A] outline-none" %>
    </div>

    <!-- Submit -->
    <div class="mt-auto mb-8">
      <%= f.submit t('devise.passwords.new.submit', default: 'Send password reset instructions'),
          class: "w-full bg-[#933a35] text-white rounded-xl min-h-[56px] font-semibold text-base cursor-pointer border-none" %>
    </div>
  <% end %>

  <!-- Back to Sign In -->
  <div class="text-center mb-8">
    <%= link_to t('devise.passwords.new.back_to_sign_in', default: 'Back to Log In'), 
        new_user_session_path,
        class: "text-[#933a35] font-semibold" %>
  </div>

</div>
