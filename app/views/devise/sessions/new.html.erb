<div class="text-center mb-8">
  <h1 class="font-serif text-3xl text-season-charcoal mb-2">Welcome Back</h1>
  <p class="text-gray-500">Sign in to continue</p>
</div>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
  <div>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "Email", class: "form-input rounded-xl" %>
  </div>

  <div>
    <%= f.password_field :password, autocomplete: "current-password", placeholder: "Password", class: "form-input rounded-xl" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center">
      <%= f.check_box :remember_me, class: "w-4 h-4 text-season-terra border-gray-300 rounded focus:ring-season-terra" %>
      <%= f.label :remember_me, "Remember me", class: "ml-2 text-sm text-gray-600" %>
    </div>
  <% end %>

  <%= f.submit "Sign in", class: "btn-primary w-full" %>
<% end %>

<div class="mt-6 text-center">
  <p class="text-gray-500">Don't have an account? <%= link_to "Sign up", new_registration_path(resource_name), class: "text-season-terra font-medium" %></p>
</div>
