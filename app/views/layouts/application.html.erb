<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Season" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path %>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/icon.png">
    <meta name="theme-color" content="#933a35">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script nonce="<%= content_security_policy_nonce %>">
      const clearOldServiceWorkers = async () => {
        if (!('serviceWorker' in navigator)) return;

        const registrations = await navigator.serviceWorker.getRegistrations();
        await Promise.all(registrations.map((registration) => registration.unregister()));
        if ('caches' in window) {
          const names = await caches.keys();
          await Promise.all(names.map((name) => caches.delete(name)));
        }

        if (navigator.serviceWorker.controller && !sessionStorage.getItem('swCleanupReloaded')) {
          sessionStorage.setItem('swCleanupReloaded', '1');
          window.location.reload();
        }
      };
      clearOldServiceWorkers();
    </script>
  </head>

  <%# Logic check: Only show App Bar/Menu if user is logged in and past the splash/auth screens %>
  <% is_authenticated_view = authenticated? && !controller_name.in?(%w[sessions registrations home onboarding]) %>

  <body class="bg-[#FCF9F7] font-['Montserrat'] antialiased h-full overflow-x-hidden">

    <% if is_authenticated_view %>
    <div data-controller="menu">
      <%# --- TOP APP BAR — constrained to mobile viewport --- %>
      <%# Settings controller auto-applies dark theme; any view can opt in via content_for(:header_dark) %>
      <% is_settings = controller_name == 'settings' %>
      <% dark_header = is_settings || content_for?(:header_dark) %>
      <% hdr_bg      = dark_header ? "bg-[#933a35]" : "bg-[#ede1d5]" %>
      <% bar_color   = dark_header ? "bg-white"     : "bg-[#933a35]" %>
      <% hdr_fg      = dark_header ? "text-white"   : "text-[#933a35]" %>
      <header class="fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-md h-20 <%= hdr_bg %> z-40 flex items-center px-4">

        <%# Left: custom back-arrow OR default hamburger %>
        <% if content_for?(:header_left) %>
          <%= yield(:header_left) %>
        <% else %>
          <button class="p-2" data-action="click->menu#open">
            <div class="w-6 h-0.5 <%= bar_color %> mb-1.5 pointer-events-none"></div>
            <div class="w-6 h-0.5 <%= bar_color %> mb-1.5 pointer-events-none"></div>
            <div class="w-6 h-0.5 <%= bar_color %> pointer-events-none"></div>
          </button>
        <% end %>

        <%# Centre: custom title OR settings default (gear + "Settings") OR app name %>
        <div class="flex-1 flex items-center justify-center gap-2">
    <% if content_for?(:page_title) %>
            <span class="<%= hdr_fg %> text-2xl font-medium font-['Montserrat']"><%= yield(:page_title) %></span>
          <% elsif is_settings %>
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="3" />
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
            </svg>
            <span class="text-white text-2xl font-medium font-['Montserrat']">Settings</span>
          <% else %>
            <span class="<%= hdr_fg %> text-xl font-medium tracking-wide font-['Montserrat']">Season</span>
          <% end %>
        </div>

        <%# Right: custom content OR settings 3-dot menu OR blank spacer %>
        <% if content_for?(:header_right) %>
          <%= yield(:header_right) %>
        <% elsif is_settings %>
          <button class="p-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="4" height="20" fill="white" viewBox="0 0 4 20">
              <circle cx="2" cy="2" r="1.5" />
              <circle cx="2" cy="10" r="1.5" />
              <circle cx="2" cy="18" r="1.5" />
            </svg>
          </button>
        <% else %>
          <div class="w-10"></div>
        <% end %>
      </header>

      <%= render "layouts/burger_menu" %>
    </div>
    <% end %>

    <main class="w-full flex-1 <%= is_authenticated_view ? 'pt-24' : '' %>">
      <div class="max-w-md mx-auto h-full">
        <%= yield %>
      </div>
    </main>

    <% if is_authenticated_view %>
      <%= render "shared/feedback_modal" %>
      <%= render "shared/quick_actions" %>
    <% end %>

  </body>
</html>
