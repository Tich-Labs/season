<!DOCTYPE html>
<html class="h-full bg-gray-100">
  <head>
    <title><%= content_for(:title).presence || "Admin — Season" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full font-['Montserrat'] antialiased">
    <div class="min-h-full flex">

      <%# ── Sidebar ── %>
      <aside class="w-56 flex-shrink-0 bg-[#933a35] flex flex-col">
        <%# Logo / wordmark %>
        <div class="h-16 flex items-center px-6 border-b border-[#7a2f2a]">
          <%= link_to admin_root_path, class: "text-white text-xl font-semibold tracking-wide" do %>
            Season <span class="text-[#f5ede8] text-xs font-normal ml-1">admin</span>
          <% end %>
        </div>

        <%# Nav links %>
        <nav class="flex-1 px-3 py-4 space-y-1">
          <% users_active    = controller_name == "users" %>
          <% signups_active  = controller_name == "launch_signups" %>
          <% inbox_active    = controller_name == "inbox" && action_name == "overview" %>
          <% feedback_active = controller_name == "inbox" && action_name == "feedback" %>
          <% bug_active      = controller_name == "inbox" && action_name == "bugs" %>
          <% support_active  = controller_name == "inbox" && action_name == "support" %>

          <%= link_to admin_users_path,
              class: class_names("flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
                                 "bg-[#7a2f2a] text-white" => users_active,
                                 "text-[#f5ede8] hover:bg-[#7a2f2a] hover:text-white" => !users_active) do %>
            <span aria-hidden="true">&#128100;</span>
            Users
          <% end %>

          <%= link_to admin_launch_signups_path,
              class: class_names("flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors",
                                 "bg-[#7a2f2a] text-white" => signups_active,
                                 "text-[#f5ede8] hover:bg-[#7a2f2a] hover:text-white" => !signups_active) do %>
            <span class="flex items-center gap-3">
              <span aria-hidden="true">&#128140;</span>
              Launch Signups
            </span>
            <span class="inline-flex items-center justify-center min-w-[20px] h-5 px-2 rounded-full text-[10px] font-bold leading-none bg-[#ede1d5] text-[#933a35]"><%= LaunchSignup.count %></span>
          <% end %>

          <%# Inbox — clicking goes to all messages; sub-items always visible below %>
          <div class="pt-2 space-y-0.5">
            <%= link_to admin_inbox_path,
                class: class_names("flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors",
                                   "bg-[#7a2f2a] text-white" => inbox_active,
                                   "text-[#f5ede8] hover:bg-[#7a2f2a] hover:text-white" => !inbox_active) do %>
              <span class="flex items-center gap-3">
                <span aria-hidden="true">&#128229;</span>
                Inbox
              </span>
              <span class="inline-flex items-center justify-center min-w-[20px] h-5 px-2 rounded-full text-[10px] font-bold leading-none <%= @stats[:total].to_i > 0 ? 'bg-[#ede1d5] text-[#933a35]' : 'bg-[#7a2f2a] text-[#f5ede8]' %>"><%= @stats[:total] %></span>
            <% end %>

            <div class="ml-4 space-y-0.5">
              <%= link_to admin_inbox_feedback_path,
                  class: class_names("flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors",
                                     "bg-[#7a2f2a] text-white" => feedback_active,
                                     "text-[#f5ede8] hover:bg-[#7a2f2a] hover:text-white" => !feedback_active) do %>
                <span>Feedback</span>
                <span class="text-xs opacity-60"><%= @stats[:feedback] %></span>
              <% end %>

              <%= link_to admin_inbox_bugs_path,
                  class: class_names("flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors",
                                     "bg-[#7a2f2a] text-white" => bug_active,
                                     "text-[#f5ede8] hover:bg-[#7a2f2a] hover:text-white" => !bug_active) do %>
                <span>Bugs</span>
                <span class="text-xs opacity-60"><%= @stats[:bugs] %></span>
              <% end %>

              <%= link_to admin_inbox_support_path,
                  class: class_names("flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium transition-colors",
                                     "bg-[#7a2f2a] text-white" => support_active,
                                     "text-[#f5ede8] hover:bg-[#7a2f2a] hover:text-white" => !support_active) do %>
                <span>Support</span>
                <span class="text-xs opacity-60"><%= @stats[:support] %></span>
              <% end %>
            </div>
          </div>
        </nav>

        <%# Footer: current user + sign out %>
        <div class="px-4 py-4 border-t border-[#7a2f2a] space-y-2">
          <p class="text-[#f5ede8] text-xs truncate"><%= current_user.email %></p>
          <%= link_to "← Back to app", root_path,
              class: "block text-center text-xs text-[#f5ede8] hover:text-white bg-[#7a2f2a] hover:bg-[#6a2824] rounded-lg px-3 py-2 transition-colors" %>
          <%= button_to "Sign out", admin_logout_path, method: :delete,
              class: "w-full text-center text-xs text-[#f5ede8] hover:text-white bg-transparent hover:bg-[#7a2f2a] rounded-lg px-3 py-2 transition-colors border-0 cursor-pointer" %>
        </div>
      </aside>

      <%# ── Main content ── %>
      <div class="flex-1 flex flex-col min-w-0">

        <%# Top bar %>
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 flex-shrink-0">
          <h1 class="text-lg font-semibold text-gray-800"><%= content_for?(:page_title) ? yield(:page_title) : "Admin" %></h1>
          <span class="text-xs text-gray-400">Season Admin Panel</span>
        </header>

        <%# Flash messages %>
        <% flash.each do |type, msg| %>
          <% bg = type.to_s == "alert" ? "bg-red-50 border-red-200 text-red-700" : "bg-green-50 border-green-200 text-green-700" %>
          <div class="mx-6 mt-4 px-4 py-3 rounded-lg border text-sm <%= bg %>"><%= msg %></div>
        <% end %>

        <%# Page content %>
        <main class="flex-1 p-6 overflow-auto">
          <%= yield %>
        </main>

      </div>
    </div>

  </body>
</html>
