<%# Burger menu drawer — extracted partial, rendered only for authenticated views.
    Controlled by menu_controller.js (data-menu-target="slider" / "panel"). %>
<div id="burger-menu"
     class="fixed inset-0 z-50 hidden justify-center"
     data-menu-target="slider">

  <%# Overlay — dismisses menu on tap %>
  <div class="absolute inset-0 bg-[#121212]/40" data-action="click->menu#close"></div>

  <%# Mobile viewport container — same max-w-md as content %>
  <div class="relative w-full max-w-md h-full">

    <%# Drawer panel — w-80 (320px) matches Figma pixel coordinates %>
    <div class="absolute left-0 top-0 bottom-0 w-80 bg-white shadow-2xl transform transition-transform duration-300 overflow-y-auto overflow-x-hidden"
         data-menu-target="panel">

      <div class="relative w-80 min-h-[720px]">

        <%# Close button — Figma: left-[250px] top-[27px] %>
        <button class="absolute left-[250px] top-[27px] size-11 bg-[#ede1d5] rounded-full flex items-center justify-center z-10"
                data-action="click->menu#close">
          <span class="text-[#933a35] text-2xl font-medium leading-none">X</span>
        </button>

        <%# Tulip icon — Figma: left-[123px] top-[49px] 66×71 %>
        <%= image_tag "screen1logo.png", class: "absolute left-[123px] top-[49px] w-[66px] h-[71px] object-contain" %>

        <%# Wordmark — Figma: left-[73px] top-[97px] 173×62 %>
        <%= image_tag "season-wortmarke-1.svg", class: "absolute left-[73px] top-[97px] w-[173px] h-[62px] object-contain" %>

        <%# Divider Line 19 — Figma: top-[187px] %>
        <div class="absolute left-0 top-[187px] w-80 h-px bg-[#ede1d5]"></div>

        <%# "Coming soon" badge — Figma: left-[214px] top-[190px] %>
        <div class="absolute left-[214px] top-[190px] w-24 h-4 bg-[#ede1d5] rounded-lg flex items-center justify-center z-20">
          <span class="text-[#933a35] text-xs font-normal tracking-wide">Coming soon</span>
        </div>

        <%# Premium box — Figma: left-[30px] top-[197px] w-64 h-20 %>
        <div class="absolute left-[30px] top-[197px] w-64 h-20 bg-[#933a35] rounded-lg z-10">
          <svg class="absolute left-[11.5px] top-[16px]" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="0.94">
            <path d="M1.5 8L3 3.5l2.5 3L8 2l2.5 4.5L13 3.5l-1.5 4.5H1.5z"/>
            <line x1="3" y1="11" x2="9" y2="11"/>
          </svg>
          <p class="absolute left-[28px] top-[11px] w-48 text-white text-base font-medium tracking-wide leading-snug">Get Season Premium now</p>
          <p class="absolute left-[28px] top-[51px] text-white text-xs font-light tracking-wide">for even more benefits!</p>
        </div>

        <%# Schedule Overview — Figma: top-[299px] %>
        <%= link_to "#", class: "absolute left-0 top-[299px] w-full h-[40px] flex items-center hover:bg-stone-50" do %>
          <div class="absolute left-[30px] top-[8px] w-[20px] flex flex-col gap-[1.5px]">
            <div class="flex gap-[1px] items-center"><div class="w-[3px] h-[4px] bg-[#933a35] rounded-[0.8px]"></div><div class="w-[15px] h-[4px] bg-[#933a35] rounded-[0.8px]"></div></div>
            <div class="flex gap-[1px] items-center"><div class="w-[3px] h-[4.5px] bg-[#933a35] rounded-[0.8px]"></div><div class="w-[15px] h-[4.5px] bg-[#933a35] rounded-[0.8px]"></div></div>
            <div class="flex gap-[1px] items-center"><div class="w-[3px] h-[4px] bg-[#933a35] rounded-[0.8px]"></div><div class="w-[15px] h-[4px] bg-[#933a35] rounded-[0.8px]"></div></div>
          </div>
          <span class="absolute left-[71px] top-[10px] text-[#933a35] text-base font-medium tracking-wide">Schedule Overview</span>
        <% end %>

        <%# Day-View — Figma: top-[339px] %>
        <%= link_to "#", class: "absolute left-0 top-[339px] w-full h-[40px] flex items-center hover:bg-stone-50" do %>
          <div class="absolute left-[30px] top-[8px] w-[20px] flex flex-col gap-[1px]">
            <div class="w-[19px] h-[2.5px] bg-[#933a35] rounded-[0.8px]"></div>
            <div class="w-[19px] h-[8px] bg-[#933a35] rounded-[0.8px]"></div>
            <div class="w-[19px] h-[2.5px] bg-[#933a35] rounded-[0.8px]"></div>
          </div>
          <span class="absolute left-[71px] top-[10px] text-[#933a35] text-base font-medium tracking-wide">Day-View</span>
        <% end %>

        <%# Weekly-View — Figma: top-[380px] %>
        <%= link_to "#", class: "absolute left-0 top-[380px] w-full h-[40px] flex items-center hover:bg-stone-50" do %>
          <div class="absolute left-[30px] top-[7px] w-[20px] flex gap-[1.4px]">
            <div class="w-[5.5px] h-[16px] bg-[#933a35] rounded-[0.8px]"></div>
            <div class="w-[5.5px] h-[16px] bg-[#933a35] rounded-[0.8px]"></div>
            <div class="w-[5.5px] h-[16px] bg-[#933a35] rounded-[0.8px]"></div>
          </div>
          <span class="absolute left-[71px] top-[10px] text-[#933a35] text-base font-medium tracking-wide">Weekly-View</span>
        <% end %>

        <%# Monthly-View — Figma: top-[420px] %>
        <%= link_to "#", class: "absolute left-0 top-[420px] w-full h-[40px] flex items-center hover:bg-stone-50" do %>
          <div class="absolute left-[30px] top-[7px] w-[19px] h-[16px] grid grid-cols-2 gap-[2px]">
            <div class="border border-[#933a35] rounded-[0.8px]"></div>
            <div class="border border-[#933a35] rounded-[0.8px]"></div>
            <div class="border border-[#933a35] rounded-[0.8px]"></div>
            <div class="border border-[#933a35] rounded-[0.8px]"></div>
          </div>
          <span class="absolute left-[71px] top-[10px] text-[#933a35] text-base font-medium tracking-wide">Monthly-View</span>
        <% end %>

        <%# Divider Line 20 — Figma: top-[461px] %>
        <div class="absolute left-0 top-[461px] w-80 h-px bg-[#ede1d5]"></div>

        <%# "Coming soon" badge 2 — Figma: left-[214px] top-[468px] %>
        <div class="absolute left-[214px] top-[468px] w-24 h-4 bg-[#ede1d5] rounded-lg flex items-center justify-center z-10">
          <span class="text-[#933a35] text-xs font-normal tracking-wide">Coming soon</span>
        </div>

        <%# E-Mail to partner — Figma: top-[471px] %>
        <a href="#" class="absolute left-0 top-[471px] w-full h-[38px] flex items-center hover:bg-stone-50">
          <svg class="absolute left-[30px] top-[7px]" width="20" height="17" viewBox="0 0 20 17" fill="none" stroke="#933a35" stroke-width="1.42">
            <rect x="1" y="1" width="18" height="14.5" rx="1.5"/>
            <path d="M1.5 1.5L10 9.5L18.5 1.5"/>
          </svg>
          <span class="absolute left-[71px] top-[10px] text-[#933a35] text-base font-medium tracking-wide">E-Mail to your partner</span>
        </a>

        <%# Divider Line 23 — Figma: top-[509px] %>
        <div class="absolute left-0 top-[509px] w-80 h-px bg-[#ede1d5]"></div>

        <%# Settings — Figma: top-[524px] %>
        <%= link_to edit_settings_path, class: "absolute left-0 top-[524px] w-full h-[49px] flex items-center hover:bg-stone-50" do %>
          <svg class="absolute left-[30px] top-[10px]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#933a35" stroke-width="1.2">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          <span class="absolute left-[71px] top-[15px] text-[#933a35] text-base font-medium tracking-wide">Settings</span>
        <% end %>

        <%# Feedback — Figma: top-[573px] %>
        <%= link_to "#", class: "absolute left-0 top-[573px] w-full h-[49px] flex items-center hover:bg-stone-50" do %>
          <svg class="absolute left-[31px] top-[10px]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#933a35" stroke-width="1.2">
            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 3 14 8 19 8"/>
            <line x1="9" y1="13" x2="15" y2="13"/>
            <line x1="9" y1="17" x2="15" y2="17"/>
          </svg>
          <span class="absolute left-[71px] top-[15px] text-[#933a35] text-base font-medium tracking-wide">Feedback</span>
        <% end %>

        <%# Bugreport — Figma: top-[621px] %>
        <%= link_to "#", class: "absolute left-0 top-[621px] w-full h-[49px] flex items-center hover:bg-stone-50" do %>
          <svg class="absolute left-[31px] top-[10px]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#933a35" stroke-width="1.2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            <line x1="9" y1="10" x2="15" y2="10"/>
            <line x1="12" y1="7" x2="12" y2="13"/>
          </svg>
          <span class="absolute left-[71px] top-[15px] text-[#933a35] text-base font-medium tracking-wide">Bugreport</span>
        <% end %>

        <%# Log out — Figma: top-[666px] %>
        <%= link_to session_path,
                    data: { turbo_method: :delete },
                    class: "absolute left-0 top-[666px] w-full h-[45px] flex items-center hover:bg-stone-50" do %>
          <svg class="absolute left-[30px] top-[9px]" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#933a35" stroke-width="1.5">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          <span class="absolute left-[71px] top-[13px] text-[#933a35] text-base font-medium tracking-wide">Log out</span>
        <% end %>

      </div>
    </div>
  </div>
</div>
