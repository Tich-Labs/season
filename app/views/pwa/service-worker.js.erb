const CACHE_NAME = 'season-v2-v1';
const ASSETS_TO_CACHE = [
  '/',
  '/manifest.json',
  '/assets/tailwind.css',
  '/icon.png',
  '/favicon.png'
];

// Install event - cache assets
self.addEventListener('install', (event) => {
  event.waitUntil(
    caches.open(CACHE_NAME).then((cache) => {
      return Promise.all(
        ASSETS_TO_CACHE.map((url) =>
          cache.add(url).catch((error) => {
            console.warn('Service worker cache failed:', url, error);
            return Promise.resolve();
          })
        )
      );
    })
  );
  self.skipWaiting();
});

// Activate event - clean old caches
self.addEventListener('activate', (event) => {
  event.waitUntil(
    caches.keys().then((cacheNames) => {
      return Promise.all(
        cacheNames.map((cacheName) => {
          if (cacheName !== CACHE_NAME) {
            return caches.delete(cacheName);
          }
        })
      );
    })
  );
  self.clients.claim();
});

// Fetch event - serve cached static assets only; use network for everything else.
self.addEventListener('fetch', (event) => {
  const request = event.request;
  const url = new URL(request.url);
  const isSameOrigin = url.origin === location.origin;
  const staticAsset = [
    '/',
    '/manifest.json',
    '/assets/tailwind.css',
    '/icon.png',
    '/favicon.png'
  ].includes(url.pathname) || url.pathname.startsWith('/assets/');

  if (request.method !== 'GET' || !isSameOrigin || request.mode === 'navigate' || !staticAsset) {
    event.respondWith(fetch(request));
    return;
  }

  event.respondWith(
    caches.match(request).then((response) => {
      if (response) return response;
      return fetch(request).then((networkResponse) => {
        const clone = networkResponse.clone();
        caches.open(CACHE_NAME).then((cache) => cache.put(request, clone));
        return networkResponse;
      });
    })
  );
});

// Listen for messages from the app
self.addEventListener('message', (event) => {
  if (event.data && event.data.type === 'SKIP_WAITING') {
    self.skipWaiting();
  }
});
