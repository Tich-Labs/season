<%#
  Locals:
    field_id   — String, id attribute for the input
    checked    — Boolean, initial state
    aria_label — String, screen-reader label
    onchange   — String (optional), inline JS handler e.g. "toggleSetting('key')"

  Renders a 44×24 accessible toggle switch using server-rendered state.
  Standardised size matches notification sub-screens (more finger-friendly than old 41×20).
%>
<label class="relative w-11 h-6 cursor-pointer flex-shrink-0"
       aria-label="<%= aria_label %>">
  <input type="checkbox"
         id="<%= field_id %>"
         role="switch"
         aria-checked="<%= checked %>"
         <%= "checked" if checked %>
         <%= "onchange=\"#{onchange}\"" if local_assigns[:onchange] %>
         class="opacity-0 w-0 h-0 absolute">
  <span class="absolute inset-0 rounded-full transition-colors duration-200" style="background:<%= checked ? '#933a35' : '#ccc' %>;"></span>
  <span class="absolute top-0.5 w-5 h-5 bg-white rounded-full shadow-sm transition-all duration-200" style="left:<%= checked ? '22px' : '2px' %>;"></span>
</label>
