<%# Shared feedback/bug report modal - slides up from bottom %>
<div id="feedback-modal-container"
     data-controller="feedback-modal"
     class="hidden fixed inset-0 z-60 bg-black/45 flex items-end justify-center p-0">

  <div class="bg-brand-background rounded-t-3xl p-8 pt-8 pb-32 w-full max-w-app relative">

    <%# Drag handle %>
    <div class="w-10 h-1 bg-[#D1C4C2] rounded mx-auto mb-6"></div>

    <%# Close %>
    <button type="button"
            data-action="click->feedback-modal#close"
            class="absolute top-5 right-5 bg-none border-none text-brand-secondary text-xl leading-none cursor-pointer p-1"
            aria-label="Close">&times;</button>

    <%# Heading %>
    <h2 id="fm-heading" class="font-montserrat text-xl font-bold text-brand-primary m-0 mb-1.5">Send Feedback</h2>
    <p id="fm-description" class="font-montserrat text-sm text-brand-secondary m-0 mb-5 leading-relaxed">Help us improve Season</p>

    <%# Form %>
    <form action="/feedbacks" method="post" enctype="multipart/form-data">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      <input type="hidden" id="feedback_type" name="feedback[type]" value="feedback">

      <%# Type toggle %>
      <div class="flex gap-2 mb-4">
        <button type="button"
                data-type="feedback"
                data-action="click->feedback-modal#selectType"
                class="fm-type-btn type-option flex-1 py-2 px-3 rounded-lg text-sm font-medium bg-[#f5ede8] text-[#933a35] border border-[#ede1d5] transition-colors">
          Feedback
        </button>
        <button type="button"
                data-type="bug_report"
                data-action="click->feedback-modal#selectType"
                class="fm-type-btn type-option flex-1 py-2 px-3 rounded-lg text-sm font-medium bg-[#f5ede8] text-[#933a35] border border-[#ede1d5] transition-colors">
          Bug
        </button>
        <button type="button"
                data-type="support"
                data-action="click->feedback-modal#selectType"
                class="fm-type-btn type-option flex-1 py-2 px-3 rounded-lg text-sm font-medium bg-[#f5ede8] text-[#933a35] border border-[#ede1d5] transition-colors">
          Support
        </button>
      </div>

      <%# Message textarea %>
      <textarea id="fm-message" name="feedback[message]"
                rows="4"
                required
                placeholder="Tell us more..."
                class="w-full px-4 py-3 rounded-xl border border-[#ede1d5] bg-white text-gray-800 text-sm font-['Montserrat'] placeholder-gray-400 focus:border-[#933a35] focus:ring-1 focus:ring-[#933a35] focus:outline-none resize-none"></textarea>

      <%# Attachment (screenshot/audio) %>
      <div class="mt-3">
        <label class="flex items-center gap-2 text-sm text-[#933a35] cursor-pointer hover:bg-[#f5ede8] px-3 py-2 rounded-lg transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
          </svg>
          <span>Add screenshot or audio</span>
          <input type="file" name="feedback[media]" accept="image/*,audio/*" class="hidden" data-action="change->feedback-modal#fileSelected">
        </label>
        <p id="attachment-name" class="text-xs text-gray-500 px-3 mt-1 truncate"></p>
      </div>

      <%# Submit button %>
      <button type="submit"
              class="w-full mt-4 py-3 bg-[#933a35] text-white rounded-xl text-base font-medium font-['Montserrat'] hover:bg-[#7a2f2a] transition-colors">
        Send
      </button>
    </form>
  </div>
</div>
