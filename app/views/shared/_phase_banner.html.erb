<%#
  Locals:
    phase     — String, cycle phase key ("menstrual","follicular","ovulation","luteal") or nil
    title     — String, main heading text
    subtitle  — String (optional), secondary line below title
    date      — Date (optional), shown formatted when provided

  Renders the standard phase-coloured top banner used across tracking, symptom
  and notification sub-screens. Falls back to brand red when phase is nil.
%>
<%
  meta   = CycleCalculatorService::PHASE_META[phase] || {}
  colour = meta[:colour] || "#933a35"
  season = meta[:season]
%>
<div class="p-6 pb-5 font-montserrat" style="background:<%= colour %>;">
  <% if season %>
    <p class="text-white font-semibold uppercase letter-spacing-wider m-0 mb-0.5 opacity-80">
      You are in your <%= season %>
    </p>
  <% end %>
  <h1 class="text-white font-bold m-0 mb-0.5 leading-tight">
    <%= title %>
  </h1>
  <% if local_assigns[:subtitle] %>
    <p class="text-white font-normal m-0 mt-1 opacity-85 leading-relaxed">
      <%= subtitle %>
    </p>
  <% end %>
  <% if local_assigns[:date] %>
    <p class="text-white font-normal m-0 mt-1 opacity-70">
      <%= date.strftime("%A, %-d %B %Y") %>
    </p>
  <% end %>
</div>
