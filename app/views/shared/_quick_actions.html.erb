<div data-controller="quick-actions">

  <%# ── Plus button — fixed bottom-centre ─────────────────────────────── %>
  <button data-action="click->quick-actions#open"
          class="fixed bottom-10 left-1/2 -translate-x-1/2 z-50
                 w-16 h-16 rounded-full bg-brand-field border-2 border-brand-primary
                 flex items-center justify-center
                 active:scale-95 transition-all duration-150 shadow-md"
          aria-label="<%= t('menu.quick_actions_label') %>">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.5"
         stroke-linecap="round" class="text-brand-primary" aria-hidden="true">
      <path d="M12 5v14M5 12h14"/>
    </svg>
  </button>

  <%# ── Backdrop + modal card — hidden by default ──────────────────────── %>
  <div data-quick-actions-target="overlay"
       data-action="click->quick-actions#clickBackdrop"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-sm">

    <div class="w-[380px] bg-white rounded-[29px] overflow-hidden flex flex-col relative">

      <%# Close button %>
      <button data-action="click->quick-actions#close"
              class="absolute top-4 right-4 w-11 h-11 bg-brand-field rounded-full
                     flex items-center justify-center
                     active:scale-95 transition-all duration-150"
              aria-label="<%= t('menu.close') %>">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" class="text-brand-primary" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>

      <%# Track my day %>
      <%= link_to tracking_index_path,
            class: "flex items-center px-7 h-[102px] text-brand-primary text-2xl font-medium font-['Montserrat'] hover:bg-brand-background transition-colors" do %>
        <%= t('menu.track_day') %>
      <% end %>

      <%# Divider %>
      <div class="h-px bg-stone-200 mx-6"></div>

      <%# Create appointment %>
      <%= link_to new_calendar_event_path,
            class: "flex items-center px-7 h-[102px] text-brand-primary text-2xl font-medium font-['Montserrat'] hover:bg-brand-background transition-colors" do %>
        <%= t('menu.create_appointment') %>
      <% end %>

    </div>
  </div>

</div>
