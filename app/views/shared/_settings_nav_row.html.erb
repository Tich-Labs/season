<%#
  Locals:
    href      — String, destination URL
    label     — String, row label text
    icon_svg  — String (optional), raw inline SVG markup (will be html_safe'd)
    subtitle  — String (optional), smaller secondary text below the label
    colour    — String (optional), override for label/icon colour (default #933a35)

  Renders a standard settings list row: icon · label · right chevron.
  Separated from border/divider so callers control spacing.
%>
<%
  row_colour = local_assigns.fetch(:colour, "#933a35")
%>
<a href="<%= href %>" class="flex items-center gap-4 py-4 no-underline">
  <% if local_assigns[:icon_svg] %>
    <span style="width:24px; height:24px; flex-shrink:0; color:<%= row_colour %>; display:flex; align-items:center; justify-content:center;">
      <%# erblint:disable:ErbSafety %>
      <%= icon_svg.html_safe %>
    </span>
  <% end %>
  <div style="flex:1;">
    <span class="font-medium" style="color:<%= row_colour %>; font-family:'Montserrat',sans-serif;">
      <%= label %>
    </span>
    <% if local_assigns[:subtitle] %>
      <span class="block text-brand-muted mt-1" style="font-family:'Montserrat',sans-serif;">
        <%= subtitle %>
      </span>
    <% end %>
  </div>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="<%= row_colour %>" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
    <polyline points="9 18 15 12 9 6" />
  </svg>
</a>
